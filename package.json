{
  "name": "hanif-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:app": "node node_modules/astro/bin/astro.mjs dev --host 127.0.0.1 --port ${PORT:-4321}",
    "dev:direct": "node node_modules/astro/bin/astro.mjs dev",
    "start": "node node_modules/astro/bin/astro.mjs dev",
    "check:projects": "node scripts/check-project-metadata.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "one-pager:pdf": "node scripts/export-one-pager-pdf.mjs",
    "build": "node node_modules/astro/bin/astro.mjs check && node node_modules/astro/bin/astro.mjs build",
    "preview": "node node_modules/astro/bin/astro.mjs preview",
    "astro": "node node_modules/astro/bin/astro.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^7.0.2",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.10",
    "typescript": "6.0.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@hyperframes/producer": "0.7.21",
    "@tailwindcss/typography": "^0.5.20",
    "baseline-browser-mapping": "^2.10.38",
    "husky": "^9.1.7",
    "hyperframes": "0.7.21",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "playwright-core": "^1.61.0"
  },
  "packageManager": "bun@1.3.8",
  "portless": {
    "name": "portfolio",
    "script": "dev:app",
    "appPort": 4321
  }
}
