{
	"name": "hanif-portfolio",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "portless",
		"dev:app": "astro dev --host 127.0.0.1 --port ${PORT:-4321}",
		"dev:direct": "astro dev",
		"start": "astro dev",
		"check:projects": "node scripts/check-project-metadata.mjs",
		"one-pager:pdf": "node scripts/export-one-pager-pdf.mjs",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "husky"
	},
	"portless": {
		"name": "portfolio",
		"script": "dev:app",
		"appPort": 4321
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@astrojs/tailwind": "^6.0.2",
		"astro": "^7.0.2",
		"sharp": "^0.35.2",
		"tailwindcss": "^3.4.10",
		"typescript": "6.0.3",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.20",
		"baseline-browser-mapping": "^2.10.38",
		"husky": "^9.1.7",
		"playwright-core": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1"
	},
	"packageManager": "bun@1.3.8"
}
