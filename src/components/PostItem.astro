---
import FormattedDate from './FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';

type BlogPost = CollectionEntry<'blog'>;
interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
const audienceLabel =
  post.data.audience === 'builder' ? 'Build Note' : 'For Founders and Operators';
---
<article class="grid gap-4 py-1 md:grid-cols-[160px_1fr_auto] md:items-start md:gap-6">
  <div class="space-y-2 text-sm text-zinc-600 dark:text-zinc-300">
    <FormattedDate date={post.data.pubDate} />
    <span class="inline-flex w-fit rounded-full border border-black/12 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.24em] text-zinc-600 dark:border-white/12 dark:text-zinc-300">
      {audienceLabel}
    </span>
  </div>
  <div class="space-y-3">
    <h3 class="heading-display heading-display--subsection text-zinc-900 dark:text-zinc-100">
      <a href={`/blog/${post.id}/`} class="transition-colors hover:text-primary">
        {post.data.title}
      </a>
    </h3>
    <p class="max-w-3xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
      {post.data.description}
    </p>
  </div>
  <div class="md:justify-self-end md:pt-1">
    <a href={`/blog/${post.id}/`} class="arrow-link">Read note</a>
  </div>
</article>
