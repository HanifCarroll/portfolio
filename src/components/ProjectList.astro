---
import type { ProjectCard } from '../lib/project-cards';

const { projects } = Astro.props;
---

<div class="space-y-16">
  {
    projects.map((project: ProjectCard) => (
      <article class="group border-t border-black/12 py-8 dark:border-white/12">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-4xl space-y-6">
              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-3">
                  <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                  {project.trackLabel}
                  </p>
                  {
                    project.year && (
                    <span class="text-sm text-zinc-500 dark:text-zinc-300">
                      {project.year}
                    </span>
                  )
                }
              </div>
              <h3 class="text-2xl font-bold text-zinc-900 transition-colors group-hover:text-primary dark:text-zinc-100">
                <a href={`/projects/${project.slug}/`}>
                  {project.name}
                </a>
              </h3>
              <p class="text-sm uppercase tracking-[0.18em] text-zinc-600 dark:text-zinc-300">
                {project.client}
              </p>
            </div>

            <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
              {project.description}
            </p>

            {
              project.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-md bg-zinc-100 px-3 py-1 text-sm font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </div>

          <div class="flex shrink-0 flex-wrap gap-3">
            <a href={`/projects/${project.slug}/`} class="arrow-link">
              View Case Study
            </a>
            {
              project.demoLink && (
                <a
                  href={project.demoLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-secondary"
                  data-track-event="project_live_site_clicked"
                  data-track-location="project_list"
                >
                  Live Site
                </a>
              )
            }
          </div>
        </div>
      </article>
    ))
  }
</div>
