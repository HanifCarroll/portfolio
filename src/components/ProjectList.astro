---
import type { ProjectCard } from '../lib/project-cards';

const { projects } = Astro.props;
---

<div class="space-y-16">
  {
    projects.map((project: ProjectCard) => (
      <article class="group border-t border-black/12 py-8 dark:border-white/12">
        <div class="grid gap-8 lg:grid-cols-[1.12fr_0.88fr] lg:gap-12">
          <div class="space-y-6">
            <div class="space-y-3">
              <div class="flex flex-wrap items-center gap-3">
                <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                  {project.trackLabel}
                </p>
                {
                  project.year && (
                    <span class="text-sm text-zinc-500 dark:text-zinc-300">
                      {project.year}
                    </span>
                  )
                }
              </div>
              <h3 class="heading-display text-3xl leading-[0.95] text-zinc-900 transition-colors group-hover:text-primary dark:text-zinc-100 md:text-4xl">
                <a href={`/projects/${project.slug}/`}>
                  {project.name}
                </a>
              </h3>
              <p class="text-sm uppercase tracking-[0.18em] text-zinc-600 dark:text-zinc-300">
                {project.client} · {project.service}
              </p>
            </div>

            <p class="max-w-3xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
              {project.description}
            </p>
          </div>

          <div class="space-y-6 border-t border-black/10 pt-5 dark:border-white/10 lg:border-t-0 lg:border-l lg:pl-8 lg:pt-0">
            <div class="space-y-3">
              <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                What changed
              </p>
              <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                {project.outcome}
              </p>
            </div>

            <div class="flex shrink-0 flex-wrap gap-3">
              <a href={`/projects/${project.slug}/`} class="arrow-link">
                View Case Study
              </a>
              {
                project.demoLink && (
                  <a
                    href={project.demoLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-secondary"
                    data-track-event="project_live_site_clicked"
                    data-track-location="project_list"
                  >
                    Live Site
                  </a>
                )
              }
            </div>
          </div>
        </div>
      </article>
    ))
  }
</div>
