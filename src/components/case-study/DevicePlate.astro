---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	alt: string;
	frame?: 'macbook' | 'ios';
}

const { image, alt, frame = 'macbook' } = Astro.props;
---

<figure class='case-study-detail__device-plate'>
	<div class={`device-frame device-frame--${frame}`}>
		{frame === 'ios' && <div class='device-frame__island' aria-hidden='true' />}
		<div class='device-frame__screen'>
			<Image src={image} alt={alt} class='device-frame__image' loading='eager' />
		</div>
		{frame !== 'ios' && <div class='device-frame__base' aria-hidden='true' />}
	</div>
</figure>
