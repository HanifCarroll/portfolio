---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	alt: string;
}

const { image, alt } = Astro.props;
---

<figure class='case-study-detail__image-plate'>
	<Image src={image} alt={alt} loading='lazy' class='case-study-detail__image-plate-img' />
</figure>
