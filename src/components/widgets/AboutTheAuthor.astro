---
import Author from '../Author.astro';

interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props as Props;
---

<div class:list={['about-the-author', compact && 'about-the-author--compact']}>
	<Author picSize={compact ? 'sm' : 'md'} />
	<div class:list={['author-desc mt-4 space-y-3 text-[0.95rem] leading-7 text-zinc-600 dark:text-zinc-300', compact && 'mt-3 space-y-0']}>
		<p>
			Hanif is a product engineer with 8+ years across web and mobile, now mostly building with LLMs. He likes owning the whole arc, from talking to users and shaping the product to designing the UX and shipping the code. Based in Buenos Aires, working US hours.
		</p>
		{
			!compact && (
				<p>His main stack is TypeScript, React, Next.js, Node.js, and React Native, with heavy AI/LLM work: RAG, agents, evals, and voice.</p>
			)
		}
	</div>
</div>
