---
import BaseHead from "./components/BaseHead.astro";
import Header from "./components/Header.astro";
import { BOOK_CALL_URL } from "../consts";

const { title, description, image, flushTop = false, showFooterCta = true } = Astro.props;

const currentYear = new Date().getFullYear();
const gtmId = import.meta.env.PUBLIC_GTM_CONTAINER_ID;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <BaseHead title={title} description={description} image={image} />
    </head>
    <body class="font-sans">
        {
            gtmId && (
                <noscript>
                    <iframe
                        src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
                        height="0"
                        width="0"
                        style="display:none;visibility:hidden"
                    ></iframe>
                </noscript>
            )
        }
        <Header />
        <div class:list={[
            "min-h-[calc(100vh-200px)]",
            flushTop ? "pb-12" : "py-12",
        ]}>
            <slot />
        </div>
        {
            showFooterCta && (
                <footer id="contact" class="bg-black dark:bg-white text-white dark:text-black border-t-2 border-black dark:border-white">
                    <div class="container py-20">
                <!-- Main Footer Grid -->
                <div class="bg-zinc-900 dark:bg-zinc-100 border-2 border-white dark:border-black p-6 md:p-8 shadow-[4px_4px_0_0_white] dark:shadow-[4px_4px_0_0_black]">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
                    <div class="lg:col-span-7 space-y-8">
                                <span class="section-label">// Work With Me</span>

                                <h2
                                    class="heading-display text-4xl md:text-5xl lg:text-6xl text-white dark:text-black"
                                >
                                    Need an MVP or automation system that actually ships?
                                </h2>

                                <p
                                    class="text-lg text-zinc-300 dark:text-zinc-600 leading-relaxed max-w-xl"
                                >
                                    Book a 30-minute roadmap call. We&rsquo;ll narrow the problem
                                    and figure out whether I&rsquo;m the right fit for it.
                                </p>

                                <div class="pt-2">
                                    <a
                                        class="btn-primary inline-block border-black bg-black px-6 py-3 text-white hover:bg-white hover:text-black focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 dark:border-black dark:bg-black dark:text-white dark:hover:bg-white dark:hover:text-black"
                                        href={BOOK_CALL_URL}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        data-track-event="book_call_clicked"
                                        data-track-location="footer_contact"
                                    >
                                        Book a Roadmap Call
                                    </a>
                                </div>
                    </div>

                    <!-- Right Column: Connect Links -->
                    <div
                        class="lg:col-span-5 lg:flex lg:flex-col lg:items-end lg:justify-end"
                    >
                        <div class="space-y-6">
                            <span class="section-label block lg:text-right">
                                // Connect
                            </span>
                            <nav class="flex flex-col gap-3">
                                <a
                                    class="group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end"
                                    href="mailto:HanifCarroll@gmail.com"
                                    data-track-event="email_clicked"
                                    data-track-location="footer_connect"
                                >
                                    <span
                                        class="h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary"
                                    ></span>
                                    Email
                                </a>
                                <a
                                    class="group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end"
                                    href="https://github.com/hanifcarroll"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <span
                                        class="h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary"
                                    ></span>
                                    GitHub
                                </a>
                                <a
                                    class="group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end"
                                    href="https://linkedin.com/in/hanifcarroll"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <span
                                        class="h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary"
                                    ></span>
                                    LinkedIn
                                </a>
                                <a
                                    class="group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end"
                                    href="https://x.com/hanifcarroll"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <span
                                        class="h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary"
                                    ></span>
                                    X / Twitter
                                </a>
                            </nav>
                        </div>
                    </div>
                </div>

                <!-- Bottom row -->
                <div class="font-mono text-sm text-zinc-400 dark:text-zinc-500 mt-8 pt-8 border-t border-zinc-700 dark:border-zinc-300">
                    &copy; {currentYear} HANIF CARROLL
                </div>
                </div>
            </div>
                </footer>
            )
        }
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            window.gtag =
                window.gtag ||
                function gtag() {
                    window.dataLayer.push(arguments);
                };

            const getLinkText = (link) =>
                (link.textContent || "").replace(/\s+/g, " ").trim();

            const toEventParams = (payload) => {
                const { event, ...eventParams } = payload;
                return eventParams;
            };

            const shouldDelayTrackedNavigation = (link, clickEvent) => {
                const href = link.getAttribute("href") || "";
                const opensNewTab =
                    link.target === "_blank" ||
                    clickEvent.metaKey ||
                    clickEvent.ctrlKey ||
                    clickEvent.shiftKey ||
                    clickEvent.altKey ||
                    clickEvent.button !== 0;

                if (opensNewTab) return false;
                if (href.startsWith("#") || href.startsWith("/#")) return false;

                return href.startsWith("mailto:") || /^https?:/i.test(href);
            };

            document.addEventListener("click", (event) => {
                if (!(event.target instanceof Element)) return;
                if (!(event instanceof MouseEvent)) return;

                const link = event.target.closest("a[data-track-event]");
                if (!(link instanceof HTMLAnchorElement)) return;

                const eventName = link.dataset.trackEvent;
                if (!eventName) return;

                const payload = {
                    event: eventName,
                    event_location: link.dataset.trackLocation || "unknown",
                    link_text: getLinkText(link),
                    link_url: link.href,
                    page_title: document.title,
                    page_path: window.location.pathname,
                };

                const href = link.getAttribute("href") || "";
                if (href.startsWith("mailto:")) {
                    payload.link_host = "mailto";
                } else {
                    try {
                        const url = new URL(link.href);
                        payload.link_host = url.host;
                        payload.link_path = url.pathname;
                    } catch {
                        // Ignore malformed URLs.
                    }
                }

                window.dataLayer.push(payload);

                const eventParams = {
                    ...toEventParams(payload),
                    transport_type: "beacon",
                };

                if (shouldDelayTrackedNavigation(link, event)) {
                    event.preventDefault();

                    let navigated = false;
                    const navigate = () => {
                        if (navigated) return;
                        navigated = true;
                        window.location.assign(link.href);
                    };

                    window.gtag("event", eventName, {
                        ...eventParams,
                        event_callback: navigate,
                    });

                    window.setTimeout(navigate, 250);
                    return;
                }

                window.gtag("event", eventName, eventParams);
            });
        </script>
    </body>
</html>
