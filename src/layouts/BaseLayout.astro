											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='/projects/'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												Case Studies
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='/about/'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												About
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='/tools/'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												Tools
											</a>
										</nav>
									</div>
									<div class='space-y-4'>
										<span class='section-label block lg:text-right'>// Connect</span>
										<nav class='flex flex-col gap-3'>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='mailto:HanifCarroll@gmail.com'
												data-track-event='email_clicked'
												data-track-location='footer_connect'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												Email
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='https://github.com/hanifcarroll'
												target='_blank'
												rel='noopener noreferrer'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												GitHub
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='https://linkedin.com/in/hanifcarroll'
												target='_blank'
												rel='noopener noreferrer'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												LinkedIn
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href={RESUME_URL}
												data-track-event='resume_clicked'
												data-track-location='footer_connect'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
												Resume
											</a>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
												href='https://x.com/hanifcarroll'
												target='_blank'
												rel='noopener noreferrer'
											>
												<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />X /
												Twitter
											</a>
										</nav>
									</div>
								</div>
							</div>
						</div>

						{/* Bottom row */}
						<div class='font-mono text-sm text-zinc-400 dark:text-zinc-500 mt-8 pt-8 border-t border-white/12 dark:border-black/12'>
							&copy; {currentYear} HANIF CARROLL
						</div>
					</div>
				</footer>
			)
		}
		{
			footerLinksOnly && !showFooterCta && (
				<footer
					id='contact'
					class='site-footer bg-[#090909] dark:bg-zinc-100 text-white dark:text-black border-t border-black/10 dark:border-white/10'
				>
					<div class='container py-12'>
						<div class='grid gap-8 sm:grid-cols-2'>
							<div class='space-y-4'>
								<span class='section-label block'>// Services</span>
								<nav class='flex flex-col gap-3'>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='/launch/'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										Services
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='/projects/'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										Case Studies
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='/about/'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										About
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='/tools/'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										Tools
									</a>
								</nav>
							</div>
							<div class='space-y-4'>
								<span class='section-label block'>// Connect</span>
								<nav class='flex flex-col gap-3'>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='mailto:HanifCarroll@gmail.com'
										data-track-event='email_clicked'
										data-track-location='footer_connect'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										Email
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='https://github.com/hanifcarroll'
										target='_blank'
										rel='noopener noreferrer'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										GitHub
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='https://linkedin.com/in/hanifcarroll'
										target='_blank'
										rel='noopener noreferrer'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										LinkedIn
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href={RESUME_URL}
										data-track-event='resume_clicked'
										data-track-location='footer_connect'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />
										Resume
									</a>
									<a
										class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary'
										href='https://x.com/hanifcarroll'
										target='_blank'
										rel='noopener noreferrer'
									>
										<span class='h-px w-6 bg-zinc-700 dark:bg-zinc-300 transition-all group-hover:w-10 group-hover:bg-primary' />X / Twitter
									</a>
								</nav>
							</div>
						</div>

						<div class='font-mono text-sm text-zinc-400 dark:text-zinc-500 mt-8 pt-8 border-t border-white/12 dark:border-black/12'>
							&copy; {currentYear} HANIF CARROLL
						</div>
					</div>
				</footer>
			)
		}
		<script is:inline>
			function fitHeadingToLines(title) {
				const rootFontSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
				const viewportWidth = window.innerWidth;
				const mobileMode = viewportWidth <= 768;
				const narrowMobileMode = viewportWidth <= 480;
				const maxLines = narrowMobileMode
					? Number.parseInt(title.dataset.fitLinesNarrowMobile || '4', 10)
					: mobileMode
						? Number.parseInt(title.dataset.fitLinesMobile || '4', 10)
						: Number.parseInt(title.dataset.fitLinesDesktop || '3', 10);
				const minRem = Number.parseFloat(title.dataset.fitMinRem || '1.8');
				const configuredMaxRem = Number.parseFloat(title.dataset.fitMaxRem || '4.85');
				const maxRem = narrowMobileMode
					? Math.min(configuredMaxRem, Number.parseFloat(title.dataset.fitMaxNarrowRem || '3.5'))
					: configuredMaxRem;
				const minPx = minRem * rootFontSize;
				const hardMaxPx = maxRem * rootFontSize;

				title.style.removeProperty('font-size');
				const cssBaselinePx = Number.parseFloat(getComputedStyle(title).fontSize) || hardMaxPx;
				const maxPx = Math.min(cssBaselinePx, hardMaxPx);

				title.style.fontSize = `${maxPx}px`;

				let low = minPx;
				let high = maxPx;
				let best = maxPx;

				for (let i = 0; i < 14; i++) {
					const mid = (low + high) / 2;
					title.style.fontSize = `${mid}px`;
					const computed = getComputedStyle(title);
					const lineHeight = Number.parseFloat(computed.lineHeight);
					const height = title.getBoundingClientRect().height;
					const lineCount = lineHeight > 0 ? Math.ceil(height / lineHeight - 0.02) : Infinity;
					const hasInlineOverflow = title.scrollWidth > title.clientWidth + 1;

					if (lineCount <= maxLines && !hasInlineOverflow) {
						best = mid;
						low = mid;
					} else {
						high = mid;
					}
				}

				title.style.fontSize = `${best}px`;
			}

			function setupHeadingFit() {
				const titles = Array.from(document.querySelectorAll('[data-fit-heading]'));
				if (titles.length === 0) return;

				const refitAll = () => {
					titles.forEach((title) => fitHeadingToLines(title));
				};

				refitAll();

				const resizeObserver = new ResizeObserver(() => {
					requestAnimationFrame(refitAll);
				});

				titles.forEach((title) => {
					const container = title.closest('[data-fit-container]') || title.parentElement;
					if (container) resizeObserver.observe(container);
				});

				window.addEventListener('resize', refitAll, { passive: true });
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', setupHeadingFit, { once: true });
			} else {
				setupHeadingFit();
			}
		</script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.gtag =
				window.gtag ||
				function gtag() {
					window.dataLayer.push(arguments);
				};

			const getLinkText = (link) => (link.textContent || '').replace(/\s+/g, ' ').trim();

			const toEventParams = (payload) => {
				const { event, ...eventParams } = payload;
				return eventParams;
			};

			const shouldDelayTrackedNavigation = (link, clickEvent) => {
				const href = link.getAttribute('href') || '';
				const opensNewTab =
					link.target === '_blank' ||
					clickEvent.metaKey ||
					clickEvent.ctrlKey ||
					clickEvent.shiftKey ||
					clickEvent.altKey ||
					clickEvent.button !== 0;

				if (opensNewTab) return false;
				if (href.startsWith('#') || href.startsWith('/#')) return false;

				return href.startsWith('mailto:') || /^https?:/i.test(href);
			};

			document.addEventListener('click', (event) => {
				if (!(event.target instanceof Element)) return;
				if (!(event instanceof MouseEvent)) return;

				const link = event.target.closest('a[data-track-event]');
				if (!(link instanceof HTMLAnchorElement)) return;

				const eventName = link.dataset.trackEvent;
				if (!eventName) return;

				const payload = {
					event: eventName,
					event_location: link.dataset.trackLocation || 'unknown',
					link_text: getLinkText(link),
					link_url: link.href,
					page_title: document.title,
					page_path: window.location.pathname
				};

				const href = link.getAttribute('href') || '';
				if (href.startsWith('mailto:')) {
					payload.link_host = 'mailto';
				} else {
					try {
						const url = new URL(link.href);
						payload.link_host = url.host;
						payload.link_path = url.pathname;
					} catch {
						// Ignore malformed URLs.
					}
				}

				window.dataLayer.push(payload);

				const eventParams = {
					...toEventParams(payload),
					transport_type: 'beacon'
				};

				if (shouldDelayTrackedNavigation(link, event)) {
					event.preventDefault();

					let navigated = false;
					const navigate = () => {
						if (navigated) return;
						navigated = true;
						window.location.assign(link.href);
					};

					window.gtag('event', eventName, {
						...eventParams,
						event_callback: navigate
					});

					window.setTimeout(navigate, 250);
					return;
				}

				window.gtag('event', eventName, eventParams);
			});
		</script>
	</body>
</html>
