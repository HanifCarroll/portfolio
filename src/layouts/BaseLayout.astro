									</a>
								</div>
							</div>

							{/* Right Column: Services + Connect Links */}
							<div class='lg:col-span-5 lg:flex lg:flex-col lg:items-end lg:justify-end'>
								<div class='space-y-10'>
									<div class='space-y-4'>
										<span class='section-label block lg:text-right'>// Services</span>
										<nav class='flex flex-col gap-3'>
											<a
												class='group flex items-center gap-3 font-mono text-sm uppercase tracking-wide transition-colors hover:text-primary lg:justify-end'
