---
import BaseHead from './components/BaseHead.astro';
import Header from './components/Header.astro';
import { BOOK_CALL_URL, RESUME_URL } from '../consts';

const {
	title,
	description,
	image,
	jsonLd,
	ogType,
	robots,
	flushTop = false,
	showFooterCta = true,
	footerLinksOnly = false,
	padContentBeforeFooter = true,
	bodyClass = ''
} = Astro.props;

const currentYear = new Date().getFullYear();
const gtmId = import.meta.env.PUBLIC_GTM_CONTAINER_ID;
---

<!doctype html>
<html lang='en' class='scroll-smooth'>
	<head>
		<BaseHead title={title} description={description} image={image} jsonLd={jsonLd} ogType={ogType} robots={robots} />
	</head>
	<body class:list={['font-sans', bodyClass]}>
		{
			gtmId && (
				<noscript>
					<iframe
						src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
						height='0'
						width='0'
						style='display:none;visibility:hidden'
					/>
				</noscript>
			)
		}
		<a class='skip-link' href='#main'>Skip to content</a>
		<Header />
		<main
			id='main'
			class:list={[
				'min-h-[calc(100vh-200px)]',
				flushTop ? ((showFooterCta || footerLinksOnly) && padContentBeforeFooter ? 'pb-12' : 'pb-0') : 'py-12'
			]}
		>
			<slot />
		</main>
		{
			showFooterCta && (
				<footer
					id='contact'
					class='site-footer bg-[#090909] dark:bg-zinc-100 text-white dark:text-black border-t border-black/10 dark:border-white/10'
				>
					<div class='container py-20'>
						<div class='grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8'>
							<div class='lg:col-span-7 space-y-8'>
								<span class='section-label'>// Work With Me</span>

