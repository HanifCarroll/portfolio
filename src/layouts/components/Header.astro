---
import HeaderLink from './HeaderLink.astro';
import { BOOK_CALL_URL } from '../../consts';

const navLinks = [
	{ href: '/launch/', label: 'Services' },
	{ href: '/projects/', label: 'Case Studies' },
	{ href: '/tools/', label: 'Tools' },
	{ href: '/about/', label: 'About' },
	{ href: '/blog/', label: 'Insights' }
];
---

<header
	class='sticky top-0 z-[1001] border-b border-black/10 bg-[#f2ede3]/92 backdrop-blur-md transition-colors duration-200 dark:border-white/10 dark:bg-[#090909]/92'
>
	<div class='container relative z-[70] flex items-center justify-between gap-4 py-4'>
		<a href='/' id='logoLink' class='flex flex-col transition hover:text-primary focus-visible:outline-none'>
			<span class='font-display text-lg font-semibold uppercase tracking-[0.18em]'> Hanif Carroll </span>
			<span class='font-mono text-[10px] uppercase tracking-[0.34em] text-zinc-500 dark:text-zinc-400'> Technical Product Partner </span>
		</a>

		<nav class='hidden items-center gap-8 lg:flex'>
			{navLinks.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
			<a
				href={BOOK_CALL_URL}
				class='inline-flex items-center justify-center gap-3 rounded-[0.35rem] border border-primary bg-primary px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.22em] text-white transition-colors duration-200 hover:border-primary-dark hover:bg-primary-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-[#f2ede3] dark:hover:border-primary-light dark:hover:bg-primary-light dark:focus-visible:ring-offset-[#090909]'
				target='_blank'
				rel='noopener noreferrer'
				data-track-event='book_call_clicked'
				data-track-location='header_primary'
			>
				Book a Roadmap Call
				<span aria-hidden='true' class='text-base leading-none'>→</span>
			</a>
		</nav>

		<button
			class='inline-flex h-10 w-10 items-center justify-center border-2 border-black text-black transition hover:bg-black hover:text-white dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black lg:hidden'
			id='mobileMenuToggle'
			aria-label='Toggle navigation'
			aria-expanded='false'
			aria-controls='mobileMenu'
		>
			<svg
				class='menu-icon'
				xmlns='http://www.w3.org/2000/svg'
				width='18'
				height='18'
				viewBox='0 0 24 24'
				fill='none'
				stroke='currentColor'
				stroke-width='2'
				stroke-linecap='round'
				stroke-linejoin='round'
			>
				<line x1='4' x2='20' y1='6' y2='6'></line>
				<line x1='4' x2='20' y1='12' y2='12'></line>
				<line x1='4' x2='20' y1='18' y2='18'></line>
			</svg>
			<svg
				class='close-icon hidden'
				xmlns='http://www.w3.org/2000/svg'
				width='18'
				height='18'
				viewBox='0 0 24 24'
				fill='none'
				stroke='currentColor'
				stroke-width='2'
				stroke-linecap='round'
				stroke-linejoin='round'
			>
				<path d='M18 6 6 18'></path>
				<path d='m6 6 12 12'></path>
			</svg>
		</button>
	</div>

	<script is:inline>
		const root = document.documentElement;
		const darkModeMedia = typeof window.matchMedia === 'function' ? window.matchMedia('(prefers-color-scheme: dark)') : null;

		const applySystemTheme = (isDark) => {
			root.classList.toggle('dark', Boolean(isDark));
		};

		applySystemTheme(darkModeMedia?.matches);

		try {
			localStorage.removeItem('theme');
		} catch {}

		if (darkModeMedia) {
			const handleThemeChange = (event) => applySystemTheme(event.matches);
			if (typeof darkModeMedia.addEventListener === 'function') {
				darkModeMedia.addEventListener('change', handleThemeChange);
			} else {
				darkModeMedia.onchange = handleThemeChange;
			}
		}

		const setupHeaderInteractions = () => {
			const mobileToggle = document.getElementById('mobileMenuToggle');
			const mobileMenu = document.getElementById('mobileMenu');
			const menuIcon = mobileToggle?.querySelector('.menu-icon');
			const closeIcon = mobileToggle?.querySelector('.close-icon');
			let lockedScrollY = 0;
			let menuCloseTimer;
			let scrollLockStyles;
			const reducedMotionMedia = window.matchMedia('(prefers-reduced-motion: reduce)');
			const menuCloseDelay = () => (reducedMotionMedia.matches ? 0 : 220);

			const lockScroll = () => {
				if (scrollLockStyles) return;
				lockedScrollY = window.scrollY || window.pageYOffset || 0;
				const scrollbarWidth = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
				scrollLockStyles = {
					rootOverflow: document.documentElement.style.overflow,
					rootScrollbarGutter: document.documentElement.style.scrollbarGutter,
					rootScrollBehavior: document.documentElement.style.scrollBehavior,
					bodyPosition: document.body.style.position,
					bodyTop: document.body.style.top,
					bodyLeft: document.body.style.left,
					bodyRight: document.body.style.right,
					bodyWidth: document.body.style.width,
					bodyPaddingRight: document.body.style.paddingRight
				};
				document.documentElement.style.overflow = 'hidden';
				document.documentElement.style.scrollbarGutter = 'stable';
				document.body.style.position = 'fixed';
				document.body.style.top = `-${lockedScrollY}px`;
				document.body.style.left = '0';
				document.body.style.right = '0';
				document.body.style.width = '100%';
				if (scrollbarWidth > 0) {
					document.body.style.paddingRight = `${scrollbarWidth}px`;
				}
			};

			const unlockScroll = () => {
				if (!scrollLockStyles) return;
				document.documentElement.style.scrollBehavior = 'auto';
				document.documentElement.style.overflow = scrollLockStyles.rootOverflow;
				document.documentElement.style.scrollbarGutter = scrollLockStyles.rootScrollbarGutter;
				document.body.style.position = scrollLockStyles.bodyPosition;
				document.body.style.top = scrollLockStyles.bodyTop;
				document.body.style.left = scrollLockStyles.bodyLeft;
				document.body.style.right = scrollLockStyles.bodyRight;
				document.body.style.width = scrollLockStyles.bodyWidth;
				document.body.style.paddingRight = scrollLockStyles.bodyPaddingRight;
				const previousScrollBehavior = scrollLockStyles.rootScrollBehavior;
				scrollLockStyles = undefined;
				window.scrollTo({ top: lockedScrollY, left: 0, behavior: 'auto' });
				requestAnimationFrame(() => {
					document.documentElement.style.scrollBehavior = previousScrollBehavior;
				});
			};

			const setMobileMenuOpen = (isOpen) => {
				if (!mobileMenu) return;
				window.clearTimeout(menuCloseTimer);
				if (isOpen) {
					mobileMenu.dataset.state = 'closed';
					mobileMenu.removeAttribute('hidden');
					requestAnimationFrame(() => {
						mobileMenu.dataset.state = 'open';
					});
					menuIcon?.classList.add('hidden');
					closeIcon?.classList.remove('hidden');
					mobileToggle?.setAttribute('aria-expanded', 'true');
					lockScroll();
				} else {
					mobileMenu.dataset.state = 'closing';
					menuIcon?.classList.remove('hidden');
					closeIcon?.classList.add('hidden');
					mobileToggle?.setAttribute('aria-expanded', 'false');
					menuCloseTimer = window.setTimeout(() => {
						mobileMenu.setAttribute('hidden', 'true');
						mobileMenu.dataset.state = 'closed';
						unlockScroll();
					}, menuCloseDelay());
				}
			};

			mobileToggle?.addEventListener('click', () => {
				if (!mobileMenu) return;
				setMobileMenuOpen(mobileMenu.hasAttribute('hidden'));
			});

			mobileMenu?.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => {
					setMobileMenuOpen(false);
				});
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && mobileMenu && !mobileMenu.hasAttribute('hidden')) {
					setMobileMenuOpen(false);
					mobileToggle?.focus();
				}
			});

			window.addEventListener('resize', () => {
				if (window.innerWidth >= 1024 && mobileMenu && !mobileMenu.hasAttribute('hidden')) {
					setMobileMenuOpen(false);
				}
			});

			const handleHomeClick = (e) => {
				const currentPath = window.location.pathname;
				if (currentPath === '/') {
					e.preventDefault();
					window.scrollTo({ top: 0, behavior: 'smooth' });
				}
			};

			const logoLink = document.getElementById('logoLink');
			logoLink?.addEventListener('click', handleHomeClick);
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', setupHeaderInteractions, { once: true });
		} else {
			setupHeaderInteractions();
		}
	</script>
</header>

<div
	class='fixed inset-0 z-[1000] min-h-dvh overflow-y-auto bg-[#f2ede3] pt-[6.5rem] dark:bg-[#090909] lg:hidden'
	id='mobileMenu'
	data-state='closed'
	hidden
>
	<nav class='container flex min-h-[calc(100dvh-6.5rem)] flex-col gap-6 py-8'>
		{
			navLinks.map((link, index) => (
				<a
					href={link.href}
					class='text-2xl font-display font-semibold uppercase tracking-[0.12em] transition hover:text-primary'
					data-mobile-menu-item
					style={`--mobile-menu-index: ${index}`}
				>
					{link.label}
				</a>
			))
		}
		<a
			href={BOOK_CALL_URL}
			class='mt-4 inline-flex w-fit items-center justify-center gap-3 rounded-[0.35rem] border border-primary bg-primary px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.22em] text-white transition-colors duration-200 hover:border-primary-dark hover:bg-primary-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-[#f2ede3] dark:hover:border-primary-light dark:hover:bg-primary-light dark:focus-visible:ring-offset-[#090909]'
			target='_blank'
			rel='noopener noreferrer'
			data-track-event='book_call_clicked'
			data-track-location='header_mobile'
			data-mobile-menu-item
			style={`--mobile-menu-index: ${navLinks.length}`}
		>
			Book a Roadmap Call
			<span aria-hidden='true' class='text-base leading-none'>→</span>
		</a>
	</nav>
</div>

<style>
	#mobileMenu {
		opacity: 0;
		transition: opacity 180ms ease-in;
	}

	#mobileMenu[data-state='open'] {
		opacity: 1;
		transition-duration: 220ms;
		transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
	}

	#mobileMenu[data-state='closing'] {
		opacity: 0;
	}

	#mobileMenu [data-mobile-menu-item] {
		opacity: 0;
		transform: translateY(12px);
		transition:
			opacity 180ms ease-in,
			transform 180ms ease-in;
		transition-delay: 0ms;
	}

	#mobileMenu[data-state='open'] [data-mobile-menu-item] {
		opacity: 1;
		transform: translateY(0);
		transition-duration: 240ms;
		transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: calc(var(--mobile-menu-index) * 32ms + 55ms);
	}

	#mobileMenu[data-state='closing'] [data-mobile-menu-item] {
		opacity: 0;
		transform: translateY(8px);
	}

	@media (prefers-reduced-motion: reduce) {
		#mobileMenu,
		#mobileMenu [data-mobile-menu-item] {
			transition: none;
			transition-delay: 0ms;
			transform: none;
		}
	}
</style>
