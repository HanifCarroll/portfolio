---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL_URL } from '../consts';

const title = 'About Hanif Carroll';
const description =
	'Product engineer helping founders and teams turn AI product ideas into shipped software. Based in Buenos Aires, working US hours through HC Studio.';

const workingStyle = [
	{
		title: 'I start with the real constraint.',
		body: 'Good products usually begin with the actual bottleneck, not a long feature list. That is usually where the leverage is.'
	},
	{
		title: 'I reduce before I build.',
		body: 'The first version should be smaller and sharper than what most teams aim for. That is how good products stay shippable.'
	},
	{
		title: 'I explain tradeoffs directly.',
		body: 'Scope, UX, architecture, and implementation decisions only help if they are understandable. I do not hide the reasoning behind technical language.'
	}
];

const backgroundMoments = [
	{
		label: 'Capgemini',
		body: 'Learned structured delivery, stakeholder management, and how larger organizations make decisions when the systems are real.'
	},
	{
		label: 'LeagueApps',
		body: 'Worked as a front end engineer inside a strong product team, keeping growth, UX, and implementation connected.'
	},
	{
		label: 'HC Studio',
		body: 'My US LLC for working with founders and teams on AI-powered products, MVPs, and internal tools.'
	}
];
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='content-page container max-w-4xl'>
		<header class='content-page__hero'>
			<h1 class='content-page__title'>
				I help founders and teams build and launch AI-powered products.
			</h1>
			<p class='content-page__lede'>
				I’m an 8+ year full-stack product engineer who works closest to founders and users — shaping the product, narrowing scope, building
				the software, and getting it shipped.
			</p>
			<p class='content-page__lede'>
				I’m based in Buenos Aires and work US hours. US clients hire me through my LLC, HC Studio.
			</p>
			<p class='content-page__lede'>
				Recent projects include evolving an AI platform for Amazon sellers (first 100 paying customers), launching a Spanish reading
				app on iOS, Android, and web for a non-technical founder, and building Casamo — my own AI tool for remote workers choosing long-term
				stays.
			</p>
		</header>

		<section class='content-page__section' aria-labelledby='about-how-i-work'>
			<h2 id='about-how-i-work' class='content-page__heading'>How I work</h2>
			<p class='content-page__intro'>
				The real value isn’t just writing code — it’s knowing what to build, what to leave out, and how it should feel to use.
			</p>
			<dl class='content-page__list'>
				{
					workingStyle.map((item) => (
						<div class='content-page__item'>
							<dt>{item.title}</dt>
							<dd>{item.body}</dd>
						</div>
					))
				}
			</dl>
		</section>

		<section class='content-page__section' aria-labelledby='about-point-of-view'>
			<h2 id='about-point-of-view' class='content-page__heading'>Point of view</h2>
			<p class='content-page__intro'>
				I believe the most important part of using AI well is knowing what you actually want before you start building. AI can make you
				faster, but it can’t decide what matters.
			</p>
			<p class='content-page__intro'>
				I stay close to the people who will use the product. The best decisions usually come from real conversations, not assumptions. I
				also work best with real autonomy — when I can see the full problem, form an opinion, and move on it.
			</p>
			<p class='content-page__aside'>
				<a href='/point-of-view/' class='content-page__link'>Read the full notes</a>
			</p>
		</section>

		<section class='content-page__section' aria-labelledby='about-background'>
			<h2 id='about-background' class='content-page__heading'>Background</h2>
			<p class='content-page__intro'>
				I’ve worked across large delivery environments, product-led teams, and my own studio — places where owning the full outcome mattered
				as much as the code.
			</p>
			<dl class='content-page__list content-page__list--compact'>
				{
					backgroundMoments.map((item) => (
						<div class='content-page__item'>
							<dt>{item.label}</dt>
							<dd>{item.body}</dd>
						</div>
					))
				}
			</dl>
		</section>

		<section class='content-page__section' aria-labelledby='about-tools'>
			<h2 id='about-tools' class='content-page__heading'>Tools</h2>
			<p class='content-page__intro'>
				Along the way I've built tools to solve problems I kept running into: remote control for agent workflows, session recall, mailbox context, safer automation.
			</p>
			<p class='content-page__aside'>
				<a href='/tools/' class='content-page__link'>See tools and experiments</a>
			</p>
		</section>

		<section class='content-page__section content-page__section--closing' aria-labelledby='about-contact'>
			<h2 id='about-contact' class='content-page__heading'>Get in touch</h2>
			<p class='content-page__intro'>
				Building an AI product and want help shipping a focused first version? I take on contract and freelance work through my US LLC, HC
				Studio. The fastest way to reach me is by email.
			</p>
			<p class='content-page__aside'>
				<a
					href={EMAIL_URL}
					class='content-page__link'
					data-track-event='email_clicked'
					data-track-location='about_closing'
				>
					hanif@hanifcarroll.com
				</a>
			</p>
		</section>
	</article>
</BaseLayout>
