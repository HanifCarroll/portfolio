---
import BaseLayout from "../layouts/BaseLayout.astro";

const clientReasons = [
    "Direct access to the person shaping the product and building it.",
    "Product strategy, UX decisions, and pricing advice — not just code.",
    "A bias toward smaller, useful first versions instead of bloated v1s.",
    "Technical and business decisions explained in plain English.",
    "Help with go-to-market: marketing sites, positioning, and launch mechanics.",
    "Clean handoff, clear communication, and honest fit assessment.",
];

const title = "About Hanif Carroll";
const description =
    "I help nontechnical founders go from idea to launched product — product strategy, UX, pricing, full-stack engineering, and go-to-market support.";
---

<BaseLayout title={title} description={description}>
    <article class="container max-w-4xl space-y-16 py-10">
        <nav class="flex items-center gap-2 font-mono text-xs uppercase tracking-wide">
            <a href="/" class="transition-colors hover:text-primary">Home</a>
            <span class="text-zinc-400">/</span>
            <span class="text-primary">About</span>
        </nav>

        <header class="space-y-6">
            <span class="section-label">// About</span>
            <h1 class="heading-display text-4xl md:text-5xl">
                Product partner for founders who need more than a developer.
            </h1>
            <div class="tech-card p-6 md:p-8">
                <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
                    Most founders don&rsquo;t just need a developer. They need someone
                    who can look at their idea, figure out what the MVP should actually
                    be, advise on pricing and positioning, design the UX, build the
                    whole thing, and help them take it to market. That&rsquo;s what I do.
                    I&rsquo;ve been building software since 2017 across consulting,
                    product teams, and client projects.
                </p>
            </div>
        </header>

        <section class="grid gap-6 md:grid-cols-2">
            <div class="tech-card p-6 space-y-4">
                <h2 class="section-label">// Journey</h2>
                <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-300">
                    I&rsquo;ve worked at Capgemini, at LeagueApps during a strong growth
                    phase, and as an independent builder for client and internal
                    products. The mix has been useful: I understand structured delivery,
                    real product constraints, and the pace smaller teams need.
                </p>
                <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-300">
                    Buenos Aires has become home. Living here has shaped the way I
                    think about work, community, and the kinds of products worth
                    building.
                </p>
            </div>

            <div class="tech-card p-6 space-y-4">
                <h2 class="section-label">// How I Work</h2>
                <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-300">
                    I&rsquo;m strongest in TypeScript and full-stack product work, but
                    half the value I bring happens before code starts: scoping the MVP,
                    designing the user experience, advising on pricing and monetization,
                    and building the marketing site that positions the product.
                </p>
                <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-300">
                    I like direct communication, small useful first versions, and
                    product decisions explained in plain English. The goal is to build
                    the right thing, ship it, and help you get it in front of the right
                    people.
                </p>
            </div>
        </section>

        <section class="tech-card p-6 md:p-8 space-y-6">
            <h2 class="heading-display text-3xl md:text-4xl">Why clients hire me</h2>
            <div class="grid gap-4 md:grid-cols-2">
                {clientReasons.map((reason) => (
                    <p class="border-t border-black/10 pt-4 text-base leading-relaxed text-zinc-600 dark:border-white/10 dark:text-zinc-300">
                        {reason}
                    </p>
                ))}
            </div>
        </section>

        <section class="tech-card p-6 md:p-8 space-y-6">
            <h2 class="heading-display text-3xl md:text-4xl">Outside of Work</h2>
            <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-300">
                I&rsquo;ve been lifting weights for nearly 20 years, I play ultimate
                frisbee, and I care a lot about writing, philosophy, and building
                strong in-person communities. I also spend a lot of time thinking about
                how AI can help people perform better in real work, not just in demos.
            </p>
        </section>
    </article>
</BaseLayout>
