---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCallout from '../components/ServiceCallout.astro';
import TestimonialSupport from '../components/TestimonialSupport.astro';
import testimonials from '../../testimonials.json';
import sarahPhoto from '@src/assets/img/sarah.jpeg';

const clientReasons = [
	'You work directly with the person making the product and technical decisions.',
	'I help narrow the first useful version before the build gets bloated.',
	'Workflow, pricing, UX, and scope decisions are explained in plain English.',
	'The goal is useful software, not a long agency process.'
];

const engagementSteps = [
	{
		label: '01',
		title: 'Start with the bottleneck',
		body: 'The work usually starts with one question: what is slowing things down right now, a missing product, a messy workflow, or a system that no longer scales?'
	},
	{
		label: '02',
		title: 'Narrow the first useful version',
		body: 'Sometimes that means a fixed-scope MVP. Sometimes it means a workflow audit and a smaller internal tool. The point is to avoid solving the wrong problem.'
	},
	{
		label: '03',
		title: 'Build with direct feedback',
		body: 'You get direct access, short feedback loops, and one person accountable for the actual outcome.'
	}
];

const title = 'About Hanif Carroll';
const description =
	'I help founders and operator-led teams launch focused MVPs and fix operational bottlenecks with internal tools, workflow automation, and useful AI systems.';
const designTestimonial = testimonials.find((testimonial) => testimonial.name === 'Sarah Hibner');
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>About</span>
		</nav>

		<header class='max-w-4xl space-y-5'>
			<p class='section-label'>// About</p>
			<h1 class='heading-display text-4xl md:text-6xl'>Technical product partner for founders and operator-led teams.</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Most clients do not need more code. They need someone who can look at the business problem, cut the first useful version, and build
				the system that actually moves things forward.
			</p>
		</header>

		<section class='grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16'>
			<div class='space-y-4'>
				<p class='section-label'>// Background</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Builder first, not agency layer.</h2>
			</div>
			<div class='space-y-5 text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				<p>
					I&rsquo;ve worked at Capgemini, at LeagueApps during a strong growth phase, and as an independent builder across client and
					internal products. That mix has been useful: I understand structured delivery, real product constraints, and the pace smaller
					teams actually need.
				</p>
				<p>
					My strongest work sits between product judgment and implementation: MVP scoping, workflow cleanup, internal tools, automation, AI
					systems, and the go-to-market surface around them.
				</p>
				<p>
					A lot of the value happens before code starts. I help decide what the first version should be, what should wait, and what kind of
					system is actually worth building.
				</p>
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// How Engagements Start</p>
				<h2 class='heading-display text-3xl md:text-5xl'>The work usually moves through three questions.</h2>
			</div>
			<div class='how-we-work-grid'>
				{
					engagementSteps.map((step) => (
						<div class='how-we-work-step'>
							<p class='launch-meta text-primary'>Step {step.label}</p>
							<div class='space-y-3'>
								<h3 class='heading-display text-2xl md:text-3xl'>{step.title}</h3>
								<p class='max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{step.body}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section class='grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16'>
			<div class='space-y-4'>
				<p class='section-label'>// Why Clients Hire Me</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Useful software, explained clearly.</h2>
			</div>
			<ul class='fit-list'>
				{
					clientReasons.map((reason) => (
						<li>{reason}</li>
					))
				}
			</ul>
		</section>

		{
			designTestimonial && (
				<section>
					<TestimonialSupport
						quote={designTestimonial.supportText ?? designTestimonial.text}
						name={designTestimonial.name}
						role={designTestimonial.role}
						company={designTestimonial.company}
						image={sarahPhoto}
						label='Design collaboration note'
					/>
				</section>
			)
		}

		<section class='grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16'>
			<div class='space-y-4'>
				<p class='section-label'>// Outside Of Work</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Still grounded in building.</h2>
			</div>
			<div class='space-y-5 text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				<p>
					I&rsquo;ve been lifting weights for nearly 20 years, I play ultimate frisbee, and I care a lot about writing, philosophy, and
					building strong in-person communities.
				</p>
				<p>
					Buenos Aires has become home. Living here has shaped how I think about work, community, and the kinds of products worth building.
				</p>
				<p>
					I also spend a lot of time thinking about how AI can help people do better work in the real world, not just produce impressive
					demos.
				</p>
			</div>
		</section>

		<ServiceCallout context='blog' variant='general' location='about_page' />
	</article>
</BaseLayout>
