---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL_URL } from '../consts';

const title = 'About Hanif Carroll';
const description =
	'Product engineer with 8+ years across web and mobile. Based in Buenos Aires, working US hours. US clients contract through HC Studio, my LLC.';

const workingStyle = [
	{
		title: 'I start with the real constraint.',
		body: 'Most work should begin with the actual bottleneck, not the feature list. That is usually where the leverage is.'
	},
	{
		title: 'I reduce before I build.',
		body: 'The first version should be smaller and clearer than what most teams reach for at the start. That is how good products stay shippable.'
	},
	{
		title: 'I explain tradeoffs directly.',
		body: 'Scope, UX, architecture, and implementation decisions only help if they are understandable. I do not hide the reasoning behind technical language.'
	}
];

const backgroundMoments = [
	{
		label: 'Capgemini',
		body: 'Learned structured delivery, stakeholder management, and what larger organizations optimize for when the systems are real.'
	},
	{
		label: 'LeagueApps',
		body: 'Front end engineer inside a strong product team, where growth, UX, and implementation had to stay connected to each other.'
	},
	{
		label: 'HC Studio',
		body: 'My US LLC. I work with founders and small teams on MVPs, AI products, and internal tools — end to end, from scoping through shipped code.'
	}
];

const pointOfViewPreview = [
	{
		title: 'Know what you want before you ask AI to help.',
		body: 'AI can make you faster, but it cannot decide what matters for you.'
	},
	{
		title: 'Stay close to the person using it.',
		body: 'The useful product decisions usually hide in conversation with the user.'
	},
	{
		title: 'Autonomy matters because context decays.',
		body: 'I do my best work when I can see the problem, form a view, and act on it.'
	}
];
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='content-page container max-w-4xl'>
		<header class='content-page__hero'>
			<h1 class='content-page__title'>
				I'm an empathetic builder.
			</h1>
			<p class='content-page__lede'>
				8-year full-stack product engineer. I started in enterprise delivery, grew inside product teams, and now work closest to
				founders and users.
			</p>
			<p class='content-page__lede'>
				Based in Buenos Aires, working US hours. US clients contract with me through HC Studio, my LLC.
			</p>
			<p class='content-page__lede'>
				Recently I've helped pivot an Amazon seller platform into AI workflows, taken a nontechnical founder's Spanish reading app to web
				and mobile subscriptions, and started building Casamo, my own stay-decision tool for remote workers.
			</p>
		</header>

		<section class='content-page__section' aria-labelledby='about-how-i-work'>
			<h2 id='about-how-i-work' class='content-page__heading'>How I work</h2>
			<p class='content-page__intro'>
				The value is rarely just output. It is judgment about what to build, what to leave out, and how the thing feels to use.
			</p>
			<dl class='content-page__list'>
				{
					workingStyle.map((item) => (
						<div class='content-page__item'>
							<dt>{item.title}</dt>
							<dd>{item.body}</dd>
						</div>
					))
				}
			</dl>
		</section>

		<section class='content-page__section' aria-labelledby='about-point-of-view'>
			<h2 id='about-point-of-view' class='content-page__heading'>Point of view</h2>
			<dl class='content-page__list'>
				{
					pointOfViewPreview.map((item) => (
						<div class='content-page__item'>
							<dt>{item.title}</dt>
							<dd>{item.body}</dd>
						</div>
					))
				}
			</dl>
			<p class='content-page__aside'>
				<a href='/point-of-view/' class='content-page__link'>Read the full notes</a>
			</p>
		</section>

		<section class='content-page__section' aria-labelledby='about-background'>
			<h2 id='about-background' class='content-page__heading'>Background</h2>
			<p class='content-page__intro'>
				Large delivery environments, a product-led team, and my own studio, where owning the outcome mattered as much as the code.
			</p>
			<dl class='content-page__list content-page__list--compact'>
				{
					backgroundMoments.map((item) => (
						<div class='content-page__item'>
							<dt>{item.label}</dt>
							<dd>{item.body}</dd>
						</div>
					))
				}
			</dl>
		</section>

		<section class='content-page__section' aria-labelledby='about-tools'>
			<h2 id='about-tools' class='content-page__heading'>Tools</h2>
			<p class='content-page__intro'>
				Along the way I've built tools to solve problems I kept running into: remote control for agent workflows, session recall, mailbox context, safer automation.
			</p>
			<p class='content-page__aside'>
				<a href='/tools/' class='content-page__link'>See tools and experiments</a>
			</p>
		</section>

		<section class='content-page__section content-page__section--closing' aria-labelledby='about-contact'>
			<h2 id='about-contact' class='content-page__heading'>Get in touch</h2>
			<p class='content-page__intro'>
				If you're building a product and need someone who can own the arc — user conversations, product calls, UX, and code — email is the
				fastest way to reach me. I take on freelance and fractional engagements through HC Studio.
			</p>
			<p class='content-page__aside'>
				<a
					href={EMAIL_URL}
					class='content-page__link'
					data-track-event='email_clicked'
					data-track-location='about_closing'
				>
					hanif@hanifcarroll.com
				</a>
			</p>
		</section>
	</article>
</BaseLayout>
