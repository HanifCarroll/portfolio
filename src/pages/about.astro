---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL, RESUME_URL } from '../consts';

const title = 'About Hanif Carroll';
const description =
	'I help nontechnical founders and founder-led teams cut the first useful scope, launch focused MVPs, and keep product engineering moving.';

const strengths = [
	{
		label: 'Scope before sprawl',
		body: 'I help narrow the first useful version before the project turns into a bigger, slower, more expensive build than it needs to be.'
	},
	{
		label: 'Product judgment plus execution',
		body: 'The value is not just building. It is knowing what to build first, what to defer, and how to make the tradeoffs legible in plain English.'
	},
	{
		label: 'One accountable partner',
		body: 'You are not coordinating strategy, design, and engineering layers. You work directly with the person making the product and technical calls.'
	}
];

const workingStyle = [
	{
		title: 'I start with the bottleneck.',
		body: 'Most projects should begin with the business constraint, not the requested feature list. That is usually where the real leverage is.'
	},
	{
		title: 'I reduce before I build.',
		body: 'The first version should be smaller and clearer than what most teams ask for at the start. That is how good projects stay shippable.'
	},
	{
		title: 'I explain tradeoffs directly.',
		body: 'Scope, UX, pricing, architecture, and implementation decisions only help if they are understandable. I do not hide the reasoning behind technical language.'
	}
];

const backgroundMoments = [
	{
		label: 'Capgemini',
		body: 'Learned structured delivery, stakeholder management, and what larger organizations optimize for when the systems are real.'
	},
	{
		label: 'LeagueApps',
		body: 'Worked inside a strong product environment where growth, UX, and implementation had to stay connected to each other.'
	},
	{
		label: 'Independent work',
		body: 'Built across MVPs, launch sites, product systems, internal tools, and AI-enabled products where smaller teams needed judgment as much as code.'
	}
];

const evidenceLinks = [
	{ label: 'Resume', href: RESUME_URL, trackEvent: 'resume_clicked' },
	{ label: 'GitHub', href: 'https://github.com/hanifcarroll' },
	{ label: 'LinkedIn', href: 'https://linkedin.com/in/hanifcarroll' },
	{ label: 'Tools and experiments', href: '/tools/' },
	{ label: 'Email', href: 'mailto:HanifCarroll@gmail.com', trackEvent: 'email_clicked' }
];
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-12 py-10 md:space-y-16'>
		<header class='about-hero-copy space-y-6' data-fit-container>
			<h1 class='heading-display heading-display--hero about-hero-title' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='4.85'>
				I help founders and operator-led teams decide what to build first
			</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Most clients do not need more code. They need someone who can look at the business problem, cut the first useful version, and build
				a system that changes the way the work gets done.
			</p>
		</header>

		<section class='about-editorial-split'>
			<div class='space-y-4'>
				<h2 class='about-section-serif-heading'>Useful software, clearer decisions, less wasted motion</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					The difference is usually judgment, not just output. The work is to make the first useful scope obvious enough to build.
				</p>
			</div>
			<div class='about-positioning-list'>
				{
					strengths.map((item) => (
						<div class='about-positioning-item'>
							<p class='launch-meta about-card-label'>{item.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='about-working-style about-working-style--rows'>
			{
				workingStyle.map((item, index) => (
					<div class='about-working-style__item'>
						<p class='about-working-style__num'>{String(index + 1).padStart(2, '0')}</p>
						<div class='space-y-2'>
							<h3 class='about-working-style__title'>{item.title}</h3>
							<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					</div>
				))
			}
		</section>

		<section class='about-background-strip'>
			<div class='space-y-3'>
				<h2 class='heading-display heading-display--note'>Background</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					Larger delivery environments, product-led teams, and independent work where smaller teams needed judgment as much as code.
				</p>
			</div>
			<div class='about-background-rail'>
				{
					backgroundMoments.map((item) => (
						<div class='about-background-rail__item'>
							<p class='launch-meta about-card-label'>{item.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='about-tools-link'>
			<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				I also build local-first tools for agent-heavy work, mostly around remote control, session recall, mailbox context, and safer
				automation.
			</p>
			<a href='/tools/' class='arrow-link w-fit'>See tools and experiments</a>
		</section>

		<section class='about-evidence-path'>
			<div class='space-y-3'>
				<p class='section-label'>For recruiters</p>
				<h2 class='heading-display heading-display--note'>The product-engineer case in one place</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					Resume, code, tools, case studies, and contact links — the full picture in one scroll.
				</p>
			</div>
			<div class='home-evidence-links about-evidence-path__links' aria-label='Professional evidence links'>
				{
					evidenceLinks.map((link) => (
						<a
							href={link.href}
							target={link.href.startsWith('http') ? '_blank' : undefined}
							rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
							data-track-event={link.trackEvent ?? 'evidence_clicked'}
							data-track-location='about_evidence'
						>
							{link.label}
						</a>
					))
				}
			</div>
		</section>

		<section class='max-w-3xl space-y-5 pb-4'>
			<h2 class='heading-display heading-display--subsection'>
				If you need a first useful version, I can usually tell you where to start
			</h2>
			<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				The roadmap call is where I tell you whether this should be an MVP launch, fractional product engineering, or a smaller first step.
			</p>
			<a
				href={BOOK_CALL_URL}
				target='_blank'
				rel='noopener noreferrer'
				class='arrow-link w-fit'
				data-track-event='book_call_clicked'
				data-track-location='about_closing'
			>
				Book a Roadmap Call
			</a>
		</section>
	</article>
</BaseLayout>
