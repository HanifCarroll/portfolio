---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About Hanif Carroll';
const description =
	'I help nontechnical founders and operator-led teams cut the first useful scope, make the right product and workflow decisions, and build systems that are actually worth using.';

const strengths = [
	{
		label: 'Scope before sprawl',
		body: 'I help narrow the first useful version before the project turns into a bigger, slower, more expensive build than it needs to be.'
	},
	{
		label: 'Product judgment plus execution',
		body: 'The value is not just building. It is knowing what to build first, what to defer, and how to make the tradeoffs legible in plain English.'
	},
	{
		label: 'One accountable partner',
		body: 'You are not coordinating strategy, design, and engineering layers. You work directly with the person making the product and technical calls.'
	}
];

const workingStyle = [
	{
		title: 'I start with the bottleneck.',
		body: 'Most projects should begin with the business constraint, not the requested feature list. That is usually where the real leverage is.'
	},
	{
		title: 'I reduce before I build.',
		body: 'The first version should be smaller and clearer than what most teams ask for at the start. That is how good projects stay shippable.'
	},
	{
		title: 'I explain tradeoffs directly.',
		body: 'Scope, UX, pricing, workflow, and AI decisions only help if they are understandable. I do not hide the reasoning behind implementation language.'
	}
];

const clientReasons = [
	{
		label: 'Closer to a product partner than a vendor',
		body: 'The value is not just implementation. It is having someone in the room who can cut scope, challenge bad assumptions, and still carry the work through.'
	},
	{
		label: 'Senior judgment without a layered team',
		body: 'Clients usually want fewer handoffs, fewer rounds of translation, and fewer people between the problem and the build.'
	},
	{
		label: 'Clear tradeoffs in plain language',
		body: 'A lot of trust comes from making the why behind product, workflow, and technical decisions easy to understand before the build gets expensive.'
	}
];

const backgroundMoments = [
	{
		label: 'Capgemini',
		body: 'Learned structured delivery, stakeholder management, and what larger organizations optimize for when the systems are real.'
	},
	{
		label: 'LeagueApps',
		body: 'Worked inside a strong product environment where growth, UX, and implementation had to stay connected to each other.'
	},
	{
		label: 'Independent work',
		body: 'Built across MVPs, launch sites, workflow systems, internal tools, and AI-enabled products where smaller teams needed judgment as much as code.'
	}
];
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>About</span>
		</nav>

		<header class='about-hero-grid'>
			<div class='about-hero-copy space-y-5'>
				<p class='section-label'>// About</p>
				<h1 class='heading-display about-hero-title text-4xl md:text-6xl'>I help founders and operator-led teams make the right first system.</h1>
				<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
					Most clients do not need more code. They need someone who can look at the business problem, cut the first useful version, and
					build the system that actually moves things forward.
				</p>
			</div>
			<div class='about-hero-note'>
				<p class='section-label'>// Working Thesis</p>
				<p class='heading-display text-2xl md:text-3xl'>Most projects get better when the first step gets smaller.</p>
			</div>
		</header>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// What I Do Best</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Useful software, clearer decisions, less wasted motion.</h2>
			</div>
			<div class='about-strengths-grid'>
				{strengths.map((item) => (
					<div class='about-strength-card'>
						<p class='launch-meta text-primary'>{item.label}</p>
						<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
					</div>
				))}
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// How I Work</p>
				<h2 class='heading-display text-3xl md:text-5xl'>The working style matters as much as the stack.</h2>
			</div>
			<div class='about-working-style'>
				{workingStyle.map((item, index) => (
					<div class:list={['about-working-style__item', index === 1 && 'about-working-style__item--offset']}>
						<p class='heading-display about-working-style__num text-primary'>{String(index + 1).padStart(2, '0')}</p>
						<div class='space-y-3'>
							<h3 class='heading-display text-2xl md:text-3xl'>{item.title}</h3>
							<p class='max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// Why Clients Hire Me</p>
				<h2 class='heading-display text-3xl md:text-5xl'>The difference is usually judgment, not just output.</h2>
			</div>
			<div class='about-reasons-grid'>
				{clientReasons.map((item) => (
					<div class='about-reasons-grid__item'>
						<p class='launch-meta text-primary'>{item.label}</p>
						<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
					</div>
				))}
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// Background</p>
				<h2 class='heading-display text-3xl md:text-5xl'>A mix of product, delivery, and independent execution.</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					The useful part of my background is not the logos. It is that I have seen how larger teams work, how product-led teams make
					decisions, and what smaller businesses actually need in order to ship something useful.
				</p>
			</div>
			<div class='about-background-rail'>
				{backgroundMoments.map((item) => (
					<div class='about-background-rail__item'>
						<p class='launch-meta text-primary'>{item.label}</p>
						<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
					</div>
				))}
			</div>
		</section>

		<section class='max-w-3xl space-y-5 pb-4'>
			<p class='section-label'>// Closing Note</p>
			<h2 class='heading-display text-3xl md:text-4xl'>If you need a first useful version, I can usually tell you where to start quickly.</h2>
			<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				The roadmap call is where I tell you whether this should start as an MVP, a workflow audit, or something smaller.
			</p>
			<a href='/launch' class='arrow-link w-fit'>Book a Roadmap Call</a>
		</section>
	</article>
</BaseLayout>
