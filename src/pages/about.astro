---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL_URL } from '../consts';

const title = 'About Hanif Carroll';
const description =
	'Product engineer with 8+ years across web and mobile, now mostly building with LLMs. I like owning the whole arc: talking to users, shaping the product, designing the UX, and shipping the code.';

const strengths = [
	{
		label: 'Close to the user',
		body: 'I do my best work when I can talk to the people we are building for, not just read a ticket. That is usually where the real product decisions hide.'
	},
	{
		label: 'The whole arc, one person',
		body: 'Scope, UX, architecture, and the code that ships. I like making those calls in the same conversation instead of throwing work over walls.'
	},
	{
		label: 'AI with judgment',
		body: 'Most of my recent work is with LLMs: RAG, agents, evals, and voice. The hard part is rarely the model. It is the product and UX choices around it.'
	}
];

const workingStyle = [
	{
		title: 'I start with the real constraint.',
		body: 'Most work should begin with the actual bottleneck, not the feature list. That is usually where the leverage is.'
	},
	{
		title: 'I reduce before I build.',
		body: 'The first version should be smaller and clearer than what most teams reach for at the start. That is how good products stay shippable.'
	},
	{
		title: 'I explain tradeoffs directly.',
		body: 'Scope, UX, architecture, and implementation decisions only help if they are understandable. I do not hide the reasoning behind technical language.'
	}
];

const backgroundMoments = [
	{
		label: 'Capgemini',
		body: 'Learned structured delivery, stakeholder management, and what larger organizations optimize for when the systems are real.'
	},
	{
		label: 'LeagueApps',
		body: 'Front end engineer inside a strong product team, where growth, UX, and implementation had to stay connected to each other.'
	},
	{
		label: 'HC Studio',
		body: 'My own studio, where I have shipped MVPs, taken AI products to paying customers, and built internal tools end to end.'
	}
];

---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-12 py-10 md:space-y-16'>
		<header class='about-hero-copy space-y-6' data-fit-container>
			<h1 class='heading-display heading-display--hero about-hero-title' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='4.85'>
				I'm an empathetic builder. I use technology to empower people.
			</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				I'm an 8-year full-stack product engineer based in Buenos Aires. I started in enterprise delivery, grew inside product teams,
				and now work closest to founders and users. Recently I've helped pivot an Amazon seller platform into AI workflows, taken a
				nontechnical founder's Spanish reading app to web and mobile subscriptions, and started building Casamo, my own stay-decision tool for remote workers.
			</p>
		</header>

		<section class='about-editorial-split'>
			<div class='space-y-4'>
				<h2 class='about-section-serif-heading'>How I work</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					The value is rarely just output. It is judgment about what to build, what to leave out, and how the thing feels to use.
				</p>
			</div>
			<div class='about-positioning-list'>
				{
					strengths.map((item) => (
						<div class='about-positioning-item'>
							<p class='launch-meta about-card-label'>{item.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='about-working-style about-working-style--rows'>
			{
				workingStyle.map((item, index) => (
					<div class='about-working-style__item'>
						<p class='about-working-style__num'>{String(index + 1).padStart(2, '0')}</p>
						<div class='space-y-2'>
							<h3 class='about-working-style__title'>{item.title}</h3>
							<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					</div>
				))
			}
		</section>

		<section class='about-editorial-split'>
			<div class='space-y-4'>
				<h2 class='about-section-serif-heading'>What I'm building toward</h2>
			</div>
			<div class='space-y-4 max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				<p>
					Long term, I want to build a product of my own that supports me and gives me room to help other people learn how to build.
					Buenos Aires has made that feel less abstract: a local indie hacker community, people trading feedback, people shipping real
					things. Casamo is my current practice ground for that.
				</p>
				<p>
					Right now, I'm looking for a team where I can use AI to solve real user problems without being far away from the customer,
					the product decisions, or the code.
				</p>
			</div>
		</section>

		<section class='about-working-style about-working-style--rows'>
			<div class='space-y-4'>
				<h2 class='about-section-serif-heading'>Point of view</h2>
			</div>
			{
				[
					{
						title: 'Know what you want before you ask AI to help.',
						body: 'AI can make you faster, but it cannot decide what matters for you. If you do not know who you are building for, you can build the wrong thing faster.'
					},
					{
						title: 'The first version is easier now. Choosing is still hard.',
						body: 'One person can get surprisingly far now. The hard part is choosing a real problem, finding the simplest shape for it, and getting it in front of people.'
					},
					{
						title: 'Stay close to the person using it.',
						body: 'The useful product decisions usually hide in conversation with the user. By the time a problem becomes a polished ticket, a lot of the meaning has already been lost.'
					},
					{
						title: 'Fast work needs guardrails.',
						body: 'Tests, linting, evals, automated QA, logs, and release checklists matter more when code is moving faster.'
					},
					{
						title: 'Autonomy matters because context decays.',
						body: 'I do my best work when I can see the problem, form a view, and act on it. Every handoff between observation and implementation loses something.'
					},
					{
						title: 'The indie hacker path is honest.',
						body: 'You either have something people want or you do not. Brutal, but clean.'
					}
				].map((item, index) => (
					<div class='about-working-style__item'>
						<p class='about-working-style__num'>{String(index + 1).padStart(2, '0')}</p>
						<div class='space-y-2'>
							<h3 class='about-working-style__title'>{item.title}</h3>
							<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					</div>
				))
			}
		</section>

		<section class='about-background-strip'>
			<div class='space-y-3'>
				<h2 class='heading-display heading-display--note'>Background</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					Large delivery environments, a product-led team, and my own studio, where owning the outcome mattered as much as the code.
				</p>
			</div>
			<div class='about-background-rail'>
				{
					backgroundMoments.map((item) => (
						<div class='about-background-rail__item'>
							<p class='launch-meta about-card-label'>{item.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='about-tools-link'>
			<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				Along the way I've built tools to solve problems I kept running into: remote control for agent workflows, session recall, mailbox context, safer automation. They're collected on the tools page.
			</p>
			<a href='/tools/' class='arrow-link w-fit'>See tools and experiments</a>
		</section>


		<section class='max-w-3xl space-y-5 pb-4'>
			<h2 class='heading-display heading-display--subsection'>
				If you're building something I might fit, I'd love to hear about it
			</h2>
			<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>
				I'm looking for a team building a product worth caring about, where an engineer who can own the whole arc would help. Email is
				the fastest way to reach me. I also take on select freelance and fractional work through HC Studio.
			</p>
			<a
				href={EMAIL_URL}
				class='arrow-link w-fit'
				data-track-event='email_clicked'
				data-track-location='about_closing'
			>
				Get in touch
			</a>
		</section>
	</article>
</BaseLayout>
