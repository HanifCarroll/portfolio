---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

type BlogPost = CollectionEntry<'blog'>;
const title = 'Insights on launching MVPs, fixing workflows, and using AI where it actually helps';
const description =
	'Notes for founders and operator-led teams deciding what to build, what to automate, and where AI is useful. Technical build notes are here too, but they support the client work rather than replace it.';

const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const supportingPosts = posts.slice(1, 4);
const editorialPosts = posts.slice(1);
const audienceLabel = (post: BlogPost) => (post.data.audience === 'builder' ? 'Build Note' : 'For Founders And Operators');
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Insights</span>
		</nav>

		<header class='max-w-5xl space-y-5'>
			<p class='section-label'>// Insights</p>
			<h1 class='heading-display text-4xl md:text-6xl'>Notes on products, workflows, and AI.</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Most of these posts come out of real product and client work. Some are for founders deciding what the first useful system should be.
				Others are build notes from the tooling, architecture, and debugging behind that work.
			</p>
		</header>

		{
			featuredPost && (
				<section class='insights-featured'>
					<div class='insights-featured__lead'>
						<div class='space-y-4'>
							<p class='section-label'>// Featured Note</p>
							<div class='flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-600 dark:text-zinc-300'>
								<FormattedDate date={featuredPost.data.pubDate} />
								<span class='launch-meta text-primary'>{audienceLabel(featuredPost)}</span>
							</div>
						</div>
						<div class='space-y-5'>
							<h2 class='heading-display text-4xl md:text-6xl'>
								<a href={`/blog/${featuredPost.id}/`} class='transition-colors hover:text-primary'>
									{featuredPost.data.title}
								</a>
							</h2>
							<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{featuredPost.data.description}</p>
							<a href={`/blog/${featuredPost.id}/`} class='arrow-link w-fit'>Read note</a>
						</div>
					</div>

					{
						supportingPosts.length > 0 && (
							<aside class='insights-featured__rail'>
								<p class='section-label'>// Recent Notes</p>
								<div class='insights-featured__rail-list'>
									{supportingPosts.map((post) => (
										<article class='insights-featured__rail-item'>
											<div class='flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-zinc-600 dark:text-zinc-300'>
												<FormattedDate date={post.data.pubDate} />
												<span class='launch-meta text-primary'>{audienceLabel(post)}</span>
											</div>
											<h3 class='heading-display text-2xl md:text-3xl'>
												<a href={`/blog/${post.id}/`} class='transition-colors hover:text-primary'>
													{post.data.title}
												</a>
											</h3>
											<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{post.data.description}</p>
										</article>
									))}
								</div>
							</aside>
						)
					}
				</section>
			)
		}

		{
			editorialPosts.length > 0 && (
				<section class='space-y-8 md:space-y-10'>
					<p class='section-label'>// Archive</p>

					<div class='insights-editorial-list'>
						{editorialPosts.map((post) => (
							<article class='insights-editorial-item'>
								<div class='insights-editorial-item__heading'>
									<div class='flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-600 dark:text-zinc-300'>
										<FormattedDate date={post.data.pubDate} />
										<span class='launch-meta text-primary'>{audienceLabel(post)}</span>
									</div>
									<h3 class='heading-display text-3xl md:text-5xl'>
										<a href={`/blog/${post.id}/`} class='transition-colors hover:text-primary'>
											{post.data.title}
										</a>
									</h3>
								</div>
								<div class='insights-editorial-item__body'>
									<p class='text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{post.data.description}</p>
									<div class='flex flex-wrap items-center gap-4'>
										<a href={`/blog/${post.id}/`} class='arrow-link'>Read note</a>
										{
											post.data.tags && post.data.tags.length > 0 && (
												<p class='launch-meta text-zinc-500 dark:text-zinc-400'>{post.data.tags.slice(0, 3).join(' / ')}</p>
											)
										}
									</div>
								</div>
							</article>
						))}
					</div>
				</section>
			)
		}

	</article>
</BaseLayout>
