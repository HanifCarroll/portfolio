---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostsByYear from '../../components/PostsByYear.astro';
import ServiceCallout from '../../components/ServiceCallout.astro';

type BlogPost = CollectionEntry<'blog'>;
const title = 'Notes on MVPs, Automation, and AI Agents';
const description =
  'Breakdowns from shipped product work, workflow automation projects, and the decisions behind useful AI systems.';

const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={title}
  description={description}
  showFooterCta={false}
  footerLinksOnly
>
  <div class='container max-w-6xl tech-card py-8 px-6 lg:px-10'>
    <div class="mb-10">
      <span class="section-label">// Insights</span>
      <h1 class="heading-display mt-3 text-4xl md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-3xl text-zinc-700 dark:text-zinc-300 text-lg leading-8">{description}</p>
    </div>
    <PostsByYear posts={posts}/>
    <div class="mt-12 border-t border-black/10 pt-10 dark:border-white/10">
      <ServiceCallout context="blog" variant="general" location="blog_index" />
    </div>
  </div>
</BaseLayout>
