---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

type BlogPost = CollectionEntry<'blog'>;
const title = 'Notes on products, workflows, and AI';
const description =
	'Notes for founders and operator-led teams deciding what to build, what to automate, and where AI is useful. Technical build notes are here too, but they support the client work rather than replace it.';

const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const audienceLabel = (post: BlogPost) => (post.data.audience === 'builder' ? 'Build note' : 'Founder note');
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Notes</span>
		</nav>

		<header class='max-w-5xl space-y-5'>
			<p class='section-label'>// Notes</p>
			<h1 class='heading-display heading-display--hero' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='4.85'>
				Notes on products, workflows, and AI.
			</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Field notes from product work, workflow systems, agent tooling, architecture decisions, and the debugging behind useful builds.
			</p>
		</header>

		{
			posts.length > 0 && (
				<section class='space-y-8 md:space-y-10'>
					<p class='section-label'>// Latest</p>

					<div class='insights-editorial-list'>
						{posts.map((post, index) => (
							<article class:list={['insights-editorial-item', index === 0 && 'insights-editorial-item--latest']}>
								<div class='insights-editorial-item__heading'>
									<div class='flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-600 dark:text-zinc-300'>
										<FormattedDate date={post.data.pubDate} />
										<span class='launch-meta text-primary'>{audienceLabel(post)}</span>
									</div>
									<h3 class='heading-display heading-display--section'>
										<a href={`/blog/${post.id}/`} class='transition-colors hover:text-primary'>
											{post.data.title}
										</a>
									</h3>
								</div>
								<div class='insights-editorial-item__body'>
									<p class='text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{post.data.description}</p>
									<a href={`/blog/${post.id}/`} class='arrow-link w-fit'>
										Read note
									</a>
								</div>
							</article>
						))}
					</div>
				</section>
			)
		}
	</article>
</BaseLayout>
