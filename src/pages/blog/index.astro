---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostItem from '../../components/PostItem.astro';
import ServiceCallout from '../../components/ServiceCallout.astro';

type BlogPost = CollectionEntry<'blog'>;
const title = 'Insights on launching MVPs, fixing workflows, and using AI where it actually helps';
const description =
	'Notes for founders and operator-led teams deciding what to build, what to automate, and where AI is useful. Technical build notes are here too, but they support the client work rather than replace it.';

const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const founderPosts = posts.filter((post) => post.data.audience === 'founder');
const builderPosts = posts.filter((post) => post.data.audience === 'builder');
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Insights</span>
		</nav>

		<header class='max-w-4xl space-y-5'>
			<p class='section-label'>// Insights</p>
			<h1 class='heading-display text-4xl md:text-6xl'>Notes on what to build, what to automate, and where AI actually helps.</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Most of this section is for founders and operator-led teams deciding what the first useful system should be. Some posts are technical
				build notes, but they are here to support the client work, not replace it.
			</p>
		</header>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// For Founders And Operators</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Start here if the product or workflow decision is still fuzzy.</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					These are the posts most likely to help you think through an MVP, an operations bottleneck, or whether AI belongs in the first
					solution at all.
				</p>
			</div>
			<div class='space-y-10'>
				{founderPosts.map((post) => <PostItem post={post} />)}
			</div>
		</section>

		{
			builderPosts.length > 0 && (
				<section class='space-y-8 md:space-y-10'>
					<div class='max-w-3xl space-y-4'>
						<p class='section-label'>// Build Notes</p>
						<h2 class='heading-display text-3xl md:text-5xl'>Technical notes behind the systems.</h2>
						<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
							Implementation details, tooling choices, and architecture notes from the kinds of products and workflow systems I build.
						</p>
					</div>
					<div class='space-y-10'>
						{builderPosts.map((post) => (
							<PostItem post={post} />
						))}
					</div>
				</section>
			)
		}

		<ServiceCallout context='blog' variant='general' location='blog_index' />
	</article>
</BaseLayout>
