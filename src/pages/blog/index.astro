---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

type BlogPost = CollectionEntry<'blog'>;
const title = 'Blog on products, workflows, and AI';
const description =
	'Blog posts for founders and operator-led teams deciding what to build, what to automate, and where AI is useful. Technical build posts are here too, but they support the client work rather than replace it.';

const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={title} description={description} showFooterCta={false} footerLinksOnly>
	<article class='content-page container max-w-4xl'>
		<header class='content-page__hero'>
			<h1 class='content-page__title'>Blog</h1>
			<p class='content-page__lede'>
				Field writing from product work, workflow systems, agent tooling, architecture decisions, and the debugging behind useful builds.
			</p>
		</header>

		{
			posts.length > 0 && (
				<section aria-label='Blog posts'>
					<div class='content-page__list'>
						{posts.map((post) => (
							<a
								class='content-page__entry content-page__entry--link'
								href={`/blog/${post.id}/`}
								aria-label={`Read ${post.data.title}`}
							>
								<p class='content-page__entry-date'>
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h2 class='content-page__entry-title'>{post.data.title}</h2>
								<p class='content-page__entry-body'>{post.data.description}</p>
							</a>
						))}
					</div>
				</section>
			)
		}
	</article>
</BaseLayout>
