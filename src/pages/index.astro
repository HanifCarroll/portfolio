---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL_URL } from '../consts';
import { HOMEPAGE_CASE_STUDY_SLUGS } from '../lib/project-curation';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import casamoPhoto from '@src/assets/img/projects/casamo-homepage-viewport.jpg';
import genruptPhoto from '@src/assets/img/projects/genrupt-creative-ops-photo.png';
import palabrunoPhoto from '@src/assets/img/projects/palabruno-reading-materials-photo.png';

const title = 'Hanif Carroll | Product Engineer';
const description =
	'I am a product engineer with 8+ years across web and mobile, now mostly building with LLMs. I own the whole arc: talking to users, shaping the product, designing the UX, and shipping the code.';

const homepageJsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		jobTitle: 'Product Engineer',
		description,
		sameAs: ['https://github.com/hanifcarroll', 'https://linkedin.com/in/hanifcarroll', 'https://x.com/hanifcarroll'],
		knowsAbout: ['Product engineering', 'AI products', 'LLMs', 'RAG', 'AI agents', 'React', 'Next.js', 'React Native', 'TypeScript']
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		description
	}
];

const caseStudyBySlug = {
	palabruno: {
		slug: 'palabruno',
		label: 'MVP build',
		title: 'Palabruno',
		body: 'Helped a nontechnical founder shape, build, and launch Palabruno: a Spanish reading app with mobile subscriptions, web payments for teachers, app store launch assets, UX polish, and public-site copy.',
		image: palabrunoPhoto,
		imageAlt: 'Spanish reading materials with vocabulary, grammar, and pronunciation cards.',
		imageClass: undefined
	},
	genrupt: {
		slug: 'genrupt',
		label: 'Product platform',
		title: 'Genrupt',
		body: 'Helped Genrupt move beyond demo-stage image and video generation by adding the commercial and reliability foundations needed for paid Amazon seller workflows.',
		image: genruptPhoto,
		imageAlt: 'E-commerce creative operations desk with packages, notes, and product materials.',
		imageClass: 'object-left-top'
	},
	casamo: {
		slug: 'casamo',
		label: 'Travel decision MVP',
		title: 'Casamo',
		body: 'Built a travel decision product that helps remote workers find the stay worth booking without opening 20 tabs or trusting misleading marketplace filters.',
		image: casamoPhoto,
		imageAlt: 'Casamo homepage showing the stay search form and audit priorities over a furnished apartment.',
		imageClass: 'object-left-top'
	}
} as const;

const caseStudies = HOMEPAGE_CASE_STUDY_SLUGS.map((slug) => caseStudyBySlug[slug]);

const testimonials = [
	{
		quote: 'Hanif quickly understood our needs, both from a business and aesthetic perspective, and translated them into a clean, functional website in no time.',
		name: 'Monica Londoño',
		role: 'Co-founder',
		company: 'Punto de Partida'
	},
	{
		quote: "He's reliable, communicates great, and has a sharp technical mind. Whether handling complex builds, troubleshooting under pressure, or adapting to shifting priorities, he was dependable every step of the way.",
		name: 'Markis Zarate',
		role: 'Founder',
		company: 'Zarate Studios'
	},
	{
		quote: 'He suggested design-to-engineering hand-off improvements to make our workflow more efficient, asked insightful follow-up questions during design reviews, and brought my Figma designs to life so we could deliver value to our users.',
		name: 'Sarah Hibner',
		role: 'Senior Product Designer',
		company: 'LeagueApps'
	}
];
---

<BaseLayout
	title={title}
	description={description}
	jsonLd={homepageJsonLd}
	flushTop
	showFooterCta={false}
	footerLinksOnly
	padContentBeforeFooter={false}
>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero'>
				<div class='home-hero-split'>
					<div class='home-hero-copy-wrap'>
						<div class='home-hero-copy'>
							<p class='home-hero-greeting'>Hey, I'm <span class='home-hero-greeting__name'>Hanif</span>.</p>
							<h1 class='home-hero-title'>
								<span>I build AI products,</span>
								<span>end to end.</span>
							</h1>
							<p class='home-hero-body'>
								Product engineer, eight years across web and mobile, now mostly building with LLMs: RAG, agents, evals, and MCP.
								I like being involved at every stage, from talking to users to shipping the code.
							</p>
							<div class='home-hero-actions'>
								<a
									class='home-hero-primary-link'
									href={EMAIL_URL}
									data-track-event='email_clicked'
									data-track-location='home_hero_primary'
								>
									Get in touch
								</a>
								<a class='home-hero-secondary-link' href='#case-studies'>See case studies</a>
							</div>
						</div>
					</div>

					<div class='home-hero-media'>
						<figure class='home-hero-image-wrap'>
							<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
						</figure>
					</div>
				</div>
			</header>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<h2 class='heading-display home-case-studies-title'>Case Studies</h2>
		</div>

		<div class='case-study-rows mt-8'>
			{
				caseStudies.map((study, index) => (
					<a href={`/projects/${study.slug}/`} class='case-study-row group'>
						<div class='case-study-row__copy'>
							<p class='case-study-row__eyebrow'>
								<span aria-hidden='true' />
								CASE STUDY {String(index + 1).padStart(2, '0')}
							</p>
							<div class='case-study-row__body'>
								<div class='space-y-5'>
									<h3 class='case-study-row__title'>{study.title}</h3>
									<p class='case-study-row__description'>{study.body}</p>
								</div>
								<span class='case-study-row__button'>View case study</span>
							</div>
						</div>
						<figure class='case-study-row__media'>
							<div class='case-study-row__image-frame'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={['case-study-row__image transition duration-700 ease-out group-hover:scale-[1.025]', study.imageClass]}
									loading='eager'
								/>
							</div>
						</figure>
					</a>
				))
			}

			<p class='case-study-archive-link'>
				<a href='/projects/'>See all case studies <span aria-hidden='true'>→</span></a>
			</p>
		</div>
	</section>

	<section class='home-testimonials-band' aria-labelledby='home-testimonials-title'>
		<div class='container home-testimonials'>
			<p class='home-testimonials__eyebrow' id='home-testimonials-title'>What people I've worked with say</p>
			<div class='home-testimonials__grid'>
				{
					testimonials.map((t) => (
						<figure class='home-testimonial'>
							<blockquote class='home-testimonial__quote'>
								<p>{t.quote}</p>
							</blockquote>
							<figcaption class='home-testimonial__attr'>
								<span class='home-testimonial__name'>{t.name}</span>
								<span class='home-testimonial__role'>
									{t.role}, {t.company}
								</span>
							</figcaption>
						</figure>
					))
				}
			</div>
		</div>
	</section>

	<section class='container home-about' aria-labelledby='home-about-title'>
		<div class='home-about__inner'>
			<h2 id='home-about-title' class='home-about__title'>A bit about me.</h2>
			<p class='home-about__body'>
				I started out as a software developer and grew into a product engineer: someone who cares as much about what we build and why
				as how it's built. I've shipped a Spanish reading app end to end, taken AI products from demo to paid, and done senior product
				engineering for teams like LeagueApps. I'm happiest close to users, making the call on scope, UX, and architecture in the same
				conversation, then shipping it.
			</p>
			<p class='home-about__location'>Based in Buenos Aires, working US hours.</p>
			<p class='home-about__location'>
				<a
					href='/about/'
					class='inline-flex items-center gap-1.5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500 transition-colors hover:text-primary dark:text-zinc-400'
				>
					More about me <span aria-hidden='true'>→</span>
				</a>
			</p>
		</div>
	</section>

	<section class='container home-about' aria-labelledby='home-pov-title'>
		<div class='home-about__inner'>
			<h2 id='home-pov-title' class='home-about__title'>Where I think this is going.</h2>
			<p class='home-about__body'>
				I care most about AI that keeps the person in the driver's seat. Not automation that quietly replaces people, but tools that
				make us better at creating, learning, and thinking for ourselves. Copilots for making things, tutors that actually teach, AI
				that can show up inside a real conversation. That's the kind of product I want to help build.
			</p>
		</div>
	</section>

	<section class='container home-fit-section' aria-labelledby='home-contact-title'>
		<div class='home-fit-section__inner'>
			<div class='space-y-3'>
				<h2 id='home-contact-title' class='home-fit-section__title'>Let's talk.</h2>
				<p class='home-fit-section__lede'>
					If you're building a product and want an engineer who can own it end to end, I'd love to hear about it.
				</p>
			</div>

			<div class='fit-actions'>
				<a
					class='home-hero-primary-link'
					href={EMAIL_URL}
					data-track-event='email_clicked'
					data-track-location='home_contact_primary'
				>
					Get in touch
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
