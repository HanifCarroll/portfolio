---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL, RESUME_URL } from '../consts';
import { HOMEPAGE_CASE_STUDY_SLUGS } from '../lib/project-curation';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import genruptPhoto from '@src/assets/img/projects/genrupt-creative-ops-photo.png';
import muchoHangoutsPhoto from '@src/assets/img/projects/mucho-hangouts-feature.png';
import palabrunoPhoto from '@src/assets/img/projects/palabruno-language-study-photo.png';

const title = 'Hanif Carroll | Product Engineer, Full Stack + AI';
const description =
	'I help founder-led teams turn rough SaaS ideas and manual workflows into useful launched software, with product judgment, full-stack engineering, and AI where it helps.';

const homepageJsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		jobTitle: 'Product Engineer, Full Stack + AI',
		description,
		sameAs: ['https://github.com/hanifcarroll', 'https://linkedin.com/in/hanifcarroll', 'https://x.com/hanifcarroll'],
		knowsAbout: ['Product engineering', 'MVP development', 'SaaS', 'workflow automation', 'AI systems']
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		description
	}
];

const pathCards = [
	{
		label: 'Product path',
		title: 'Launch a first version',
		body: 'For founders who need the first useful version scoped, built, and live.',
		href: '/launch/#mvp',
		cta: 'See the launch path'
	},
	{
		label: 'Workflow path',
		title: 'Diagnose the workflow',
		body: 'For teams that need to find the bottleneck before building software or adding AI.',
		href: '/launch/#automation',
		cta: 'See the audit path'
	}
];

const caseStudyBySlug = {
	palabruno: {
		slug: 'palabruno',
		label: 'MVP build',
		title: 'Palabruno',
		body: 'Helped a nontechnical founder shape, build, and launch Palabruno: a Spanish reading app with mobile subscriptions, web payments for teachers, app store launch assets, UX polish, and public-site copy.',
		outcome: 'Launched iOS, Android, and web surfaces with real payment paths and a clearer teacher-led buyer path.',
		image: palabrunoPhoto,
		imageAlt: 'Language study notebook and vocabulary cards on a wooden table.',
		imageClass: undefined
	},
	genrupt: {
		slug: 'genrupt',
		label: 'AI systems',
		title: 'Genrupt',
		body: 'Helped Genrupt move beyond demo-stage image and video generation by adding the commercial and reliability foundations needed for paid Amazon seller workflows.',
		outcome: 'Made the product more subscription-ready, more reliable under load, and easier to extend into new seller workflows.',
		image: genruptPhoto,
		imageAlt: 'E-commerce creative operations desk with packages, notes, and product materials.',
		imageClass: 'object-left-top'
	},
	'mucho-hangouts': {
		slug: 'mucho-hangouts',
		label: 'Product reliability',
		title: 'Mucho Hangouts',
		body: 'Helped a live social events product become more reliable, easier to extend, and less dependent on constant senior intervention while the team kept shipping.',
		outcome: 'Stabilized messaging, notifications, typed patterns, and junior-developer delivery inside a live product team.',
		image: muchoHangoutsPhoto,
		imageAlt: 'Social events platform interface shown on a mobile device.',
		imageClass: undefined
	}
} as const;

const caseStudies = HOMEPAGE_CASE_STUDY_SLUGS.map((slug) => caseStudyBySlug[slug]);

const proofStats = [
	{ label: '8+ years', value: 'Product and software delivery' },
	{ label: '10+ shipped', value: 'Products, systems, and tools' },
	{ label: 'Launched', value: 'Palabruno across iOS, Android, and web' },
	{ label: '3,000+', value: 'Organizers supported at LeagueApps' },
	{ label: '45%', value: 'Scheduling-time reduction at LeagueApps' }
];

const evidenceLinks = [
	{ label: 'Resume', href: RESUME_URL, trackEvent: 'resume_clicked' },
	{ label: 'GitHub', href: 'https://github.com/hanifcarroll' },
	{ label: 'LinkedIn', href: 'https://linkedin.com/in/hanifcarroll' },
	{ label: 'Tools', href: '/tools/' },
	{ label: 'Email', href: 'mailto:HanifCarroll@gmail.com', trackEvent: 'email_clicked' }
];

const fitColumns = [
	{
		title: 'Good fit',
		items: [
			'You need a first product, workflow, or internal system in use soon.',
			'You want one person who can advise on scope, workflow, and implementation.',
			'You need a smaller first step before committing to a bigger build.'
		]
	},
	{
		title: 'Probably not a fit',
		items: [
			'Idea-only projects with no urgency or budget.',
			'Teams shopping for the cheapest developer hours they can find.',
			'Large enterprise programs with broad committee scope from day one.'
		]
	}
];
---

<BaseLayout
	title={title}
	description={description}
	jsonLd={homepageJsonLd}
	flushTop
	showFooterCta={false}
	footerLinksOnly
	padContentBeforeFooter={false}
>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero-split'>
				<div class='home-hero-copy-wrap'>
					<div class='home-hero-copy space-y-6 md:space-y-7'>
						<p class='home-hero-context home-hero-context--hero'>Product Engineer, Full Stack + AI</p>
						<h1 class='home-hero-title'>
							<span>Founder-led SaaS</span>
							<span>from idea</span>
							<span>to launch</span>
						</h1>
						<p class='home-hero-body'>
							I help nontechnical founders and lean teams turn rough product ideas or manual workflows into launched software. Scope, UX,
							full-stack build, AI systems where they help, and the product judgment to keep v1 shippable.
						</p>
						<div class='home-hero-actions'>
							<a
								class='home-hero-primary-link'
								href={BOOK_CALL_URL}
								target='_blank'
								rel='noopener noreferrer'
								data-track-event='book_call_clicked'
								data-track-location='home_hero_primary'
							>
								Book a Roadmap Call
							</a>
							<a class='home-hero-secondary-link' href='/projects/'>See case studies</a>
						</div>
						<div class='home-evidence-links' aria-label='Professional evidence links'>
							{
								evidenceLinks.map((link) => (
									<a
										href={link.href}
										target={link.href.startsWith('http') ? '_blank' : undefined}
										rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
										data-track-event={link.trackEvent ?? 'evidence_clicked'}
										data-track-location='home_evidence'
									>
										{link.label}
									</a>
								))
							}
						</div>
					</div>
				</div>

				<div class='home-hero-media'>
					<figure class='home-hero-image-wrap'>
						<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
					</figure>
				</div>
			</header>

			<dl class='home-proof-strip' aria-label='Portfolio proof points'>
				{
					proofStats.map((item) => (
						<div class='home-proof-strip__item'>
							<dt>{item.label}</dt>
							<dd>{item.value}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</section>

	<section class='container home-start-section' aria-labelledby='home-paths-title'>
		<div class='home-start-section__inner'>
			<div class='space-y-5'>
				<h2 id='home-paths-title' class='heading-display home-start-section__title'>Choose the right first step</h2>
			</div>

			<div class='path-choices'>
				{
					pathCards.map((path) => (
						<a href={path.href} class='path-choice group'>
							<div class='path-choice__header'>
								<p class='launch-meta text-primary'>{path.label}</p>
								<span class='path-choice__arrow'>↗</span>
							</div>
							<div class='space-y-4'>
								<h3 class='heading-display path-choice__title'>{path.title}</h3>
								<p class='path-choice__body'>{path.body}</p>
							</div>
							<span class='path-choice__link'>
								{path.cta} <span aria-hidden='true'>→</span>
							</span>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<h2 class='heading-display home-case-studies-title'>Case Studies</h2>
		</div>

		<div class='case-study-rows mt-8'>
			{
				caseStudies.map((study, index) => (
					<a href={`/projects/${study.slug}/`} class='case-study-row group'>
						<div class='case-study-row__copy'>
							<p class='case-study-row__eyebrow'>
								<span aria-hidden='true' />
								CASE STUDY {String(index + 1).padStart(2, '0')}
							</p>
							<div class='case-study-row__body'>
								<div class='space-y-5'>
									<h3 class='case-study-row__title'>{study.title}</h3>
									<p class='case-study-row__description'>{study.body}</p>
									<p class='case-study-row__outcome'>{study.outcome}</p>
								</div>
								<span class='case-study-row__button'>View case study</span>
							</div>
						</div>
						<figure class='case-study-row__media'>
							<div class='case-study-row__image-frame'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={['case-study-row__image transition duration-700 ease-out group-hover:scale-[1.025]', study.imageClass]}
									loading='eager'
								/>
							</div>
						</figure>
					</a>
				))
			}

			<p class='case-study-archive-link'>
				<a href='/projects/'>See all case studies <span aria-hidden='true'>→</span></a>
			</p>
		</div>
	</section>

	<section class='container home-fit-section' aria-labelledby='home-fit-title'>
		<div class='home-fit-section__inner'>
			<div class='space-y-4'>
				<h2 id='home-fit-title' class='heading-display home-fit-section__title'>A quick fit check before booking</h2>
			</div>

			<div class='fit-grid'>
				{
					fitColumns.map((column) => (
						<div class='fit-column'>
							<p class='launch-meta text-primary'>{column.title}</p>
							<ul class='fit-list'>
								{column.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					))
				}
			</div>

			<div class='fit-actions'>
				<a
					class='home-hero-primary-link'
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					data-track-event='book_call_clicked'
					data-track-location='home_fit_primary'
				>
					Book a Roadmap Call
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
