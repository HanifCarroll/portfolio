---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import desarmaderoPhoto from '@src/assets/img/projects/desarmadero-parts-stockroom-photo.png';
import genruptPhoto from '@src/assets/img/projects/genrupt-creative-ops-photo.png';
import palabrunoPhoto from '@src/assets/img/projects/palabruno-language-study-photo.png';

const title = 'Hanif Carroll | Technical Product Partner';
const description =
	'I help founder-led teams turn vague product ideas and manual workflows into smaller systems that can be scoped, built, launched, and owned without agency overhead.';

const pathCards = [
	{
		label: 'Product path',
		title: 'Launch a first version',
		body: 'For founders who need the first useful version scoped, built, and live.',
		href: '/launch/',
		cta: 'See the launch path'
	},
	{
		label: 'Workflow path',
		title: 'Diagnose the workflow',
		body: 'For teams that need to find the bottleneck before building software or adding AI.',
		href: '/launch/',
		cta: 'See the audit path'
	}
];

const caseStudies = [
	{
		slug: 'palabruno',
		label: 'MVP build',
		title: 'Palabruno',
		body: 'Helped a nontechnical founder shape, build, and launch Palabruno: a Spanish reading app with mobile subscriptions, web payments for teachers, app store launch assets, UX polish, and public-site copy.',
		outcome:
			'Launched iOS, Android, and web surfaces with real payment paths and a clearer teacher-led buyer path.',
		image: palabrunoPhoto,
		imageAlt: 'Language study notebook and vocabulary cards on a wooden table.'
	},
	{
		slug: 'genrupt',
		label: 'AI systems',
		title: 'Genrupt',
		body: 'Helped Genrupt move beyond demo-stage image and video generation by adding the commercial and reliability foundations needed for paid Amazon seller workflows.',
		outcome: 'Made the product more subscription-ready, more reliable under load, and easier to extend into new seller workflows.',
		image: genruptPhoto,
		imageAlt: 'E-commerce creative operations desk with packages, notes, and product materials.',
		imageClass: 'object-left-top'
	},
	{
		slug: 'desarmadero-latorre',
		label: 'Workflow automation',
		title: 'Desarmadero La Torre',
		body: 'Created a searchable inventory system for an auto-parts supplier so customers could browse stock 24/7 instead of calling staff for every question.',
		outcome: 'Reduced repetitive operational work and increased qualified inbound inquiries.',
		image: desarmaderoPhoto,
		imageAlt: 'Organized shelves of used auto parts in a stockroom.'
	}
];

const fitColumns = [
	{
		title: 'Good fit',
		items: [
			'You need a first product, workflow, or internal system in use soon.',
			'You want one person who can advise on scope, workflow, and implementation.',
			'You need a smaller first step before committing to a bigger build.'
		]
	},
	{
		title: 'Probably not a fit',
		items: [
			'Idea-only projects with no urgency or budget.',
			'Teams shopping for the cheapest developer hours they can find.',
			'Large enterprise programs with broad committee scope from day one.'
		]
	}
];
---

<BaseLayout title={title} description={description} flushTop showFooterCta={false} footerLinksOnly padContentBeforeFooter={false}>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero-split'>
				<div class='home-hero-copy-wrap'>
					<div class='home-hero-copy space-y-6 md:space-y-7'>
						<p class='home-hero-context home-hero-context--hero'>For nontechnical founders</p>
						<h1 class='home-hero-title'>Turn rough ideas and manual workflows into working software.</h1>
						<p class='home-hero-body'>
							Work with one senior partner to cut scope, choose the right path, and build the first version directly. Product launch,
							workflow audit, or a smaller first step.
						</p>
						<div class='home-hero-actions'>
							<a
								class='home-hero-primary-link'
								href={BOOK_CALL_URL}
								target='_blank'
								rel='noopener noreferrer'
								data-track-event='book_call_clicked'
								data-track-location='home_hero_primary'
							>
								Book a Roadmap Call
							</a>
							<a class='home-hero-secondary-link' href='/projects/'>See case studies</a>
						</div>
					</div>
				</div>

				<div class='home-hero-media'>
					<figure class='home-hero-image-wrap'>
						<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
					</figure>
				</div>
			</header>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<p class='section-label'>// Case Studies</p>
			<p class='home-section-intro max-w-2xl text-zinc-600 dark:text-zinc-300'>
				Three examples of the same pattern: narrow the problem, build the useful system, and leave the work easier to own.
			</p>
		</div>

		<div class='case-study-rows mt-8'>
			{
				caseStudies.map((study, index) => (
					<a href={`/projects/${study.slug}/`} class='case-study-row group'>
						<div class='case-study-row__copy'>
							<p class='case-study-row__eyebrow'>
								<span aria-hidden='true'></span>
								CASE STUDY {String(index + 1).padStart(2, '0')}
							</p>
							<div class='case-study-row__body'>
								<div class='space-y-5'>
									<p class='launch-meta text-primary'>{study.label}</p>
									<h3 class='case-study-row__title'>{study.title}</h3>
									<p class='case-study-row__description'>{study.body}</p>
								</div>
								<span class='case-study-row__button'>View case study</span>
							</div>
						</div>
						<figure class='case-study-row__media'>
							<div class='case-study-row__image-frame'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={[
										'case-study-row__image transition duration-700 ease-out group-hover:scale-[1.025]',
										study.imageClass
									]}
									loading='eager'
								/>
							</div>
						</figure>
					</a>
				))
			}

			<p class='case-study-archive-link'>
				<a href='/projects/'>See all case studies <span aria-hidden='true'>→</span></a>
			</p>
		</div>
	</section>

	<section class='container home-start-section' aria-labelledby='home-paths-title'>
		<div class='home-start-section__inner'>
			<div class='max-w-3xl space-y-5'>
				<p class='launch-meta text-primary'>Start here</p>
				<h2 id='home-paths-title' class='heading-display home-start-section__title'>Choose the right first step.</h2>
				<p class='home-start-section__body'>
					The first conversation should clarify whether you need a build path or a workflow diagnosis before anything gets scoped.
				</p>
			</div>

			<div class='path-choices'>
				{
					pathCards.map((path) => (
						<a href={path.href} class='path-choice group'>
							<div class='path-choice__header'>
								<p class='launch-meta text-primary'>{path.label}</p>
								<span class='path-choice__arrow'>↗</span>
							</div>
							<div class='space-y-4'>
								<h3 class='heading-display path-choice__title'>{path.title}</h3>
								<p class='path-choice__body'>{path.body}</p>
							</div>
							<span class='path-choice__link'>{path.cta} <span aria-hidden='true'>→</span></span>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class='container home-fit-section' aria-labelledby='home-fit-title'>
		<div class='home-fit-section__inner'>
			<div class='max-w-2xl space-y-4'>
				<p class='launch-meta text-primary'>Fit check</p>
				<h2 id='home-fit-title' class='heading-display home-fit-section__title'>A quick fit check before booking.</h2>
			</div>

			<div class='fit-grid'>
				{
					fitColumns.map((column) => (
						<div class='fit-column'>
							<p class='launch-meta text-primary'>{column.title}</p>
							<ul class='fit-list'>
								{column.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					))
				}
			</div>

			<div class='fit-actions'>
				<a
					class='home-hero-primary-link'
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					data-track-event='book_call_clicked'
					data-track-location='home_fit_primary'
				>
					Book a Roadmap Call
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
