---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BOOK_CALL_URL } from "../consts";
import HeroImage from "@src/assets/img/portrait-brick.webp";
import casaElariaHero from "@src/assets/img/projects/casa-elaria-hero.png";
import desarmaderoHero from "@src/assets/img/projects/desarmadero-hero.png";
import genruptHero from "@src/assets/img/projects/genrupt-hero.png";
import monicaPhoto from "@src/assets/img/monica.jpeg";
import markisPhoto from "@src/assets/img/markis.jpeg";
import testimonials from "../../testimonials.json";

const title = "Hanif Carroll | Product Partner for Nontechnical Founders";
const description =
    "I help nontechnical founders figure out what to build, then I build it. Product strategy, MVP builds, and AI systems without agency overhead.";

const founderQuote = testimonials.find(
    (testimonial) => testimonial.name === "Monica Londoño",
);
const operatorQuote = testimonials.find(
    (testimonial) => testimonial.name === "Markis Zarate",
);

const fitColumns = [
    {
        title: "Best fit",
        items: [
            "You have an idea but aren't sure what the MVP should actually include.",
            "You need a first version in users' hands soon.",
            "You want one person who can advise on product, pricing, and launch — not just write code.",
        ],
    },
    {
        title: "Probably not a fit",
        items: [
            "Idea-only projects with no urgency or budget.",
            "Teams shopping for the cheapest developer hours they can find.",
            "You already have a detailed spec and just need hands to code it.",
        ],
    },
];

const offers = [
    {
        label: "01",
        title: "MVP builds",
        description:
            "For founders who need someone to shape the product, not just code it. I define the scope, design the UX, advise on pricing and positioning, and build the whole thing.",
        bullets: [
            "Figure out what the MVP should actually include before code starts.",
            "Ship something people can use, pay for, and come back to.",
        ],
        href: "/launch/",
        cta: "See the MVP path",
        image: casaElariaHero,
        imageAlt: "Market validation storefront built for a beauty brand MVP test.",
    },
    {
        label: "02",
        title: "Workflow automation + AI agents",
        description:
            "For business owners and lean teams who need software to remove operational drag and make AI genuinely useful.",
        bullets: [
            "Remove repetitive work inside the business.",
            "Add AI only when it reduces work or improves a decision.",
        ],
        href: "/launch/#automation",
        cta: "See automation examples",
        image: desarmaderoHero,
        imageAlt: "Inventory and workflow software interface for an auto-parts supplier.",
    },
];

const processSteps = [
    {
        number: "01",
        title: "Understand the business and the user",
        body: "Before anything gets built, I learn who it's for, what the business model is, and what success looks like. This shapes everything that follows.",
    },
    {
        number: "02",
        title: "Define the product and cut scope hard",
        body: "I help decide what the MVP should include, how to price it, and what to leave out. The first build has to be useful and small enough to ship.",
    },
    {
        number: "03",
        title: "Build with direct feedback",
        body: "You get direct updates and short demos without extra layers between us. I handle the UX, the design decisions, and the code.",
    },
    {
        number: "04",
        title: "Launch and go to market",
        body: "We ship something people can use, then I help with the marketing site, positioning, and whatever else it takes to get the product in front of the right people.",
    },
];

const proofPoints = [
    {
        metric: "8+",
        label: "years from consulting to product teams to independent work",
    },
    {
        metric: "10+",
        label: "products shipped — MVPs, automations, and AI systems",
    },
    {
        metric: "3,000+",
        label: "end users served through tools built with founders",
    },
];

const caseStudies = [
    {
        slug: "casa-elaria",
        label: "MVP validation",
        title: "Validated demand before inventory spend",
        body: "Built a fake-door e-commerce launch for a beauty brand so the founder could test purchase intent and collect early demand before committing to inventory.",
        outcome: "Measured demand with a high-fidelity storefront and turned curiosity into a launch list.",
        image: casaElariaHero,
        imageAlt: "Beauty brand landing page used for fake-door validation.",
    },
    {
        slug: "desarmadero-latorre",
        label: "Workflow automation",
        title: "Turned phone calls into a digital stockroom",
        body: "Created a searchable inventory system for an auto-parts supplier so customers could browse stock 24/7 instead of calling staff for every question.",
        outcome: "Reduced repetitive operational work and increased qualified inbound inquiries.",
        image: desarmaderoHero,
        imageAlt: "Digital stockroom and searchable inventory interface.",
    },
    {
        slug: "genrupt",
        label: "AI systems",
        title: "Expanded an AI demo into an Amazon creative platform",
        body: "Built the billing, worker infrastructure, and product foundations behind Genrupt as it grew from image and video generation into a broader Amazon creative ops system.",
        outcome: "Made the product billable, more reliable under load, and much broader than the original MVP.",
        image: genruptHero,
        imageAlt: "AI creative platform interface for image and video generation.",
        imageClass: "object-left-top",
    },
];
---

<BaseLayout
    title={title}
    description={description}
    flushTop
    showFooterCta={false}
    footerLinksOnly
    padContentBeforeFooter={false}
>
    <section class="border-b border-black/15 bg-[#f2ede3] text-black dark:border-white/10 dark:bg-black dark:text-white">
        <div class="home-hero-split min-h-[calc(100svh-73px)]">
            <div class="relative flex items-center bg-[#f2ede3] px-6 py-12 md:px-10 md:py-14 lg:border-r lg:border-r-black/10 lg:px-16 xl:px-20 dark:bg-[linear-gradient(165deg,#050505,#07162d)] dark:lg:border-r-white/10">
                <div class="max-w-[31rem] space-y-7">
                    <p
                        class="kicker-line animate-fade-in-up opacity-0"
                        style="animation-delay: 80ms; animation-fill-mode: forwards;"
                    >
                        Hanif Carroll
                        <span class="text-black/45 dark:text-white/60">Product partner for founders</span>
                    </p>

                    <h1
                        class="hero-title max-w-[13.2ch] animate-fade-in-up opacity-0"
                        style="animation-delay: 180ms; animation-fill-mode: forwards;"
                    >
                        <span class="block whitespace-nowrap">I figure out</span>
                        <span class="block whitespace-nowrap">what to build,</span>
                        <span class="block whitespace-nowrap">then I build</span>
                        <span class="block">it.</span>
                    </h1>

                    <p
                        class="max-w-[28rem] animate-fade-in-up text-lg leading-8 text-black/60 opacity-0 dark:text-white/80"
                        style="animation-delay: 280ms; animation-fill-mode: forwards;"
                    >
                        Product strategy, UX, pricing, and full-stack engineering for
                        nontechnical founders — without agency overhead.
                    </p>

                    <div
                        class="flex flex-wrap gap-4 animate-fade-in-up opacity-0"
                        style="animation-delay: 380ms; animation-fill-mode: forwards;"
                    >
                        <a
                            class="btn-primary"
                            href={BOOK_CALL_URL}
                            target="_blank"
                            rel="noopener noreferrer"
                            data-track-event="book_call_clicked"
                            data-track-location="home_hero_primary"
                        >
                            Book a Roadmap Call
                        </a>
                        <a class="btn-secondary" href="#case-studies">
                            See Case Studies
                        </a>
                    </div>

                    <div
                        class="grid gap-3 border-t border-black/10 pt-5 text-sm text-black/50 animate-fade-in-up opacity-0 dark:border-white/15 dark:text-white/70 md:grid-cols-2"
                        style="animation-delay: 460ms; animation-fill-mode: forwards;"
                    >
                        <p>Product decisions and code from the same person.</p>
                        <p>From idea through launch and go-to-market.</p>
                    </div>
                </div>
            </div>

            <div class="relative min-h-[24rem] overflow-hidden bg-[#d8c6b9] lg:min-h-full">
                <Image
                    src={HeroImage}
                    alt="Hanif Carroll"
                    class="hero-portrait absolute inset-0 h-full w-full object-cover"
                    loading="eager"
                />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.08),rgba(0,0,0,0.14))]"></div>
            </div>
        </div>
    </section>

    <section class="container py-20 md:py-24">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
            <div class="space-y-5">
                <p class="kicker-line">Who This Is For</p>
                <h2 class="heading-display text-4xl md:text-5xl">
                    Know quickly if this is the right kind of help.
                </h2>
                <p class="max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    If you need a first version soon or software to remove a recurring
                    bottleneck, the fit should be clear fast.
                </p>
            </div>

            <div class="grid gap-10 md:grid-cols-2">
                {fitColumns.map((column) => (
                    <div class="signal-line pt-5">
                        <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                            {column.title}
                        </p>
                        <ul class="mt-6 space-y-4 text-base leading-7 text-zinc-700 dark:text-zinc-200">
                            {column.items.map((item) => (
                                <li class="border-t border-black/10 pt-4 dark:border-white/10">
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="container py-6 md:py-10">
        <div class="soft-divider"></div>
    </section>

    <section class="container py-14 md:py-20">
        <div class="space-y-5">
            <p class="kicker-line">Where This Usually Starts</p>
            <div class="max-w-3xl space-y-4">
                <h2 class="heading-display text-4xl md:text-5xl">
                    Most projects start in one of two places.
                </h2>
                <p class="max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    Either a founder needs a first version, or a business needs software
                    to remove a recurring bottleneck.
                </p>
            </div>
        </div>

        <div class="mt-12 space-y-12 md:space-y-16">
            {offers.map((offer, index) => (
                <article class="grid gap-8 border-t border-black/12 py-10 dark:border-white/12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14">
                    <div class:list={[index % 2 === 1 && "lg:order-2"]}>
                        <p class="font-mono text-xs uppercase tracking-[0.3em] text-primary">
                            Offer {offer.label}
                        </p>
                        <div class="mt-5 max-w-2xl space-y-5">
                            <h3 class="heading-display text-3xl md:text-4xl">{offer.title}</h3>
                            <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                                {offer.description}
                            </p>
                            <ul class="space-y-4 text-sm leading-6 text-zinc-700 dark:text-zinc-200 md:text-base">
                                {offer.bullets.map((bullet) => (
                                    <li class="border-t border-black/10 pt-4 dark:border-white/10">
                                        {bullet}
                                    </li>
                                ))}
                            </ul>
                            <div class="pt-2">
                                <a class="arrow-link" href={offer.href}>
                                    {offer.cta}
                                </a>
                            </div>
                        </div>
                    </div>

                    <figure class:list={["overflow-hidden border border-black/15 bg-black dark:border-white/15", index % 2 === 1 && "lg:order-1"]}>
                        <Image
                            src={offer.image}
                            alt={offer.imageAlt}
                            class="aspect-[5/4] h-full w-full object-cover transition duration-700 ease-out hover:scale-[1.03]"
                            loading="lazy"
                        />
                    </figure>
                </article>
            ))}
        </div>
    </section>

    <section class="border-y border-black/20 bg-zinc-950 py-20 text-white dark:border-white/10 dark:bg-zinc-900 md:py-28" id="proof">
        <div class="container grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:gap-20">
            <div class="space-y-6 lg:sticky lg:top-28 lg:self-start">
                <p class="kicker-line">Why This Works</p>
                <h2 class="heading-display text-4xl md:text-5xl">
                    Strategy and execution from the same person.
                </h2>
                <p class="max-w-xl text-base leading-7 text-white/70">
                    You get one person handling the product decisions, the UX, the pricing
                    strategy, the build, and the communication. No handoffs between a
                    strategist, a designer, and a developer.
                </p>

                {founderQuote && (
                    <div class="border-t border-white/12 pt-6">
                        <div class="flex items-start gap-4">
                            <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border border-white/20">
                                <Image
                                    src={monicaPhoto}
                                    alt={founderQuote.name}
                                    width={64}
                                    height={64}
                                    loading="lazy"
                                    class="h-full w-full object-cover"
                                />
                            </div>
                            <div class="space-y-3">
                                <p class="text-base leading-7 text-white/80">
                                    &ldquo;{founderQuote.text}&rdquo;
                                </p>
                                <div class="space-y-1 font-mono text-white/40">
                                    <p class="text-xs uppercase tracking-[0.24em]">
                                        {founderQuote.name}
                                    </p>
                                    <p class="text-[11px] uppercase tracking-[0.18em]">
                                        {founderQuote.role}
                                        {founderQuote.company ? ` · ${founderQuote.company}` : ""}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                )}
            </div>

            <div class="space-y-14">
                <div class="grid gap-8 md:grid-cols-3">
                    {proofPoints.map((point) => (
                        <div class="border-t border-white/15 pt-5">
                            <p class="inline-metric">{point.metric}</p>
                            <p class="mt-3 text-sm uppercase tracking-[0.2em] text-white/55">
                                {point.label}
                            </p>
                        </div>
                    ))}
                </div>

                <div class="space-y-8">
                    {processSteps.map((step) => (
                        <div class="grid gap-4 border-t border-white/12 pt-6 md:grid-cols-[100px_1fr]">
                            <p class="font-mono text-xs uppercase tracking-[0.3em] text-primary">
                                Step {step.number}
                            </p>
                            <div class="space-y-3">
                                <h3 class="heading-display text-2xl md:text-3xl">
                                    {step.title}
                                </h3>
                                <p class="max-w-2xl text-base leading-7 text-white/70">
                                    {step.body}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>

                {operatorQuote && (
                    <div class="border-t border-white/12 pt-6">
                        <div class="flex items-start gap-4">
                            <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full border border-white/20">
                                <Image
                                    src={markisPhoto}
                                    alt={operatorQuote.name}
                                    width={64}
                                    height={64}
                                    loading="lazy"
                                    class="h-full w-full object-cover object-center"
                                />
                            </div>
                            <div class="space-y-3">
                                <p class="text-base leading-7 text-white/80">
                                    &ldquo;{operatorQuote.text}&rdquo;
                                </p>
                                <div class="space-y-1 font-mono text-white/40">
                                    <p class="text-xs uppercase tracking-[0.24em]">
                                        {operatorQuote.name}
                                    </p>
                                    <p class="text-[11px] uppercase tracking-[0.18em]">
                                        {operatorQuote.role}
                                        {operatorQuote.company ? ` · ${operatorQuote.company}` : ""}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                )}

            </div>
        </div>
    </section>

    <section class="container py-20 md:py-24" id="case-studies">
        <div class="space-y-5">
            <p class="kicker-line">Case Studies</p>
            <div class="max-w-3xl space-y-4">
                <h2 class="heading-display text-4xl md:text-5xl">
                    Find the closest match for the kind of problem you have.
                </h2>
                <p class="max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    The work is grouped by MVP, workflow, and AI-system projects so you can
                    start with the most relevant examples.
                </p>
            </div>
        </div>

        <div class="mt-12 space-y-0">
            {caseStudies.map((study, index) => (
                <a
                    href={`/projects/${study.slug}/`}
                    class="group grid gap-8 border-t border-black/12 py-12 transition-colors dark:border-white/12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-16"
                >
                    <figure class:list={["overflow-hidden border border-black/15 bg-black dark:border-white/15", index % 2 === 1 && "lg:order-2"]}>
                        <Image
                            src={study.image}
                            alt={study.imageAlt}
                            class:list={[
                                "aspect-[16/10] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.02]",
                                study.imageClass,
                            ]}
                            loading="lazy"
                        />
                    </figure>

                    <div class:list={["flex h-full flex-col justify-between gap-6 lg:py-2", index % 2 === 1 && "lg:order-1"]}>
                        <div class="space-y-4">
                            <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                                {study.label}
                            </p>
                            <h3 class="heading-display text-3xl md:text-4xl">
                                {study.title}
                            </h3>
                            <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                                {study.body}
                            </p>
                        </div>
                        <div class="space-y-4">
                            <div class="border-t border-black/12 pt-4 dark:border-white/12">
                                <p class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">Outcome</p>
                                <p class="mt-1 text-sm font-medium leading-6 text-zinc-800 dark:text-zinc-100">
                                    {study.outcome}
                                </p>
                            </div>
                            <span class="arrow-link group-hover:border-primary group-hover:text-primary">View case study</span>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <section class="border-y border-black/10 bg-black py-20 text-white dark:border-white/10 md:py-24">
        <div class="container">
            <div class="max-w-4xl space-y-6">
                <p class="kicker-line">Next Step</p>
                <h2 class="poster-title max-w-3xl">
                    Bring the bottleneck, and I&rsquo;ll help decide what to build first.
                </h2>
                <p class="poster-copy max-w-2xl text-white/74">
                    Book a roadmap call if you need an MVP or a workflow that no longer
                    depends on manual cleanup. If AI belongs in the solution, we can decide
                    that after the workflow is clear.
                </p>
                <div class="flex flex-wrap gap-4 pt-2">
                    <a
                        class="btn-primary"
                        href={BOOK_CALL_URL}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-track-event="book_call_clicked"
                        data-track-location="home_final_primary"
                    >
                        Book a Roadmap Call
                    </a>
                    <a class="btn-secondary border-white text-white hover:bg-white hover:text-black dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black" href="/projects/">
                        Browse Case Studies
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .home-hero-split {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
    }

    .hero-portrait {
        object-position: 58% 12%;
        transform: scaleX(-1) scale(1.08);
        transform-origin: center;
    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(3rem, 5.4vw, 5.25rem);
        font-weight: 700;
        line-height: 0.88;
        letter-spacing: -0.07em;
        text-transform: uppercase;
        text-wrap: balance;
    }

    @media (min-width: 1024px) {
        .home-hero-split {
            grid-template-columns: minmax(0, 62%) minmax(0, 38%);
        }

        .hero-portrait {
            object-position: 76% 12%;
            transform: scaleX(-1) scale(1.2);
        }
    }
</style>
