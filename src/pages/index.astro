---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BOOK_CALL_URL } from "../consts";
import HeroImage from "@src/assets/img/portrait-brick.webp";
import casaElariaHero from "@src/assets/img/projects/casa-elaria-hero.png";
import desarmaderoHero from "@src/assets/img/projects/desarmadero-hero.png";
import genruptHero from "@src/assets/img/projects/genrupt-hero.png";
import monicaPhoto from "@src/assets/img/monica.jpeg";
import markisPhoto from "@src/assets/img/markis.jpeg";
import testimonials from "../../testimonials.json";

const title = "Hanif Carroll | MVPs and AI Automation for Nontechnical Founders";
const description =
    "I build MVPs, workflow automation, and AI agents for nontechnical founders and business owners who need working software fast.";

const founderQuote = testimonials.find(
    (testimonial) => testimonial.name === "Monica Londoño",
);
const operatorQuote = testimonials.find(
    (testimonial) => testimonial.name === "Markis Zarate",
);

const fitColumns = [
    {
        title: "Best fit",
        items: [
            "You need a first version in users' hands soon.",
            "Your business keeps losing time to the same manual work.",
        ],
    },
    {
        title: "Probably not a fit",
        items: [
            "Idea-only projects with no urgency or budget.",
            "Teams shopping for the cheapest developer hours they can find.",
        ],
    },
];

const offers = [
    {
        label: "01",
        title: "MVP builds",
        description:
            "For founders who need a first version in front of users without hiring a team from scratch.",
        bullets: [
            "Cut the first version down before code starts.",
            "Ship something people can actually use.",
        ],
        href: "/launch/",
        cta: "See the MVP path",
        image: casaElariaHero,
        imageAlt: "Market validation storefront built for a beauty brand MVP test.",
    },
    {
        label: "02",
        title: "Workflow automation + AI agents",
        description:
            "For business owners and lean teams who need software to remove operational drag and make AI genuinely useful.",
        bullets: [
            "Remove repetitive work inside the business.",
            "Add AI only when it reduces work or improves a decision.",
        ],
        href: "/automation-ai-agents/",
        cta: "See automation examples",
        image: desarmaderoHero,
        imageAlt: "Inventory and workflow software interface for an auto-parts supplier.",
    },
];

const processSteps = [
    {
        number: "01",
        title: "Find the real bottleneck",
        body: "We decide whether the problem is a first version, an ops bottleneck, or both.",
    },
    {
        number: "02",
        title: "Cut scope hard",
        body: "The first build has to be useful and small enough to ship.",
    },
    {
        number: "03",
        title: "Build with direct feedback",
        body: "You get direct updates and short demos without extra layers between us.",
    },
    {
        number: "04",
        title: "Launch and learn",
        body: "We ship something people can use, then decide what deserves the next round.",
    },
];

const proofPoints = [
    {
        metric: "8+",
        label: "years building software products",
    },
    {
        metric: "10+",
        label: "client and internal projects shipped",
    },
    {
        metric: "3,000+",
        label: "organizers served through tools I helped build",
    },
];

const caseStudies = [
    {
        slug: "casa-elaria",
        label: "MVP validation",
        title: "Validated demand before inventory spend",
        body: "Built a fake-door e-commerce launch for a beauty brand so the founder could test purchase intent and collect early demand before committing to inventory.",
        outcome: "Measured demand with a high-fidelity storefront and turned curiosity into a launch list.",
        image: casaElariaHero,
        imageAlt: "Beauty brand landing page used for fake-door validation.",
    },
    {
        slug: "desarmadero-latorre",
        label: "Workflow automation",
        title: "Turned phone calls into a digital stockroom",
        body: "Created a searchable inventory system for an auto-parts supplier so customers could browse stock 24/7 instead of calling staff for every question.",
        outcome: "Reduced repetitive operational work and increased qualified inbound inquiries.",
        image: desarmaderoHero,
        imageAlt: "Digital stockroom and searchable inventory interface.",
    },
    {
        slug: "genrupt",
        label: "AI systems",
        title: "Took an AI product from fragile MVP to paid SaaS",
        body: "Built subscription infrastructure, job queues, and production AI workflows for a creative platform generating image and video assets at scale.",
        outcome: "Made the product billable, more reliable, and ready to support paying customers.",
        image: genruptHero,
        imageAlt: "AI creative platform interface for image and video generation.",
    },
];
---

<BaseLayout title={title} description={description} flushTop>
    <section class="relative isolate overflow-hidden border-b border-black/10 bg-black text-white dark:border-white/10">
        <div class="absolute inset-0">
            <Image
                src={HeroImage}
                alt="Hanif Carroll"
                class="h-full w-full object-cover object-[72%_18%] opacity-60 lg:object-[68%_18%]"
                loading="eager"
            />
            <div class="absolute inset-0 bg-[linear-gradient(110deg,rgba(5,5,5,0.94)_24%,rgba(5,5,5,0.82)_50%,rgba(5,5,5,0.18)_100%)]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(0,102,255,0.24),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.10),transparent_26%)]"></div>
        </div>

        <div class="relative mx-auto flex min-h-[calc(100svh-73px)] max-w-[1480px] flex-col justify-between px-6 pb-8 pt-16 md:px-10 md:pt-20 lg:px-16 lg:pb-10 lg:pt-24">
            <div class="max-w-5xl space-y-6">
                <p
                    class="kicker-line animate-fade-in-up opacity-0"
                    style="animation-delay: 80ms; animation-fill-mode: forwards;"
                >
                    Hanif Carroll
                    <span class="text-white/60">Independent product engineer</span>
                </p>

                <div class="space-y-4">
                    <p
                        class="poster-brand animate-fade-in-up text-white/16 opacity-0"
                        style="animation-delay: 140ms; animation-fill-mode: forwards;"
                    >
                        Hanif Carroll
                    </p>
                    <h1
                        class="poster-title max-w-4xl animate-fade-in-up opacity-0"
                        style="animation-delay: 220ms; animation-fill-mode: forwards;"
                    >
                        MVPs and AI automation for nontechnical founders.
                    </h1>
                </div>

                <p
                    class="poster-copy max-w-2xl animate-fade-in-up text-white/78 opacity-0"
                    style="animation-delay: 320ms; animation-fill-mode: forwards;"
                >
                    I turn product ideas and messy manual workflows into working software
                    without agency overhead or technical hand-holding.
                </p>

                <div
                    class="flex flex-wrap gap-4 animate-fade-in-up opacity-0"
                    style="animation-delay: 420ms; animation-fill-mode: forwards;"
                >
                    <a
                        class="btn-primary"
                        href={BOOK_CALL_URL}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-track-event="book_call_clicked"
                        data-track-location="home_hero_primary"
                    >
                        Book a Roadmap Call
                    </a>
                    <a class="btn-secondary border-white text-white hover:bg-white hover:text-black dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black" href="#case-studies">
                        See Case Studies
                    </a>
                </div>
            </div>

            <div
                class="mt-10 grid gap-4 border-t border-white/14 pt-6 text-sm text-white/74 md:grid-cols-2"
            >
                <p>Real v1 builds for founder-led products.</p>
                <p>Automation and AI systems for teams buried in manual work.</p>
            </div>
        </div>
    </section>

    <section class="container py-20 md:py-24">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
            <div class="space-y-5">
                <p class="kicker-line">Who This Is For</p>
                <h2 class="heading-display text-4xl md:text-5xl">
                    You should know fast whether this is a fit.
                </h2>
                <p class="max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    Most people land here cold. They should know fast whether I build the
                    kind of thing they need.
                </p>
            </div>

            <div class="grid gap-10 md:grid-cols-2">
                {fitColumns.map((column) => (
                    <div class="signal-line pt-5">
                        <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                            {column.title}
                        </p>
                        <ul class="mt-6 space-y-4 text-base leading-7 text-zinc-700 dark:text-zinc-200">
                            {column.items.map((item) => (
                                <li class="border-t border-black/10 pt-4 dark:border-white/10">
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="container py-6 md:py-10">
        <div class="soft-divider"></div>
    </section>

    <section class="container py-14 md:py-20">
        <div class="space-y-5">
            <p class="kicker-line">What I Build</p>
            <div class="max-w-3xl space-y-4">
                <h2 class="heading-display text-4xl md:text-5xl">
                    Most projects start in one of two places.
                </h2>
                <p class="max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    Either a founder needs a first version, or a business needs software
                    to remove a recurring bottleneck.
                </p>
            </div>
        </div>

        <div class="mt-12 space-y-12 md:space-y-16">
            {offers.map((offer, index) => (
                <article class="grid gap-8 border-t border-black/12 py-10 dark:border-white/12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14">
                    <div class:list={[index % 2 === 1 && "lg:order-2"]}>
                        <p class="font-mono text-xs uppercase tracking-[0.3em] text-primary">
                            Offer {offer.label}
                        </p>
                        <div class="mt-5 max-w-2xl space-y-5">
                            <h3 class="heading-display text-3xl md:text-4xl">{offer.title}</h3>
                            <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                                {offer.description}
                            </p>
                            <ul class="space-y-4 text-sm leading-6 text-zinc-700 dark:text-zinc-200 md:text-base">
                                {offer.bullets.map((bullet) => (
                                    <li class="border-t border-black/10 pt-4 dark:border-white/10">
                                        {bullet}
                                    </li>
                                ))}
                            </ul>
                            <div class="pt-2">
                                <a class="arrow-link" href={offer.href}>
                                    {offer.cta}
                                </a>
                            </div>
                        </div>
                    </div>

                    <figure class:list={["overflow-hidden border border-black/15 bg-black dark:border-white/15", index % 2 === 1 && "lg:order-1"]}>
                        <Image
                            src={offer.image}
                            alt={offer.imageAlt}
                            class="aspect-[5/4] h-full w-full object-cover transition duration-700 ease-out hover:scale-[1.03]"
                            loading="lazy"
                        />
                    </figure>
                </article>
            ))}
        </div>
    </section>

    <section class="container py-20 md:py-24" id="proof">
        <div class="grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:gap-20">
            <div class="space-y-6 lg:sticky lg:top-28 lg:self-start">
                <p class="kicker-line">Why This Works</p>
                <h2 class="heading-display text-4xl md:text-5xl">
                    Direct senior execution without the agency drag.
                </h2>
                <p class="max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    The point is clarity. One person owns the scope, the build, the tradeoffs,
                    and the communication. That matters a lot when the client is nontechnical.
                </p>

                {founderQuote && (
                    <div class="border-t border-black/12 pt-6 dark:border-white/12">
                        <div class="flex items-start gap-4">
                            <div class="h-16 w-16 overflow-hidden rounded-full border border-black/15 dark:border-white/15">
                                <Image
                                    src={monicaPhoto}
                                    alt={founderQuote.name}
                                    width={64}
                                    height={64}
                                    loading="lazy"
                                    class="h-full w-full object-cover"
                                />
                            </div>
                            <div class="space-y-3">
                                <p class="text-base leading-7 text-zinc-700 dark:text-zinc-200">
                                    &ldquo;{founderQuote.text}&rdquo;
                                </p>
                                <p class="font-mono text-xs uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
                                    {founderQuote.name} · {founderQuote.role}
                                    {founderQuote.company ? ` · ${founderQuote.company}` : ""}
                                </p>
                            </div>
                        </div>
                    </div>
                )}
            </div>

            <div class="space-y-14">
                <div class="grid gap-8 md:grid-cols-3">
                    {proofPoints.map((point) => (
                        <div class="border-t border-black/12 pt-5 dark:border-white/12">
                            <p class="inline-metric">{point.metric}</p>
                            <p class="mt-3 text-sm uppercase tracking-[0.2em] text-zinc-600 dark:text-zinc-300">
                                {point.label}
                            </p>
                        </div>
                    ))}
                </div>

                <div class="space-y-8">
                    {processSteps.map((step) => (
                        <div class="grid gap-4 border-t border-black/12 pt-6 dark:border-white/12 md:grid-cols-[100px_1fr]">
                            <p class="font-mono text-xs uppercase tracking-[0.3em] text-primary">
                                Step {step.number}
                            </p>
                            <div class="space-y-3">
                                <h3 class="heading-display text-2xl md:text-3xl">
                                    {step.title}
                                </h3>
                                <p class="max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                                    {step.body}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>

                {operatorQuote && (
                    <div class="border-t border-black/12 pt-6 dark:border-white/12">
                        <div class="flex items-start gap-4">
                            <div class="h-16 w-16 overflow-hidden rounded-full border border-black/15 dark:border-white/15">
                                <Image
                                    src={markisPhoto}
                                    alt={operatorQuote.name}
                                    width={64}
                                    height={64}
                                    loading="lazy"
                                    class="h-full w-full object-cover"
                                />
                            </div>
                            <div class="space-y-3">
                                <p class="text-base leading-7 text-zinc-700 dark:text-zinc-200">
                                    &ldquo;{operatorQuote.text}&rdquo;
                                </p>
                                <p class="font-mono text-xs uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
                                    {operatorQuote.name} · {operatorQuote.role}
                                    {operatorQuote.company ? ` · ${operatorQuote.company}` : ""}
                                </p>
                            </div>
                        </div>
                    </div>
                )}

            </div>
        </div>
    </section>

    <section class="container py-20 md:py-24" id="case-studies">
        <div class="space-y-5">
            <p class="kicker-line">Selected Case Studies</p>
            <div class="max-w-3xl space-y-4">
                <h2 class="heading-display text-4xl md:text-5xl">
                    Case studies grouped by the problem they solved.
                </h2>
                <p class="max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                    If you&rsquo;re trying to launch something or clean up a messy workflow,
                    you should be able to find similar work fast.
                </p>
            </div>
        </div>

        <div class="mt-12 space-y-12">
            {caseStudies.map((study, index) => (
                <a
                    href={`/projects/${study.slug}/`}
                    class="group grid gap-8 border-t border-black/12 py-10 transition-colors dark:border-white/12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14"
                >
                    <figure class:list={["overflow-hidden border border-black/15 bg-black dark:border-white/15", index % 2 === 1 && "lg:order-2"]}>
                        <Image
                            src={study.image}
                            alt={study.imageAlt}
                            class="aspect-[5/4] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.03]"
                            loading="lazy"
                        />
                    </figure>

                    <div class:list={["space-y-5", index % 2 === 1 && "lg:order-1"]}>
                        <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                            {study.label}
                        </p>
                        <h3 class="heading-display text-3xl md:text-4xl">
                            {study.title}
                        </h3>
                        <p class="max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                            {study.body}
                        </p>
                        <p class="border-t border-black/10 pt-4 text-sm uppercase tracking-[0.18em] text-zinc-700 dark:border-white/10 dark:text-zinc-200">
                            {study.outcome}
                        </p>
                        <span class="arrow-link">View case study</span>
                    </div>
                </a>
            ))}
        </div>
    </section>

    <section class="border-y border-black/10 bg-black py-20 text-white dark:border-white/10 md:py-24">
        <div class="container">
            <div class="max-w-4xl space-y-6">
                <p class="kicker-line">Next Step</p>
                <h2 class="poster-title max-w-3xl">
                    Bring the bottleneck, and I&rsquo;ll help decide what to build first.
                </h2>
                <p class="poster-copy max-w-2xl text-white/74">
                    Book a roadmap call if you need an MVP or a workflow that no longer
                    depends on manual cleanup. If AI belongs in the solution, we can decide
                    that after the workflow is clear.
                </p>
                <div class="flex flex-wrap gap-4 pt-2">
                    <a
                        class="btn-primary"
                        href={BOOK_CALL_URL}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-track-event="book_call_clicked"
                        data-track-location="home_final_primary"
                    >
                        Book a Roadmap Call
                    </a>
                    <a class="btn-secondary border-white text-white hover:bg-white hover:text-black dark:border-white dark:text-white dark:hover:bg-white dark:hover:text-black" href="/projects/">
                        Browse Case Studies
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
