---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import casaElariaHero from '@src/assets/img/projects/casa-elaria-hero.png';
import desarmaderoHero from '@src/assets/img/projects/desarmadero-hero.png';
import genruptFeature from '@src/assets/img/projects/genrupt-feature.png';

const title = 'Hanif Carroll | Technical Product Partner';
const description =
	'I help founder-led teams turn vague product ideas and manual workflows into smaller systems that can be scoped, built, launched, and owned without agency overhead.';

const pathCards = [
	{
		label: 'Product path',
		title: 'Launch a first version',
		body: 'For founders who need the first useful version scoped, built, and live.',
		href: '/launch/',
		cta: 'See the launch path'
	},
	{
		label: 'Workflow path',
		title: 'Diagnose the workflow',
		body: 'For teams that need to find the bottleneck before building software or adding AI.',
		href: '/launch/',
		cta: 'See the audit path'
	}
];

const caseStudies = [
	{
		slug: 'casa-elaria',
		label: 'MVP validation',
		title: 'Validated demand before inventory spend',
		body: 'Built a fake-door e-commerce launch for a beauty brand so the founder could test purchase intent and collect early demand before committing to inventory.',
		outcome: 'Measured demand with a high-fidelity storefront and turned curiosity into a launch list.',
		image: casaElariaHero,
		imageAlt: 'Beauty brand landing page used for fake-door validation.'
	},
	{
		slug: 'desarmadero-latorre',
		label: 'Workflow automation',
		title: 'Turned phone calls into a digital stockroom',
		body: 'Created a searchable inventory system for an auto-parts supplier so customers could browse stock 24/7 instead of calling staff for every question.',
		outcome: 'Reduced repetitive operational work and increased qualified inbound inquiries.',
		image: desarmaderoHero,
		imageAlt: 'Digital stockroom and searchable inventory interface.'
	},
	{
		slug: 'genrupt',
		label: 'AI systems',
		title: 'Moved an AI demo toward a billable seller platform',
		body: 'Helped Genrupt move beyond demo-stage image and video generation by adding the commercial and reliability foundations needed for paid Amazon seller workflows.',
		outcome: 'Made the product more subscription-ready, more reliable under load, and easier to extend into new seller workflows.',
		image: genruptFeature,
		imageAlt: 'AI creative platform interface for image and video generation.',
		imageClass: 'object-left-top'
	}
];

const [featuredCaseStudy, ...secondaryCaseStudies] = caseStudies;

const fitColumns = [
	{
		title: 'Good fit',
		items: [
			'You need a first product, workflow, or internal system in use soon.',
			'You want one person who can advise on scope, workflow, and implementation.',
			'You need a smaller first step before committing to a bigger build.'
		]
	},
	{
		title: 'Probably not a fit',
		items: [
			'Idea-only projects with no urgency or budget.',
			'Teams shopping for the cheapest developer hours they can find.',
			'Large enterprise programs with broad committee scope from day one.'
		]
	}
];

---

<BaseLayout title={title} description={description} flushTop showFooterCta={false} footerLinksOnly padContentBeforeFooter={false}>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero-split'>
				<div class='home-hero-copy-wrap'>
					<div class='home-hero-copy space-y-6 md:space-y-7'>
						<p class='home-hero-context home-hero-context--hero'>For nontechnical founders</p>
						<h1 class='home-hero-title'>Turn rough ideas and manual workflows into working software.</h1>
						<p class='home-hero-body'>
							Get one senior partner to choose the right first system, cut scope, and build it directly. Product launch, workflow audit,
							or a smaller first step.
						</p>
						<div class='home-hero-actions'>
							<a
								class='home-hero-primary-link'
								href={BOOK_CALL_URL}
								target='_blank'
								rel='noopener noreferrer'
								data-track-event='book_call_clicked'
								data-track-location='home_hero_primary'
							>
								Book a Roadmap Call
							</a>
							<a class='home-hero-secondary-link' href='/projects/'>See case studies</a>
						</div>
					</div>
				</div>

				<div class='home-hero-media'>
					<figure class='home-hero-image-wrap'>
						<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
					</figure>
				</div>
			</header>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<p class='section-label'>// Case Studies</p>
			<div class='max-w-3xl space-y-4'>
				<h2 class='heading-display heading-display--section'>Proof from products, workflows, and AI systems.</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					Three examples of the same pattern: narrow the problem, build the useful system, and leave the work easier to own.
				</p>
			</div>
		</div>

		<div class='mt-12 space-y-10 md:space-y-12'>
			{
				featuredCaseStudy && (
					<a
						href={`/projects/${featuredCaseStudy.slug}/`}
						class='case-study-feature group grid gap-8 transition-colors lg:grid-cols-[1.08fr_0.92fr] lg:items-end lg:gap-14'
					>
						<figure class='overflow-hidden border border-black/15 bg-zinc-950 dark:border-white/15'>
							<Image
								src={featuredCaseStudy.image}
								alt={featuredCaseStudy.imageAlt}
								class:list={[
									'aspect-[16/10] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.02]',
									featuredCaseStudy.imageClass
								]}
								loading='eager'
							/>
						</figure>

						<div class='flex h-full flex-col justify-between gap-6 lg:py-2'>
							<div class='space-y-4'>
								<p class='font-mono text-xs uppercase tracking-[0.28em] text-primary'>Featured / {featuredCaseStudy.label}</p>
								<h3 class='heading-display heading-display--section'>{featuredCaseStudy.title}</h3>
								<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{featuredCaseStudy.body}</p>
							</div>
							<div class='space-y-4'>
								<div class='border-t border-black/12 pt-4 dark:border-white/12'>
									<p class='font-mono text-xs uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500'>Outcome</p>
									<p class='mt-1 text-sm font-medium leading-6 text-zinc-800 dark:text-zinc-100'>{featuredCaseStudy.outcome}</p>
								</div>
								<span class='arrow-link group-hover:border-primary group-hover:text-primary'>View case study</span>
							</div>
						</div>
					</a>
				)
			}

			<div class='case-study-secondary-grid'>
				{
					secondaryCaseStudies.map((study) => (
						<a href={`/projects/${study.slug}/`} class='case-study-secondary group'>
							<figure class='overflow-hidden border border-black/15 bg-zinc-950 dark:border-white/15'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={[
										'aspect-[16/10] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.02]',
										study.imageClass
									]}
									loading='eager'
								/>
							</figure>
							<div class='space-y-3'>
								<p class='font-mono text-xs uppercase tracking-[0.28em] text-primary'>{study.label}</p>
								<h3 class='heading-display heading-display--subsection'>{study.title}</h3>
								<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{study.outcome}</p>
							</div>
							<span class='arrow-link w-fit group-hover:border-primary group-hover:text-primary'>View case study</span>
						</a>
					))
				}
			</div>

			<div class='pt-2'>
				<a class='arrow-link' href='/projects/'>
					See all case studies
				</a>
			</div>
		</div>
	</section>

	<section class='container py-16 md:py-20' aria-labelledby='home-paths-title'>
		<div class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='launch-meta text-primary'>Start here</p>
				<h2 id='home-paths-title' class='heading-display heading-display--section'>Choose the kind of uncertainty you have.</h2>
			</div>

			<div class='path-choices'>
				{
					pathCards.map((path) => (
						<a href={path.href} class='path-choice group'>
							<div class='path-choice__header'>
								<p class='launch-meta text-primary'>{path.label}</p>
								<span class='path-choice__arrow'>↗</span>
							</div>
							<div class='space-y-4'>
								<h3 class='heading-display text-[clamp(2.25rem,4vw,4.4rem)]'>{path.title}</h3>
								<p class='path-choice__body'>{path.body}</p>
							</div>
							<span class='arrow-link w-fit group-hover:border-primary group-hover:text-primary'>{path.cta}</span>
						</a>
					))
				}
			</div>

			<div class='home-fit-check'>
				<div class='max-w-2xl space-y-3'>
					<p class='launch-meta text-primary'>Fit check</p>
					<h3 class='heading-display heading-display--subsection'>Before we talk, this should feel familiar.</h3>
				</div>

				<div class='fit-grid'>
					{
						fitColumns.map((column) => (
							<div class='fit-column'>
								<p class='launch-meta text-primary'>{column.title}</p>
								<ul class='fit-list'>
									{column.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
							</div>
						))
					}
				</div>
			</div>

			<div class='fit-actions pt-2'>
				<a
					class='home-hero-primary-link'
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					data-track-event='book_call_clicked'
					data-track-location='home_fit_primary'
				>
					Book a Roadmap Call
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
