---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';
import { HOMEPAGE_CASE_STUDY_SLUGS } from '../lib/project-curation';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import casamoPhoto from '@src/assets/img/projects/casamo-homepage-viewport.jpg';
import genruptPhoto from '@src/assets/img/projects/genrupt-creative-ops-photo.png';
import palabrunoPhoto from '@src/assets/img/projects/palabruno-language-study-photo.png';

const title = 'Hanif Carroll | Technical Product Partner for MVPs';
const description =
	'I help nontechnical founders launch focused web and mobile MVPs, and give founder-led teams senior fractional product engineering help.';

const homepageJsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		jobTitle: 'Technical Product Partner',
		description,
		sameAs: ['https://github.com/hanifcarroll', 'https://linkedin.com/in/hanifcarroll', 'https://x.com/hanifcarroll'],
		knowsAbout: ['Product engineering', 'MVP development', 'SaaS', 'mobile apps', 'fractional product engineering']
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		description
	}
];

const pathCards = [
	{
		label: 'Product path',
		title: 'Launch a first version',
		body: 'For founders who need the first useful version scoped, built, and live.',
		href: '/launch/#mvp'
	},
	{
		label: 'Fractional path',
		title: 'Add senior product engineering',
		body: 'For founder-led teams that need scope control, architecture judgment, and steady shipping help.',
		href: '/launch/#fractional'
	}
];

const caseStudyBySlug = {
	palabruno: {
		slug: 'palabruno',
		label: 'MVP build',
		title: 'Palabruno',
		body: 'Helped a nontechnical founder shape, build, and launch Palabruno: a Spanish reading app with mobile subscriptions, web payments for teachers, app store launch assets, UX polish, and public-site copy.',
		image: palabrunoPhoto,
		imageAlt: 'Language study notebook and vocabulary cards on a wooden table.',
		imageClass: undefined
	},
	genrupt: {
		slug: 'genrupt',
		label: 'Product platform',
		title: 'Genrupt',
		body: 'Helped Genrupt move beyond demo-stage image and video generation by adding the commercial and reliability foundations needed for paid Amazon seller workflows.',
		image: genruptPhoto,
		imageAlt: 'E-commerce creative operations desk with packages, notes, and product materials.',
		imageClass: 'object-left-top'
	},
	casamo: {
		slug: 'casamo',
		label: 'Travel decision MVP',
		title: 'Casamo',
		body: 'Built a travel decision product that helps remote workers find the stay worth booking without opening 20 tabs or trusting misleading marketplace filters.',
		image: casamoPhoto,
		imageAlt: 'Casamo homepage showing the stay search form and audit priorities over a furnished apartment.',
		imageClass: 'object-left-top'
	}
} as const;

const caseStudies = HOMEPAGE_CASE_STUDY_SLUGS.map((slug) => caseStudyBySlug[slug]);

const proofStats = [
	{ label: '8+ years', value: 'Product and software delivery' },
	{ label: '10+ shipped', value: 'Products, systems, and tools' },
	{ label: '3,000+', value: 'Organizers supported at LeagueApps' }
];

const fitItems = [
	'You need a focused MVP built from scratch, or senior product engineering help for an existing product.',
	'You want one person who can advise on scope, UX, architecture, and implementation.',
	'You need a smaller first step before committing to a bigger build.'
];

const testimonials = [
	{
		quote: 'Hanif quickly understood our needs, both from a business and aesthetic perspective, and translated them into a clean, functional website in no time.',
		name: 'Monica Londoño',
		role: 'Co-founder',
		company: 'Punto de Partida'
	},
	{
		quote: "He's reliable, communicates great, and has a sharp technical mind. Whether handling complex builds, troubleshooting under pressure, or adapting to shifting priorities, he was dependable every step of the way.",
		name: 'Markis Zarate',
		role: 'Founder',
		company: 'Zarate Studios'
	},
	{
		quote: 'He suggested design-to-engineering hand-off improvements to make our workflow more efficient, asked insightful follow-up questions during design reviews, and brought my Figma designs to life so we could deliver value to our users.',
		name: 'Sarah Hibner',
		role: 'Senior Product Designer',
		company: 'LeagueApps'
	}
];
---

<BaseLayout
	title={title}
	description={description}
	jsonLd={homepageJsonLd}
	flushTop
	showFooterCta={false}
	footerLinksOnly
	padContentBeforeFooter={false}
>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero'>
				<h1 class='home-hero-title'>
					<span>Launch your MVP.</span>
					<span>Keep a senior engineer on call.</span>
				</h1>

				<div class='home-hero-split'>
					<div class='home-hero-copy-wrap'>
						<div class='home-hero-copy space-y-6 md:space-y-7'>
							<p class='home-hero-body'>
								I help nontechnical founders and lean teams turn rough product ideas into launched web and mobile MVPs.
								Then I stay on as fractional product engineering support when senior judgment matters.
							</p>
							<div class='home-hero-actions'>
								<a
									class='home-hero-primary-link'
									href={BOOK_CALL_URL}
									target='_blank'
									rel='noopener noreferrer'
									data-track-event='book_call_clicked'
									data-track-location='home_hero_primary'
								>
									Book a Roadmap Call
								</a>
								<a class='home-hero-secondary-link' href='/projects/'>See case studies</a>
							</div>
						</div>
					</div>

					<div class='home-hero-media'>
						<figure class='home-hero-image-wrap'>
							<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
						</figure>
					</div>
				</div>
			</header>

			<dl class='home-proof-strip' aria-label='Portfolio proof points'>
				{
					proofStats.map((item) => (
						<div class='home-proof-strip__item'>
							<dt>{item.label}</dt>
							<dd>{item.value}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</section>

	<section class='home-testimonials-band' aria-labelledby='home-testimonials-title'>
		<div class='container home-testimonials'>
			<p class='home-testimonials__eyebrow' id='home-testimonials-title'>What clients say</p>
			<div class='home-testimonials__grid'>
				{
					testimonials.map((t) => (
						<figure class='home-testimonial'>
							<blockquote class='home-testimonial__quote'>
								<p>{t.quote}</p>
							</blockquote>
							<figcaption class='home-testimonial__attr'>
								<span class='home-testimonial__name'>{t.name}</span>
								<span class='home-testimonial__role'>
									{t.role}, {t.company}
								</span>
							</figcaption>
						</figure>
					))
				}
			</div>
		</div>
	</section>

	<section class='container home-about' aria-labelledby='home-about-title'>
		<div class='home-about__inner'>
			<h2 id='home-about-title' class='home-about__title'>Hi, I'm Hanif.</h2>
			<p class='home-about__body'>
				I've spent eight years shipping web and mobile products — from a Spanish reading app I built end-to-end to senior product
				engineering for teams at LeagueApps and beyond. I work with nontechnical founders and lean teams who need someone who can
				make scope, design, and engineering judgment calls in the same conversation, then ship the result.
			</p>
			<p class='home-about__location'>Based in Buenos Aires. Available worldwide.</p>
		</div>
	</section>

	<section class='container home-start-section' aria-labelledby='home-paths-title'>
		<div class='home-start-section__inner'>
			<div class='space-y-5'>
				<h2 id='home-paths-title' class='heading-display home-start-section__title'>Choose the right first step</h2>
			</div>

			<div class='path-choices'>
				{
					pathCards.map((path) => (
						<a href={path.href} class='path-choice group'>
							<div class='path-choice__header'>
								<p class='launch-meta'>{path.label}</p>
								<span class='path-choice__arrow'>↗</span>
							</div>
							<div class='space-y-3'>
								<h3 class='heading-display path-choice__title'>{path.title}</h3>
								<p class='path-choice__body'>{path.body}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<h2 class='heading-display home-case-studies-title'>Case Studies</h2>
		</div>

		<div class='case-study-rows mt-8'>
			{
				caseStudies.map((study, index) => (
					<a href={`/projects/${study.slug}/`} class='case-study-row group'>
						<div class='case-study-row__copy'>
							<p class='case-study-row__eyebrow'>
								<span aria-hidden='true' />
								CASE STUDY {String(index + 1).padStart(2, '0')}
							</p>
							<div class='case-study-row__body'>
								<div class='space-y-5'>
									<h3 class='case-study-row__title'>{study.title}</h3>
									<p class='case-study-row__description'>{study.body}</p>
								</div>
								<span class='case-study-row__button'>View case study</span>
							</div>
						</div>
						<figure class='case-study-row__media'>
							<div class='case-study-row__image-frame'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={['case-study-row__image transition duration-700 ease-out group-hover:scale-[1.025]', study.imageClass]}
									loading='eager'
								/>
							</div>
						</figure>
					</a>
				))
			}

			<p class='case-study-archive-link'>
				<a href='/projects/'>See all case studies <span aria-hidden='true'>→</span></a>
			</p>
		</div>
	</section>

	<section class='container home-fit-section' aria-labelledby='home-fit-title'>
		<div class='home-fit-section__inner'>
			<div class='space-y-3'>
				<h2 id='home-fit-title' class='home-fit-section__title'>Is this for you?</h2>
				<p class='home-fit-section__lede'>A roadmap call is the right next step if any of these sound familiar:</p>
			</div>

			<ul class='fit-list home-fit-list'>
				{fitItems.map((item) => <li>{item}</li>)}
			</ul>

			<div class='fit-actions'>
				<a
					class='home-hero-primary-link'
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					data-track-event='book_call_clicked'
					data-track-location='home_fit_primary'
				>
					Book a Roadmap Call
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
