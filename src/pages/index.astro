---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL_URL } from '../consts';
import { HOMEPAGE_CASE_STUDY_SLUGS } from '../lib/project-curation';
import HeroImage from '@src/assets/img/portrait-brick.webp';
import casamoPhoto from '@src/assets/img/projects/casamo-homepage-viewport.jpg';
import genruptPhoto from '@src/assets/img/projects/genrupt-creative-ops-photo.png';
import palabrunoPhoto from '@src/assets/img/projects/palabruno-reading-materials-photo.png';

const title = 'Hanif Carroll | Product Engineer';
const description =
	'Product engineer with 8+ years across web and mobile. Based in Buenos Aires, working US hours. US clients contract through HC Studio, my LLC.';

const homepageJsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		jobTitle: 'Product Engineer',
		description,
		sameAs: ['https://github.com/hanifcarroll', 'https://linkedin.com/in/hanifcarroll', 'https://x.com/hanifcarroll'],
		knowsAbout: ['Product engineering', 'AI products', 'LLMs', 'RAG', 'AI agents', 'React', 'Next.js', 'React Native', 'TypeScript']
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/',
		description
	}
];

const caseStudyBySlug = {
	palabruno: {
		slug: 'palabruno',
		label: 'MVP build',
		title: 'Palabruno',
		body: "Took a non-technical founder's idea from concept to live iOS, Android, and web app — including teacher workflows, AI features, Stripe/RevenueCat billing, and App Store launch.",
		tech: 'React Native / Expo • Supabase • Stripe • RevenueCat • OpenAI',
		image: palabrunoPhoto,
		imageAlt: 'Spanish reading materials with vocabulary, grammar, and pronunciation cards.',
		imageClass: undefined
	},
	genrupt: {
		slug: 'genrupt',
		label: 'Product platform',
		title: 'Genrupt',
		body: 'Evolved an AI media MVP into a production platform for Amazon sellers with subscriptions, credit billing, agent access, and background jobs — enabled the first 100 paying customers.',
		tech: 'Next.js • PostgreSQL • Stripe • OpenAI • MCP',
		image: genruptPhoto,
		imageAlt: 'E-commerce creative operations desk with packages, notes, and product materials.',
		imageClass: 'object-left-top'
	},
	casamo: {
		slug: 'casamo',
		label: 'Travel decision MVP',
		title: 'Casamo',
		body: 'Built an AI-powered travel decision tool that helps remote workers find quality long-stay accommodations, with automated scanning, payments, and analytics.',
		tech: 'TanStack Start • PostgreSQL • Stripe • Playwright • OpenAI',
		image: casamoPhoto,
		imageAlt: 'Casamo homepage showing the stay search form and audit priorities over a furnished apartment.',
		imageClass: 'object-left-top'
	}
} as const;

const caseStudies = HOMEPAGE_CASE_STUDY_SLUGS.map((slug) => caseStudyBySlug[slug]);

const techStackGroups = [
	{
		id: 'core-stack',
		title: 'Core Stack',
		items: ['TypeScript', 'React', 'Next.js', 'Supabase', 'React Native / Expo', 'Node.js', 'PostgreSQL']
	},
	{
		id: 'ai-agents',
		title: 'AI & Agents',
		items: ['OpenAI', 'Anthropic', 'MCP', 'RAG', 'Evals', 'Agent Workflows']
	},
	{
		id: 'tools-infrastructure',
		title: 'Tools & Infrastructure',
		items: ['Stripe', 'RevenueCat', 'Vercel', 'Docker', 'Playwright', 'Claude Code', 'ChatGPT Codex']
	}
];

const testimonials = [
	{
		quote:
			'Hanif quickly understood our needs, both from a business and aesthetic perspective, and translated them into a clean, functional website in no time.',
		name: 'Monica Londoño',
		role: 'Co-founder',
		company: 'Punto de Partida'
	},
	{
		quote:
			"He's reliable, communicates great, and has a sharp technical mind. Whether handling complex builds, troubleshooting under pressure, or adapting to shifting priorities, he was dependable every step of the way.",
		name: 'Markis Zarate',
		role: 'Founder',
		company: 'Zarate Studios'
	},
	{
		quote:
			'He suggested design-to-engineering hand-off improvements to make our workflow more efficient, asked insightful follow-up questions during design reviews, and brought my Figma designs to life so we could deliver value to our users.',
		name: 'Sarah Hibner',
		role: 'Senior Product Designer',
		company: 'LeagueApps'
	}
];
---

<BaseLayout
	title={title}
	description={description}
	jsonLd={homepageJsonLd}
	flushTop
	showFooterCta={false}
	footerLinksOnly
	padContentBeforeFooter={false}
>
	<section class='home-hero-shell'>
		<div class='container home-hero-stage'>
			<header class='home-hero'>
				<h1 class='sr-only'>{title}</h1>
				<div class='home-hero-split'>
					<div class='home-hero-copy-wrap'>
						<div class='home-hero-copy'>
							<p class='home-hero-greeting'>Hey, I'm <span class='home-hero-greeting__name'>Hanif</span>.</p>
							<p class='home-hero-subheadline'>
								<span>I help founders and teams turn </span>
								<span>AI product ideas into shipped, </span>
								<span>revenue-generating software.</span>
							</p>
							<p class='home-hero-body'>
								8+ years building web and mobile products, with recent work focused on LLMs, agents, RAG, evals, and MCP.
							</p>
							<div class='home-hero-actions'>
								<a class='home-hero-primary-link' href={EMAIL_URL} data-track-event='email_clicked' data-track-location='home_hero_primary'>
									Get in touch
								</a>
								<a class='home-hero-secondary-link' href='#case-studies'>See case studies</a>
							</div>
						</div>
					</div>

					<div class='home-hero-media'>
						<figure class='home-hero-image-wrap'>
							<Image src={HeroImage} alt='Hanif Carroll' class='home-hero-portrait' loading='eager' />
						</figure>
					</div>
				</div>
			</header>
		</div>
	</section>

	<section class='container py-16 md:py-20' id='case-studies'>
		<div class='space-y-5'>
			<h2 class='heading-display home-case-studies-title'>Case Studies</h2>
		</div>

		<div class='case-study-rows mt-8'>
			{
				caseStudies.map((study, index) => (
					<a href={`/projects/${study.slug}/`} class='case-study-row group'>
						<div class='case-study-row__copy'>
							<p class='case-study-row__eyebrow'>
								<span aria-hidden='true' />
								CASE STUDY {String(index + 1).padStart(2, '0')}
							</p>
							<div class='case-study-row__body'>
								<div class='space-y-5'>
									<h3 class='case-study-row__title'>{study.title}</h3>
									<p class='case-study-row__description'>{study.body}</p>
									<p class='case-study-row__tech'>{study.tech}</p>
								</div>
								<span class='case-study-row__button'>View case study</span>
							</div>
						</div>
						<figure class='case-study-row__media'>
							<div class='case-study-row__image-frame'>
								<Image
									src={study.image}
									alt={study.imageAlt}
									class:list={['case-study-row__image transition duration-700 ease-out group-hover:scale-[1.025]', study.imageClass]}
									loading='eager'
								/>
							</div>
						</figure>
					</a>
				))
			}

			<p class='case-study-archive-link'>
				<a href='/projects/'>See all case studies <span aria-hidden='true'>→</span></a>
			</p>
		</div>
	</section>

	<section class='container home-tech-section' aria-labelledby='home-tech-title'>
		<div class='home-tech-section__heading'>
			<h2 id='home-tech-title' class='home-tech-section__title'>What I Work With</h2>
			<p class='home-tech-section__intro'>
				Tools I use to take AI products from early ideas all the way to production.
			</p>
		</div>

		<div class='home-tech-grid'>
			{
				techStackGroups.map((group) => (
					<section class='home-tech-group' aria-labelledby={`home-tech-${group.id}`}>
						<h3 id={`home-tech-${group.id}`} class='home-tech-group__title'>{group.title}</h3>
						<ul class='home-tech-group__tags'>
							{group.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</section>

	<section class='home-testimonials-band' aria-labelledby='home-testimonials-title'>
		<div class='container home-testimonials'>
			<p class='home-testimonials__eyebrow' id='home-testimonials-title'>What People I've Worked With Say</p>
			<div class='home-testimonials__grid'>
				{
					testimonials.map((t) => (
						<figure class='home-testimonial'>
							<blockquote class='home-testimonial__quote'>
								<p>{t.quote}</p>
							</blockquote>
							<figcaption class='home-testimonial__attr'>
								<span class='home-testimonial__name'>{t.name}</span>
								<span class='home-testimonial__role'>
									{t.role}, {t.company}
								</span>
							</figcaption>
						</figure>
					))
				}
			</div>
		</div>
	</section>

	<section class='container home-about' aria-labelledby='home-about-title'>
		<div class='home-about__inner'>
			<h2 id='home-about-title' class='home-about__title'>A Bit About Me</h2>
			<p class='home-about__body'>
				I partner with founders and teams to build and launch AI products — from shaping the idea and narrowing scope to shipping the first
				version. I’m also building Casamo, an AI tool that helps remote workers find good long-term stays.
			</p>
			<p class='home-about__location'>Based in Buenos Aires, working US hours. US clients contract with me through HC Studio, my LLC.</p>
			<p class='home-about__location'>
				<a
					href='/about/'
					class='inline-flex items-center gap-1.5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500 transition-colors hover:text-primary dark:text-zinc-400'
				>
					More about me <span aria-hidden='true'>→</span>
				</a>
			</p>
		</div>
	</section>

	<section class='container home-about' aria-labelledby='home-pov-title'>
		<div class='home-about__inner'>
			<h2 id='home-pov-title' class='home-about__title'>Point of View</h2>
			<p class='home-about__body'>
				In the age of AI, taste gets a lot of attention. But the harder skill is deciding what’s actually worth building and following through.
				Implementation is getting easier while clear judgment and execution are becoming more rare.
			</p>
			<p class='home-about__location'>
				<a
					href='/point-of-view/'
					class='inline-flex items-center gap-1.5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500 transition-colors hover:text-primary dark:text-zinc-400'
				>
					More points of view <span aria-hidden='true'>→</span>
				</a>
			</p>
		</div>
	</section>

	<section class='container home-fit-section' aria-labelledby='home-contact-title'>
		<div class='home-fit-section__inner'>
			<div class='space-y-3'>
				<h2 id='home-contact-title' class='home-fit-section__title'>Let's Talk</h2>
				<p class='home-fit-section__lede'>
					Working on an AI product and need a partner who can help shape it and get it shipped? Let’s talk.
				</p>
			</div>

			<div class='fit-actions'>
				<a class='home-hero-primary-link' href={EMAIL_URL} data-track-event='email_clicked' data-track-location='home_contact_primary'>
					Let's talk
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
