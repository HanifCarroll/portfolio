---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';

const title = 'MVP Launches & Fractional Product Engineering';
const description =
	'Web and mobile MVP launches for nontechnical founders. Fractional product engineering for founder-led teams that need senior help shipping.';
const calUrl = BOOK_CALL_URL;

const pathChoices = [
	{
		label: 'Product path',
		title: '4-Week Launch',
		anchor: 'mvp',
		summary: 'For nontechnical founders with a product idea that needs to become a usable first version.',
		price: 'Starts at $10,000',
		signals: ['The idea is still rough.', 'You need scope, UX, build, and launch support from one person.'],
		cta: 'Talk through a launch',
		trackLocation: 'launch_path_product'
	},
	{
		label: 'Fractional path',
		title: 'Fractional Product Engineering',
		anchor: 'fractional',
		summary: 'For founder-led teams that need senior product engineering help without hiring full-time.',
		price: 'Fractional retainers',
		signals: [
			'Scope keeps slipping, or technical decisions are slowing the team down.',
			'You need one senior builder who can make architecture calls and ship.'
		],
		cta: 'Talk through the retainer',
		trackLocation: 'launch_path_fractional'
	}
];

const roadmapSteps = [
	{
		num: '01',
		title: 'Bring the messy version',
		body: 'A rough idea, half-built product, or current constraint is enough.'
	},
	{
		num: '02',
		title: 'Pick the smallest useful step',
		body: 'We decide whether this is a launch, a fractional retainer, or a smaller first step.'
	},
	{
		num: '03',
		title: 'Leave with a practical scope',
		body: 'You leave with a path, budget range, and the next decision.'
	}
];

const faqItems = [
	{
		title: 'Can I book a call before the scope is clear?',
		body: 'Yes. Bring the rough version: an idea, prototype, half-built product, or current team constraint. I will help identify the first useful move and tell you whether the work should be a focused MVP launch, fractional product engineering, or a smaller first step.'
	},
	{
		title: 'How does pricing work?',
		body: '4-Week Launches start at $10,000. Fractional work depends on how much senior product and engineering support the team needs each week.'
	},
	{
		title: 'What if the first version should be smaller?',
		body: 'We choose the simplest useful version. That might mean narrowing the MVP, turning the work into a short fractional sprint, or delaying features until the signal is clearer.'
	}
];
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly bodyClass='page-launch'>
	<article class='container max-w-6xl service-page-stack py-14 md:py-16'>

		<header class='service-hero-grid'>
			<div class='service-hero-copy'>
				<p class='service-section-label'>Technical Product Partner</p>
				<h1 class='heading-display heading-display--hero' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='4.85'>
					Launch the right first product.
				</h1>
				<p class='service-hero-body'>
					I help nontechnical founders turn rough ideas into focused web and mobile MVPs. I also work with founder-led teams that
					need senior product engineering support without hiring full-time.
				</p>
				<div class='flex flex-wrap gap-4'>
					<a
						href={calUrl}
						target='_blank'
						rel='noopener noreferrer'
						class='home-hero-primary-link'
						data-track-event='book_call_clicked'
						data-track-location='launch_hero'
					>
						Book a Roadmap Call
					</a>
					<a href='#paths' class='fit-secondary-link'>See the options</a>
				</div>
			</div>
		</header>

		<section id='paths' class='service-paths-section'>
			<div class='service-paths-heading'>
				<p class='service-section-label'>Two ways to start</p>
				<h2 class='heading-display service-choice-title'>
					<span>Start a first version</span>
					<span class='service-choice-or'>or</span>
					<span>Continue building with senior product help</span>
				</h2>
			</div>

			<div class='service-path-cards'>
				{
					pathChoices.map((choice) => (
						<a
							id={choice.anchor}
							href={calUrl}
							target='_blank'
							rel='noopener noreferrer'
							class='service-path-card group'
							data-track-event='book_call_clicked'
							data-track-location={choice.trackLocation}
						>
							<div class='service-path-card__header'>
								<p class='service-section-label'>{choice.label}</p>
								<p class='service-path-card__price'>{choice.price}</p>
							</div>
							<div class='service-path-card__body'>
								<h3 class='heading-display heading-display--subsection service-path-card__title'>{choice.title}</h3>
								<p class='service-path-card__summary'>{choice.summary}</p>
								<ul class='service-path-card__signals'>
									{choice.signals.map((signal) => (
										<li>{signal}</li>
									))}
								</ul>
							</div>
							<span class='arrow-link w-fit'>{choice.cta}</span>
						</a>
					))
				}
			</div>
		</section>

		<section class='service-section'>
			<div class='space-y-4'>
				<h2 class='heading-display heading-display--section'>Use the call to choose the first move.</h2>
			</div>
			<div class='service-launch-steps'>
				{
					roadmapSteps.map((step) => (
						<div class='service-launch-step'>
							<p class='service-launch-step__num'>{step.num}</p>
							<div class='space-y-3'>
								<h3 class='heading-display heading-display--subsection'>{step.title}</h3>
								<p class='text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{step.body}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section class='service-faq-section'>
			<h2 class='heading-display heading-display--section'>Questions founders usually ask first.</h2>
			<div class='service-faq-compact'>
				{
					faqItems.map((item) => (
						<div class='service-faq-compact__item'>
							<p class='service-faq-compact__question'>{item.title}</p>
							<p class='text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='service-section service-detail-grid'>
			<div class='space-y-4'>
				<h2 class='heading-display heading-display--section'>Not sure which path fits?</h2>
			</div>
			<div class='space-y-5'>
				<p class='max-w-2xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
					I&rsquo;ll help decide whether this should be a focused MVP launch, a fractional retainer, or a smaller first step.
				</p>
				<a
					href={calUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='home-hero-primary-link'
					data-track-event='book_call_clicked'
					data-track-location='launch_final'
				>
					Book a Roadmap Call
				</a>
			</div>
		</section>

	</article>
</BaseLayout>
