---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { BOOK_CALL_URL } from "../consts";
import testimonials from "../../testimonials.json";
import monicaPhoto from "@src/assets/img/monica.jpeg";
import markisPhoto from "@src/assets/img/markis.jpeg";
import sarahPhoto from "@src/assets/img/sarah.jpeg";

const title = "MVP Builds";
const description =
    "I help nontechnical founders shape the product, build it, and take it to market in 4 weeks.";
const calUrl = BOOK_CALL_URL;
const monicaTestimonial = testimonials.find(
    (testimonial) => testimonial.name === "Monica Londoño",
);

const testimonialPhotos: Record<string, ImageMetadata> = {
    "Monica Londoño": monicaPhoto,
    "Markis Zarate": markisPhoto,
    "Sarah Hibner": sarahPhoto,
};

const buyerChallenges = [
    {
        title: "You're not sure what the MVP should include",
        body: "You need someone who can look at your idea, figure out what matters, and define the first version — not just code what you describe.",
    },
    {
        title: "You need more than just a developer",
        body: "You want help with product decisions, pricing, UX, and go-to-market — not someone who waits for a spec.",
    },
    {
        title: "You want direct accountability",
        body: "A previous freelancer or agency left you with too little visibility and too much cleanup.",
    },
    {
        title: "You need plain-English decisions",
        body: "You want the tradeoffs explained in business terms, not buried under technical jargon.",
    },
];

const bestFit = [
    "You need a real v1 in front of users soon.",
    "You can make product decisions and join a short weekly check-in.",
    "You want direct access to the person building the product.",
];

const notFit = [
    "You need a large platform with broad feature scope on day one.",
    "You want exhaustive custom design before product decisions are made.",
    "You cannot stay involved during scoping and review.",
];

const includedItems = [
    "Product strategy: scoping the MVP, defining user tiers, and advising on pricing.",
    "UX and design decisions so you don't need a separate designer.",
    "Full-stack product build across frontend, backend, and deployment.",
    "Marketing site and positioning to support your launch.",
    "Launch setup plus 30 days of post-launch bug coverage.",
    "Recorded handoff and shared project visibility from day one.",
];

const priceComparisons = [
    {
        label: "US-Based Developer",
        value: "$8-15K/month",
        note: "And you are still managing the process.",
    },
    {
        label: "Technical Cofounder",
        value: "30-50% equity",
        note: "A huge long-term trade for an early build.",
    },
    {
        label: "Agency",
        value: "$15-30K",
        note: "Usually with more overhead and a longer timeline.",
    },
];

const faqItems = [
    {
        title: "Burned by a developer before",
        body: "The code lives in your GitHub from day one, you see weekly demos, and the project board stays shared the whole time.",
    },
    {
        title: "Not sure what to build first",
        body: "The scoping sprint is for that. You leave with a clearer roadmap before I write a line of code.",
    },
    {
        title: "After launch",
        body: "I handle deployment, monitoring, bug fixes for 30 days, and a recorded handoff so the next developer can pick it up cleanly.",
    },
    {
        title: "Budget and payment",
        body: "Projects typically range from $10,000\u2013$15,000 depending on scope. Payment is 50% upfront to start, 50% at launch. No equity required.",
    },
];
---

<BaseLayout
    title={`${title} · Hanif Carroll`}
    description={description}
    showFooterCta={false}
    footerLinksOnly
>
    <article class="container max-w-5xl space-y-32 py-10">
        <!-- Breadcrumb -->
        <nav
            class="flex items-center gap-2 font-mono text-xs uppercase tracking-wide"
        >
            <a href="/" class="transition-colors hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">Home</a>
            <span class="text-zinc-400">/</span>
            <span class="text-primary">Launch</span>
        </nav>

        <!-- 1. Hero -->
        <header class="space-y-6">
            <span class="section-label">// MVP Builds</span>
            <h1 class="heading-display text-5xl md:text-6xl" style="text-wrap: balance">
                A focused MVP live in 4&nbsp;weeks.
            </h1>
            <p
                class="text-xl text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-2xl"
            >
                I help you figure out what the MVP should be, advise on pricing and
                positioning, design the UX, build the product, and set up the marketing
                site. Best for nontechnical founders who need a product partner, not
                just a developer.
            </p>
            <div class="space-y-2">
                <a href={calUrl} target="_blank" rel="noopener noreferrer" class="btn-primary inline-block py-3 px-6 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" data-track-event="book_call_clicked" data-track-location="launch_hero">
                    Book a Roadmap Call
                </a>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 font-mono uppercase tracking-wide">30 minutes &middot; Clear next step</p>
            </div>
        </header>

        <div class="grid-line-horizontal"></div>

        <!-- 2. Credibility Strip -->
        <section class="space-y-12">
            <div class="grid gap-6 md:grid-cols-3">
                <div class="tech-card p-6 text-center">
                    <p class="heading-display text-3xl text-primary" style="font-variant-numeric: tabular-nums">8+</p>
                    <p class="font-mono text-xs uppercase tracking-wide text-zinc-600 dark:text-zinc-300 mt-2">Years Building Products</p>
                </div>
                <div class="tech-card p-6 text-center">
                    <p class="heading-display text-3xl text-primary" style="font-variant-numeric: tabular-nums">10+</p>
                    <p class="font-mono text-xs uppercase tracking-wide text-zinc-600 dark:text-zinc-300 mt-2">Projects Shipped</p>
                </div>
                <div class="tech-card p-6 text-center">
                    <p class="heading-display text-3xl text-primary">4 Weeks</p>
                    <p class="font-mono text-xs uppercase tracking-wide text-zinc-600 dark:text-zinc-300 mt-2">Average Time to Launch</p>
                </div>
            </div>

            <p class="text-sm text-zinc-500 dark:text-zinc-400 text-center font-mono uppercase tracking-wide">Previously at Capgemini &amp; LeagueApps</p>

            <!-- Testimonials -->
            <div class="space-y-4">
                <h2 class="heading-display text-3xl md:text-4xl">Client notes</h2>
            </div>
            <div class="space-y-6">
                {testimonials.map((testimonial) => {
                    const photo = testimonialPhotos[testimonial.name];
                    return (
                        <div class="tech-card p-8">
                            <div class="flex items-start gap-6">
                                {photo && (
                                    <div class="shrink-0">
                                        <div class="w-16 h-16 border-2 border-black dark:border-white overflow-hidden bg-black">
                                            <Image
                                                src={photo}
                                                alt={testimonial.name}
                                                width={64}
                                                height={64}
                                                loading="lazy"
                                                class="w-full h-full object-cover"
                                            />
                                        </div>
                                    </div>
                                )}
                                <div class="space-y-3">
                                    <div>
                                        <p class="font-bold uppercase tracking-wide">{testimonial.name}</p>
                                        <p class="text-xs font-mono uppercase tracking-wider text-zinc-500 dark:text-zinc-300">
                                            {testimonial.role}
                                            {testimonial.company ? ` · ${testimonial.company}` : ""}
                                        </p>
                                    </div>
                                    <p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
                                        &ldquo;{testimonial.text}&rdquo;
                                    </p>
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 3. Problem Section -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// Why Founders Come to Me</span>
                <h2 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">
                    You need a real v1 without wasting months on the wrong build.
                </h2>
                <p class="text-lg text-zinc-600 dark:text-zinc-300">
                    Usually the problem is simpler: the scope is fuzzy, execution is slow,
                    or the work keeps getting handed off.
                </p>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
                {buyerChallenges.map((challenge) => (
                    <div class="tech-card p-8">
                        <h3 class="font-bold uppercase tracking-wide">{challenge.title}</h3>
                        <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">
                            {challenge.body}
                        </p>
                    </div>
                ))}
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 4. "Not for Everyone" Qualifier -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// Best Fit</span>
                <h2 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">
                    Best fit for founders who need a smaller, clearer first version.
                </h2>
            </div>

            <div class="tech-card p-8 md:p-10 space-y-8">
                <div class="grid gap-8 md:grid-cols-2">
                    <div class="space-y-4">
                        <p class="font-mono text-xs uppercase tracking-[0.24em] text-primary">Best fit</p>
                        <ul class="space-y-4 text-zinc-600 dark:text-zinc-300">
                            {bestFit.map((item) => (
                                <li class="flex gap-3">
                                    <span class="text-primary font-bold shrink-0">+</span>
                                    <span>{item}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="space-y-4">
                        <p class="font-mono text-xs uppercase tracking-[0.24em] text-primary">Not a fit</p>
                        <ul class="space-y-4 text-zinc-600 dark:text-zinc-300">
                            {notFit.map((item) => (
                                <li class="flex gap-3">
                                    <span class="text-primary font-bold shrink-0">&times;</span>
                                    <span>{item}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>

                <div class="grid-line-horizontal"></div>

                <blockquote class="text-xl font-bold" style="text-wrap: balance">
                    I&rsquo;m a solo engineer in Buenos Aires. This is direct work, not an agency process.
                </blockquote>

                <div class="grid gap-6 md:grid-cols-3">
                    <div>
                        <p class="font-bold uppercase tracking-wide">Direct Access</p>
                        <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-2">You talk to the person building your product. No account managers, no game of telephone.</p>
                    </div>
                    <div>
                        <p class="font-bold uppercase tracking-wide">No Overhead</p>
                        <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-2">No office, no junior devs learning on your dime. You pay for senior-level execution, nothing else.</p>
                    </div>
                    <div>
                        <p class="font-bold uppercase tracking-wide">Speed</p>
                        <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-2">One decision-maker, zero bureaucracy. I move fast because there&rsquo;s nothing slowing me down.</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 5. How It Works -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// The Process</span>
                <h2 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">
                    How the four weeks are used.
                </h2>
            </div>

            <div class="space-y-6">
                <div class="tech-card p-8">
                    <span class="section-label">// 01</span>
                    <h3 class="font-bold uppercase tracking-wide mt-3">Scoping Sprint (Days 1&ndash;3)</h3>
                    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">You leave with a clear build plan before I write a line of code.</p>
                </div>
                <div class="tech-card p-8">
                    <span class="section-label">// 02</span>
                    <h3 class="font-bold uppercase tracking-wide mt-3">Core Build Starts (Week 1)</h3>
                    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">
                        The highest-risk part of the product gets built early so you have
                        visible progress and something concrete to react to.
                    </p>
                </div>
                <div class="tech-card p-8">
                    <span class="section-label">// 03</span>
                    <h3 class="font-bold uppercase tracking-wide mt-3">Full Build + Weekly Demos (Weeks 2&ndash;4)</h3>
                    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">I build while you join a 30-minute demo each week and give feedback in plain English.</p>
                </div>
                <div class="tech-card p-8">
                    <span class="section-label">// 04</span>
                    <h3 class="font-bold uppercase tracking-wide mt-3">Launch Day</h3>
                    <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">Your product is live, hosted, and monitored. I handle the technical launch. You focus on telling customers.</p>
                </div>
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 6. Offer Stack -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// Offer + Price</span>
                <h2 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">
                    What a focused four-week build includes.
                </h2>
                <p class="text-lg text-zinc-600 dark:text-zinc-300 max-w-2xl">
                    The roadmap call is where we narrow whether this is the right kind of
                    project. If it is, the build starts with a scoping sprint and a fixed
                    first version.
                </p>
            </div>

            <div class="tech-card p-8 md:p-10 space-y-8">
                <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
                    <div class="space-y-4">
                        <p class="font-mono text-xs uppercase tracking-wide text-primary font-bold">Included</p>
                        <ul class="space-y-4 text-zinc-600 dark:text-zinc-300">
                            {includedItems.map((item) => (
                                <li class="border-t border-black/10 pt-4 dark:border-white/10">
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>

                    <div class="space-y-4 border-t border-black/10 pt-6 dark:border-white/10 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
                        <p class="font-mono text-xs uppercase tracking-wide text-primary font-bold">Starting price</p>
                        <p class="heading-display text-4xl text-primary" style="font-variant-numeric: tabular-nums">
                            Starting at $10,000
                        </p>
                        <div class="space-y-3 text-sm text-zinc-600 dark:text-zinc-300">
                            <p>Fixed-scope build for the first useful version.</p>
                            <p>50% upfront to start, 50% at launch.</p>
                            <p>No equity. No agency layers. Direct communication.</p>
                        </div>
                    </div>
                </div>

                <div class="grid-line-horizontal"></div>

                <div class="grid gap-6 md:grid-cols-3">
                    {priceComparisons.map((comparison) => (
                        <div class="tech-card p-6 text-center space-y-3">
                            <p class="font-mono text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
                                {comparison.label}
                            </p>
                            <p class="heading-display text-2xl" style="font-variant-numeric: tabular-nums">
                                {comparison.value}
                            </p>
                            <p class="text-sm text-zinc-600 dark:text-zinc-300">
                                {comparison.note}
                            </p>
                        </div>
                    ))}
                </div>

                <div class="text-center pt-2">
                    <a href={calUrl} target="_blank" rel="noopener noreferrer" class="btn-primary inline-block py-3 px-6 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" data-track-event="book_call_clicked" data-track-location="launch_offer_price">
                        Book a Roadmap Call
                    </a>
                </div>
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 7. Guarantee / Risk Reversal -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// The Guarantee</span>
            </div>

            <div class="tech-card border-primary p-10 md:p-12 space-y-6">
                <p class="font-mono text-xs uppercase tracking-wide text-primary font-bold">Low-risk first step</p>
                <p class="text-2xl md:text-3xl font-bold" style="text-wrap: balance">
                    If I miss the four-week timeline because of my execution, I keep working until the agreed MVP is live at no added cost.
                </p>
                <p class="text-zinc-600 dark:text-zinc-300">
                    This depends on timely feedback, a tight scope, and normal client-side access during the build.
                </p>
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 8. Objection FAQ -->
        <section class="space-y-12">
            <div class="space-y-4">
                <span class="section-label">// Common Concerns</span>
                <h2 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">Common concerns</h2>
            </div>

            <div class="space-y-6">
                {faqItems.map((item) => (
                    <div class="tech-card p-8">
                        <h3 class="font-bold uppercase tracking-wide">{item.title}</h3>
                        <p class="text-sm text-zinc-600 dark:text-zinc-300 mt-3">
                            {item.body}
                        </p>
                    </div>
                ))}
            </div>
        </section>

        <div class="grid-line-horizontal"></div>

        <!-- 9. Scarcity + Final CTA -->
        <section class="text-center max-w-2xl mx-auto space-y-6">
            {monicaTestimonial && (
                <div class="tech-card p-6 text-left space-y-2">
                    <p class="font-mono text-xs uppercase tracking-wide text-primary font-bold">
                        Founder note
                    </p>
                    <p class="text-sm leading-7 text-zinc-600 dark:text-zinc-300">
                        Monica Londoño, co-founder at Punto de Partida, said the work moved
                        quickly and stayed aligned with both the business need and the visual
                        direction.
                    </p>
                </div>
            )}
            <p class="font-mono text-sm uppercase tracking-wide text-zinc-600 dark:text-zinc-300">I only take on 2 build projects at a time.</p>
            <h2 class="heading-display text-3xl md:text-4xl" style="text-wrap: balance">
                Bring the scope. I&rsquo;ll tell you whether this should be a 4-week build.
            </h2>
            <p class="text-zinc-600 dark:text-zinc-300">
                Book a 30-minute roadmap call. You&rsquo;ll leave with a clearer scope,
                rough timeline, and a direct answer on fit.
            </p>
            <a href={calUrl} target="_blank" rel="noopener noreferrer" class="btn-primary inline-block py-3 px-6 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" data-track-event="book_call_clicked" data-track-location="launch_final">
                Book a Roadmap Call
            </a>
        </section>
    </article>
</BaseLayout>
