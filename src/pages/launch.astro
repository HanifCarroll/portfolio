---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';

const title = 'MVP Launches & Workflow Audits';
const description =
	'MVP launches for nontechnical founders and workflow audits for founder-led teams that need automation, internal tools, or useful AI systems.';
const calUrl = BOOK_CALL_URL;

const heroFacts = [
	{ label: 'Best for', value: 'Nontechnical founders and founder-led teams that need a useful first system in use soon.' },
	{ label: 'Starting points', value: 'The 4-Week Launch starts at $10,000. Workflow audits start at $2,000.' },
	{ label: 'What you get', value: 'Clear scope, direct execution, and one person handling the product and technical tradeoffs.' }
];

const compareCards = [
	{
		label: 'Offer 01',
		title: 'The 4-Week Launch',
		summary: 'A fixed-scope MVP for nontechnical founders who need product judgment and senior execution in one person.',
		price: 'Starts at $10,000',
		priceDisplay: '$10K+',
		kicker: 'Fixed-scope MVP build',
		bestFor: [
			'You need a first useful version live without hiring a team first.',
			'The idea is promising, but the right v1 is still fuzzy.',
			'You want one person handling scope, UX, build, and launch.'
		],
		cta: 'See the MVP path',
		href: '#mvp'
	},
	{
		label: 'Offer 02',
		title: 'Workflow Audit / AI Systems',
		summary: 'A paid diagnostic for founder-led teams with repeated manual work, scattered context, or an AI idea without a clean workflow underneath.',
		price: 'Workflow audits from $2,000',
		priceDisplay: '$2K+',
		kicker: 'Paid diagnostic first',
		bestFor: [
			'Your team is losing time to copy-paste, inbox triage, or handoff chaos.',
			'You suspect the workflow is the real issue, not the tool on top of it.',
			'You want to know whether software, automation, or AI is actually the right fix.'
		],
		cta: 'See the workflow path',
		href: '#automation'
	}
];

const mvpBestFor = [
	'Nontechnical founders who need more than a developer.',
	'Teams that need a smaller, clearer first version.',
	'Founders who can stay involved in scope and weekly review.'
];

const includedItems = [
	'Product strategy, scope cuts, and pricing guidance before code starts.',
	'UX and design decisions so you do not need a separate designer.',
	'Frontend, backend, deployment, and launch setup.',
	'Marketing site support plus 30 days of post-launch bug coverage.',
	'Recorded handoff and shared project visibility from day one.'
];

const automationBestFor = [
	'Founder-led teams with repeated manual work and no clear system under it.',
	'SMBs that rely on copy-paste, inbox triage, or one person holding too much context.',
	'Teams exploring AI, but only if it actually improves the workflow.'
];

const workflowAuditItems = [
	'Workflow map: tools, people, handoffs, data, and failure points.',
	'Bottleneck diagnosis: what is actually slowing the business down.',
	'Data and context readiness check before AI or automation gets added.',
	'Human review map: where a person needs to approve, edit, or override the system.',
	'Implementation recommendation: software, automation, AI, or no build yet.',
	'Scope, budget range, timeline, risks, and next step.'
];

const launchSteps = [
	{
		num: '01',
		title: 'Cut the v1 scope',
		body: 'Reduce the product to the first version that can create real learning or revenue.'
	},
	{
		num: '02',
		title: 'Build with direct feedback',
		body: 'Weekly demos and tradeoff calls keep the work moving without agency layers.'
	},
	{
		num: '03',
		title: 'Launch with handoff',
		body: 'Go live cleanly, then leave the project in a state the next person can pick up.'
	}
];

const auditOutputs = [
	{ label: 'Workflow map', body: 'Tools, people, handoffs, and where the work actually stalls.' },
	{ label: 'Constraint diagnosis', body: 'What is really slowing the business down and what is just a symptom.' },
	{ label: 'Build recommendation', body: 'Software, automation, AI, or no build yet.' },
	{ label: 'First-step scope', body: 'Budget range, risks, and the smallest next system worth implementing.' }
];

const engagementSteps = [
	{
		num: '01',
		title: 'Clarify the bottleneck',
		body: 'We narrow the actual problem first so the engagement starts from the business constraint, not from a guessed solution.'
	},
	{
		num: '02',
		title: 'Cut the first useful scope',
		body: 'The work gets reduced to the smallest system that can create a real outcome, whether that is an MVP, an internal tool, or an audit.'
	},
	{
		num: '03',
		title: 'Build the right first system',
		body: 'Once the first step is clear, I build it directly with short feedback loops and a clean handoff.'
	}
];

const faqItems = [
	{
		title: 'Not sure which path fits?',
		body: 'That is exactly what the roadmap call is for. I will tell you whether this should start as an MVP, a workflow audit, or something smaller.'
	},
	{
		title: 'Burned by developers before?',
		body: 'The code lives in your GitHub from day one, you see regular demos, and the project stays visible the whole time.'
	},
	{
		title: 'What happens after launch?',
		body: 'I handle deployment, bug coverage for 30 days, and a recorded handoff so the next developer can pick it up cleanly.'
	},
	{
		title: 'How does pricing work?',
		body: 'The 4-Week Launch starts at $10,000 with 50% upfront and 50% at launch. Workflow audits start at $2,000 and are credited toward implementation if we move forward.'
	},
	{
		title: 'What if AI is not the right fix?',
		body: 'Then I will say that. The audit is meant to choose the right first system, not force AI into the workflow.'
	}
];
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly bodyClass='page-launch'>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Services</span>
		</nav>

		<header class='service-hero-grid'>
			<div class='space-y-6'>
				<p class='section-label'>// Services</p>
				<h1 class='heading-display text-4xl md:text-6xl'>Choose the right starting path.</h1>
				<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
					This page should help you decide whether you need a focused MVP build or a workflow audit first.
				</p>
				<div class='flex flex-wrap gap-4 pt-1'>
					<a
						href={calUrl}
						target='_blank'
						rel='noopener noreferrer'
						class='home-hero-primary-link'
						data-track-event='book_call_clicked'
						data-track-location='launch_hero'
					>
						Book a Roadmap Call
					</a>
				</div>
			</div>

			<div class='service-summary-grid'>
				{
					heroFacts.map((fact) => (
						<div class='service-summary-item'>
							<p class='launch-meta text-primary'>{fact.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{fact.value}</p>
						</div>
					))
				}
			</div>
		</header>

		<section id='compare' class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// Compare The Paths</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Most engagements start in one of two places.</h2>
			</div>

			<div class='service-compare-grid'>
				<a href={compareCards[0].href} class='service-compare-panel service-compare-panel--launch group'>
					<div class='service-compare-price'>
						<p class='heading-display text-5xl text-primary md:text-6xl' style='font-variant-numeric: tabular-nums'>{compareCards[0].priceDisplay}</p>
						<p class='launch-meta'>{compareCards[0].price}</p>
					</div>
					<div class='space-y-4'>
						<p class='launch-meta text-primary'>{compareCards[0].label}</p>
						<p class='launch-meta'>{compareCards[0].kicker}</p>
						<h3 class='heading-display text-3xl md:text-5xl'>{compareCards[0].title}</h3>
						<p class='max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{compareCards[0].summary}</p>
					</div>
					<div class='space-y-4'>
						<p class='launch-meta text-primary'>Best fit</p>
						<ul class='fit-list'>
							{compareCards[0].bestFor.map((item) => <li>{item}</li>)}
						</ul>
					</div>
					<span class='arrow-link w-fit group-hover:border-primary group-hover:text-primary'>{compareCards[0].cta}</span>
				</a>

				<a href={compareCards[1].href} class='service-compare-panel service-compare-panel--audit group'>
					<div class='service-audit-sheet'>
						<div class='service-audit-sheet__head'>
							<div class='space-y-2'>
								<p class='launch-meta text-primary'>{compareCards[1].label}</p>
								<p class='launch-meta'>{compareCards[1].kicker}</p>
							</div>
							<div class='space-y-1 text-left md:text-right'>
								<p class='heading-display text-5xl text-primary md:text-6xl' style='font-variant-numeric: tabular-nums'>{compareCards[1].priceDisplay}</p>
								<p class='launch-meta'>{compareCards[1].price}</p>
							</div>
						</div>
						<div class='space-y-4'>
							<h3 class='heading-display text-3xl md:text-[3.2rem]'>{compareCards[1].title}</h3>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{compareCards[1].summary}</p>
						</div>
						<div class='service-audit-sheet__rows'>
							<p class='launch-meta text-primary'>Best fit</p>
							{compareCards[1].bestFor.map((item) => <p class='fit-signal'>{item}</p>)}
						</div>
					</div>
					<span class='arrow-link w-fit group-hover:border-primary group-hover:text-primary'>{compareCards[1].cta}</span>
				</a>
			</div>
		</section>

		<section id='mvp' class='space-y-10 md:space-y-12'>
			<div class='service-detail-grid'>
				<div class='space-y-4'>
					<p class='section-label'>// The 4-Week Launch</p>
					<h2 class='heading-display text-3xl md:text-5xl'>A focused MVP live in 4 weeks.</h2>
					<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>
						I help define what the MVP should be, advise on pricing and positioning, design the UX, build the product, and set up the
						launch. Best for nontechnical founders who need a product partner, not just a pair of hands.
					</p>
					<p class='launch-meta'>Starts at $10,000. Fixed scope. 50% upfront, 50% at launch.</p>
				</div>

				<div class='grid gap-10 lg:grid-cols-[0.95fr_1.05fr]'>
					<div class='space-y-4'>
						<p class='launch-meta text-primary'>Best for</p>
						<ul class='fit-list'>
							{mvpBestFor.map((item) => <li>{item}</li>)}
						</ul>
					</div>
					<div class='space-y-4'>
						<p class='launch-meta text-primary'>Included</p>
						<ul class='fit-list'>
							{includedItems.map((item) => <li>{item}</li>)}
						</ul>
					</div>
				</div>
			</div>

			<div class='service-launch-steps'>
				{launchSteps.map((step) => (
					<div class='service-launch-step'>
						<p class='launch-meta text-primary'>Step {step.num}</p>
						<div class='space-y-3'>
							<h3 class='heading-display text-2xl md:text-3xl'>{step.title}</h3>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{step.body}</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<section id='automation' class='space-y-10 md:space-y-12'>
			<div class='service-detail-grid service-detail-grid--audit'>
				<div class='space-y-4'>
					<p class='section-label'>// Workflow Audit / AI Systems</p>
					<h2 class='heading-display text-3xl md:text-5xl'>Figure out what the workflow actually needs first.</h2>
					<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>
						For founder-led teams and business owners whose operations are slowing down because too much knowledge lives in people, tabs,
						and manual workarounds. The audit comes before the build because most automation failures are workflow failures first.
					</p>
					<p class='launch-meta'>Workflow audits start at $2,000 and are credited toward implementation if we move forward.</p>
				</div>

				<div class='service-audit-sidebar'>
					<p class='launch-meta text-primary'>Best for</p>
					<ul class='fit-list'>
						{automationBestFor.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</div>

			<div class='service-audit-worksheet'>
				<div class='service-audit-worksheet__intro space-y-4'>
					<p class='section-label'>// Audit Output</p>
					<h3 class='heading-display text-3xl md:text-5xl'>A smaller first system, not a vague recommendation.</h3>
					<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
						The audit should leave you with something concrete enough to act on, even if the right next move is not a build yet.
					</p>
				</div>
				<div class='service-audit-worksheet__grid'>
					{auditOutputs.map((item) => (
						<div class='service-audit-note'>
							<p class='launch-meta text-primary'>{item.label}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))}
				</div>
			</div>

			<div class='service-audit-includes'>
				<div class='space-y-4'>
					<p class='launch-meta text-primary'>Audit includes</p>
					<ul class='fit-list'>
						{workflowAuditItems.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// How Engagements Start</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Most engagements start by narrowing the real problem.</h2>
			</div>
			<div class='how-we-work-grid'>
				{
					engagementSteps.map((step) => (
						<div class='how-we-work-step'>
							<p class='heading-display how-we-work-step__num text-primary'>{step.num}</p>
							<div class='space-y-3'>
								<h3 class='heading-display text-2xl md:text-3xl'>{step.title}</h3>
								<p class='max-w-xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>{step.body}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// Common Concerns</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Common concerns before starting.</h2>
			</div>
			<div class='service-faq-grid'>
				{
					faqItems.map((item) => (
						<div class='space-y-3'>
							<p class='launch-meta text-primary'>{item.title}</p>
							<p class='text-base leading-7 text-zinc-600 dark:text-zinc-300'>{item.body}</p>
						</div>
					))
				}
			</div>
		</section>

		<section class='service-detail-grid'>
			<div class='space-y-4'>
				<p class='section-label'>// Next Step</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Bring the scope. I&rsquo;ll tell you what the first useful step is.</h2>
			</div>
			<div class='space-y-5'>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					Book a 30-minute roadmap call. You&rsquo;ll leave with a clearer scope, the likely budget range, and a direct answer on whether
					this should start as an MVP, a workflow audit, or something smaller.
				</p>
				<a
					href={calUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='home-hero-primary-link'
					data-track-event='book_call_clicked'
					data-track-location='launch_final'
				>
					Book a Roadmap Call
				</a>
			</div>
		</section>
	</article>
</BaseLayout>
