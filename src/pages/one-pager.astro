---
import BaseHead from '../layouts/components/BaseHead.astro';
import { BOOK_CALL_URL } from '../consts';

const title = 'Founder MVP + Workflow One-Pager';
const description = "A shareable overview of Hanif Carroll's MVP launch, workflow audit, and AI systems work for nontechnical founders.";

const proofItems = [
	{
		name: 'Palabruno',
		label: 'Founder MVP',
		detail:
			'Helped a nontechnical founder shape and launch a Spanish reading MVP across iOS, Android, and web, including subscriptions, teacher payments, app store assets, UX polish, and public-site copy.'
	},
	{
		name: 'Apartment Finder',
		label: 'AI product',
		detail:
			'Built an AI search product that turns noisy rental listings into evidence-backed decisions, with fixture-based evaluation and measured model-cost tradeoffs.'
	},
	{
		name: 'Genrupt',
		label: 'AI systems',
		detail:
			'Expanded an AI media MVP into a commercial Amazon seller workflow platform with subscriptions, safer async generation, credit accounting, and agent-accessible creative operations.'
	},
	{
		name: 'Desarmadero La Torre',
		label: 'Workflow system',
		detail:
			'Built a searchable digital stockroom so customers could check inventory before calling and staff could spend less time answering repetitive stock questions.'
	}
];

const launchSteps = [
	['01', 'Scope', 'Cut the idea to the smallest useful first version.'],
	['02', 'Build', 'Ship the core product surface, data flow, and integrations.'],
	['03', 'Polish', 'Tighten UX, copy, payments, launch assets, and feedback loops.'],
	['04', 'Launch', 'Deploy, hand off, and leave the founder with a product they can own.']
];

const fitSignals = [
	'A nontechnical founder needs more than implementation of a fixed spec.',
	'A team has manual review, search, handoff, or decision work that software could simplify.',
	'The first version needs senior product judgment, UX thinking, and implementation in one place.',
	'There is enough urgency and decision speed to keep momentum.'
];
---

<!doctype html>
<html lang='en'>
	<head>
		<BaseHead title={`${title} · Hanif Carroll`} description={description} />
		<style is:inline>
			@page {
				size: Letter;
				margin: 0.58in;
			}

			:root {
				--ink: #121212;
				--muted: #5f6368;
				--soft: #f5f1e8;
				--paper: #fffdf8;
				--line: #d8d0c2;
				--blue: #155eef;
				--green: #117865;
			}

			html,
			body {
				background: var(--soft) !important;
			}

			body {
				color: var(--ink);
				-webkit-print-color-adjust: exact;
				print-color-adjust: exact;
				font-family: Inter, system-ui, sans-serif;
			}

			a {
				color: inherit;
			}

			.sheet {
				max-width: 1040px;
				margin: 0 auto;
				background: var(--paper);
				border: 1px solid var(--line);
			}

			.display {
				font-family: Inter, system-ui, sans-serif;
				font-weight: 900;
				letter-spacing: -0.055em;
				line-height: 0.92;
				text-transform: uppercase;
				text-wrap: balance;
			}

			.eyebrow,
			.mini-label {
				font-family: 'IBM Plex Mono', ui-monospace, monospace;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			.eyebrow {
				color: var(--muted);
			}

			.mini-label,
			.accent {
				color: var(--blue);
			}

			.muted {
				color: var(--muted);
			}

			.section {
				break-inside: auto;
				page-break-inside: auto;
			}

			.section + .section {
				margin-top: 1.75rem;
				padding-top: 1.35rem;
				border-top: 1px solid var(--line);
			}

			.hero-grid,
			.two-col,
			.proof-grid {
				display: grid;
				gap: 1.35rem;
			}

			.hero-grid {
				grid-template-columns: 1.18fr 0.82fr;
				align-items: end;
			}

			.two-col {
				grid-template-columns: 1fr 1fr;
			}

			.proof-grid {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.panel {
				border: 1px solid var(--ink);
				background: #ffffff;
				padding: 1.05rem;
			}

			.proof-card {
				border-top: 2px solid var(--ink);
				padding-top: 0.78rem;
				break-inside: avoid;
				page-break-inside: avoid;
			}

			.stat-grid,
			.launch-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.8rem;
			}

			.launch-grid {
				grid-template-columns: repeat(4, minmax(0, 1fr));
			}

			.stat,
			.launch-step {
				border-left: 3px solid var(--blue);
				padding-left: 0.75rem;
			}

			.hero-panel .stat-grid {
				grid-template-columns: 1fr;
				gap: 0.7rem;
			}

			.hero-panel .stat {
				display: grid;
				grid-template-columns: 4.6rem 1fr;
				gap: 0.6rem;
			}

			.hero-panel .stat .display {
				font-size: 1.35rem;
				letter-spacing: -0.025em;
				line-height: 1;
			}

			.price-band {
				border: 1px solid var(--ink);
				background: var(--ink);
				color: #ffffff;
				padding: 1.1rem;
				break-inside: avoid;
				page-break-inside: avoid;
			}

			.price-band .muted {
				color: rgba(255, 255, 255, 0.72);
			}

			.fit-list {
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.fit-list li {
				border-top: 1px solid var(--line);
				padding: 0.52rem 0;
			}

			.fit-list li:first-child {
				border-top: 0;
				padding-top: 0;
			}

			@media print {
				html,
				body {
					background: white !important;
				}

				.sheet {
					border: 0;
					max-width: none;
					padding: 0 !important;
				}

				.display {
					letter-spacing: -0.045em;
				}

				.section + .section {
					margin-top: 1.15rem;
					padding-top: 0.95rem;
				}

				.two-col.section,
				.launch-section,
				.proof-section,
				.price-band {
					break-inside: avoid;
					page-break-inside: avoid;
				}

				.launch-section,
				.proof-section {
					break-before: page;
					page-break-before: always;
				}

				.fit-list li {
					padding: 0.42rem 0;
				}

				a {
					color: inherit;
					text-decoration: none;
				}
			}

			@media screen and (max-width: 800px) {
				.hero-grid,
				.two-col,
				.proof-grid,
				.stat-grid,
				.launch-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<main class='px-5 py-5'>
			<article class='sheet px-7 py-7 md:px-10 md:py-10'>
				<section class='section hero-grid'>
					<div class='space-y-5'>
						<p class='eyebrow'>Hanif Carroll · Technical Product Partner · Buenos Aires</p>
						<div class='space-y-4'>
							<h1 class='display text-4xl md:text-5xl'>I help nontechnical founders turn rough ideas into working software.</h1>
							<p class='muted max-w-2xl text-lg leading-relaxed'>
								Scope, UX, full-stack development, launch support, workflow automation, and useful AI systems, handled directly by one
								senior product builder.
							</p>
						</div>
					</div>

					<div class='panel hero-panel space-y-4'>
						<p class='mini-label'>When to send me someone</p>
						<p class='display text-2xl'>They need the right first product or workflow system, not a pile of developer hours.</p>
						<div class='stat-grid'>
							<div class='stat'>
								<p class='display text-2xl'>10+</p>
								<p class='muted text-sm'>years building products</p>
							</div>
							<div class='stat'>
								<p class='display text-2xl'>Direct</p>
								<p class='muted text-sm'>senior execution</p>
							</div>
							<div class='stat'>
								<p class='display text-2xl'>Fast</p>
								<p class='muted text-sm'>focused scope and feedback</p>
							</div>
						</div>
					</div>
				</section>

				<section class='section two-col'>
					<div class='space-y-4'>
						<p class='mini-label'>Two ways to start</p>
						<h2 class='display text-2xl md:text-3xl'>Launch when the product is unclear.</h2>
						<p class='muted leading-relaxed'>
							The 4-Week Launch is for founders who need the first useful version scoped, built, and live. It is best when the goal is a
							real product users can try, pay for, or react to.
						</p>
					</div>

					<div class='space-y-4'>
						<p class='mini-label' style='color: var(--green);'>Lower-friction first step</p>
						<h2 class='display text-2xl md:text-3xl'>Audit when the workflow is unclear.</h2>
						<p class='muted leading-relaxed'>
							The Workflow Audit is for teams that need to find the bottleneck before building. The answer might be software, automation,
							AI, a cleaner handoff, or no build yet.
						</p>
					</div>
				</section>

				<section class='section launch-section space-y-6'>
					<div class='flex items-end justify-between gap-6'>
						<div>
							<p class='mini-label'>The 4-Week Launch</p>
							<h2 class='display mt-2 text-2xl md:text-3xl'>From idea to live MVP in four focused weeks.</h2>
						</div>
						<p class='muted max-w-sm text-right text-sm leading-relaxed'>
							A fixed-scope build with weekly demos, direct communication, launch support, and a handoff the founder can own.
						</p>
					</div>

					<div class='launch-grid'>
						{
							launchSteps.map(([num, label, body]) => (
								<div class='launch-step'>
									<p class='mini-label'>{num}</p>
									<p class='mt-2 font-semibold'>{label}</p>
									<p class='muted mt-1 text-sm leading-relaxed'>{body}</p>
								</div>
							))
						}
					</div>
				</section>

				<section class='section proof-section space-y-6'>
					<div>
						<p class='mini-label'>Recent proof</p>
						<h2 class='display mt-2 text-2xl md:text-3xl'>Founder launch, AI product, seller workflows, operational systems.</h2>
					</div>

					<div class='proof-grid'>
						{
							proofItems.map((item) => (
								<div class='proof-card'>
									<p class='mini-label'>{item.label}</p>
									<p class='mt-2 text-lg font-bold'>{item.name}</p>
									<p class='muted mt-2 text-sm leading-relaxed'>{item.detail}</p>
								</div>
							))
						}
					</div>
				</section>

				<section class='section split-col two-col'>
					<div class='space-y-5'>
						<div>
							<p class='mini-label'>Good referrals</p>
							<h2 class='display mt-2 text-2xl md:text-3xl'>Best fit for founders who can decide and want momentum.</h2>
						</div>
						<ul class='fit-list muted text-sm leading-relaxed'>
							{fitSignals.map((signal) => <li>{signal}</li>)}
						</ul>
					</div>

					<div class='space-y-5'>
						<div class='price-band space-y-3'>
							<p class='mini-label'>Engagements</p>
							<p class='display text-2xl md:text-3xl'>Launches start at $10,000.</p>
							<p class='muted text-sm leading-relaxed'>
								Workflow audits start at $1,000 and can be credited toward implementation if we move forward.
							</p>
						</div>

						<div class='space-y-3'>
							<p class='mini-label'>Next step</p>
							<h2 class='display text-2xl'>Book a Product Roadmap Call.</h2>
							<p class='muted text-sm leading-relaxed'>
								I will help cut scope, choose the right first step, and tell you whether I am the right fit.
							</p>
							<div class='space-y-1 text-sm'>
								<p><span class='font-bold'>Offer:</span> <a href='https://www.hanifcarroll.com/launch'>hanifcarroll.com/launch</a></p>
								<p>
									<span class='font-bold'>Portfolio:</span>
									<a href='https://www.hanifcarroll.com/projects'>hanifcarroll.com/projects</a>
								</p>
								<p><span class='font-bold'>Call:</span> <a href={BOOK_CALL_URL}>{BOOK_CALL_URL.replace('https://', '')}</a></p>
								<p><span class='font-bold'>Email:</span> <a href='mailto:HanifCarroll@gmail.com'>HanifCarroll@gmail.com</a></p>
							</div>
						</div>
					</div>
				</section>
			</article>
		</main>
	</body>
</html>
