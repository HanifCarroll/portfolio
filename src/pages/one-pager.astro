---
import BaseHead from "../layouts/components/BaseHead.astro";

const title = "Founder MVP One-Pager";
const description =
  "From idea to live MVP in 4 weeks. Direct senior execution, clear communication, and no agency overhead.";
const calUrl = "https://cal.com/hanifcarroll/roadmap-call";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={`${title} · Hanif Carroll`} description={description} />
    <style is:inline>
      @page {
        size: Letter;
        margin: 0.45in;
      }

      html,
      body {
        background: white !important;
      }

      @media print {
        html,
        body {
          background: white !important;
        }

        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }

        .print-shell {
          padding-top: 0 !important;
          padding-bottom: 0 !important;
        }

        .avoid-break,
        .avoid-break > *,
        .tech-card,
        .print-block {
          break-inside: avoid;
          page-break-inside: avoid;
        }

        a {
          color: inherit !important;
          text-decoration: none !important;
        }
      }
    </style>
  </head>
  <body class="font-sans bg-white text-black">
    <main class="print-shell py-8 md:py-10">
      <article class="container">
        <div class="mx-auto max-w-4xl space-y-8">
          <header class="avoid-break space-y-5 border-2 border-black p-8 md:p-10">
            <div class="space-y-2">
              <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">Hanif Carroll</p>
              <h1 class="heading-display text-4xl md:text-5xl" style="text-wrap: balance">
                Full-stack engineer for nontechnical founders who need a real MVP fast.
              </h1>
            </div>
            <p class="text-lg text-zinc-700 max-w-3xl leading-relaxed">
              I help founders go from idea to live product in 4 weeks. Scope, UX,
              full-stack development, deployment, and launch support — handled directly by me.
            </p>
            <div class="grid gap-4 md:grid-cols-3 text-sm font-mono uppercase tracking-wide text-zinc-700">
              <div class="tech-card print-block p-4">8+ years building products</div>
              <div class="tech-card print-block p-4">React / Next.js / Node / TypeScript / AI</div>
              <div class="tech-card print-block p-4">Focused MVP launches start at $7,500</div>
            </div>
          </header>

          <section class="avoid-break grid gap-6 md:grid-cols-2">
            <div class="tech-card print-block p-8 space-y-4">
              <h2 class="heading-display text-2xl">Who I help</h2>
              <ul class="space-y-3 text-zinc-700">
                <li>• Nontechnical founders who need a technical partner they can trust</li>
                <li>• Early-stage teams validating a new product or internal tool</li>
                <li>• Operators who want direct access to the builder, not agency layers</li>
                <li>• Founders who need clarity, speed, and plain-English communication</li>
              </ul>
            </div>

            <div class="tech-card print-block p-8 space-y-4">
              <h2 class="heading-display text-2xl">What I deliver</h2>
              <ul class="space-y-3 text-zinc-700">
                <li>• MVP scoping sprint to cut scope to what matters</li>
                <li>• UX and product thinking for a clean v1 experience</li>
                <li>• Full-stack build from frontend to backend</li>
                <li>• Deployment, launch support, and 30-day bug coverage</li>
              </ul>
            </div>
          </section>

          <section class="avoid-break tech-card print-block p-8 md:p-10 space-y-6">
            <div class="space-y-2">
              <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">The 4-Week Launch</p>
              <h2 class="heading-display text-3xl md:text-4xl">From idea to live MVP in 4 weeks.</h2>
            </div>
            <div class="grid gap-6 md:grid-cols-4">
              <div class="print-block">
                <p class="font-mono text-xs uppercase tracking-wide text-zinc-500">Week 1</p>
                <p class="mt-2 text-sm text-zinc-700">Scoping sprint, roadmap, and product decisions.</p>
              </div>
              <div class="print-block">
                <p class="font-mono text-xs uppercase tracking-wide text-zinc-500">Week 2</p>
                <p class="mt-2 text-sm text-zinc-700">Core build starts with visible momentum.</p>
              </div>
              <div class="print-block">
                <p class="font-mono text-xs uppercase tracking-wide text-zinc-500">Week 3</p>
                <p class="mt-2 text-sm text-zinc-700">Refinement, polish, integrations, and founder feedback.</p>
              </div>
              <div class="print-block">
                <p class="font-mono text-xs uppercase tracking-wide text-zinc-500">Week 4</p>
                <p class="mt-2 text-sm text-zinc-700">Launch, deployment, handoff, and bug shield.</p>
              </div>
            </div>
          </section>

          <section class="avoid-break grid gap-6 md:grid-cols-[1.2fr_0.8fr]">
            <div class="tech-card print-block p-8 space-y-4">
              <h2 class="heading-display text-2xl">Relevant work</h2>
              <div class="space-y-4 text-zinc-700">
                <div class="print-block">
                  <p class="font-bold">Genrupt</p>
                  <p class="text-sm">Ongoing development partner for an AI image and video generation platform.</p>
                </div>
                <div class="print-block">
                  <p class="font-bold">BA Events</p>
                  <p class="text-sm">AI-powered event discovery product with conversational UX and production data pipelines.</p>
                </div>
                <div class="print-block">
                  <p class="font-bold">Client fit</p>
                  <p class="text-sm">Best fit for founders who want a focused first version, weekly demos, and a product they can actually show users.</p>
                </div>
              </div>
            </div>

            <div class="tech-card print-block p-8 space-y-5">
              <div class="print-block">
                <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary">Pricing</p>
                <p class="heading-display text-3xl mt-2">Starting at $7,500</p>
                <p class="text-sm text-zinc-700 mt-2">Exact pricing depends on scope, integrations, and complexity.</p>
              </div>
              <div class="space-y-3 text-sm text-zinc-700">
                <p>• Fixed-scope launch engagement</p>
                <p>• Weekly demos and direct communication</p>
                <p>• No equity required</p>
                <p>• 50% upfront, 50% at launch</p>
              </div>
            </div>
          </section>

          <section class="avoid-break border-2 border-black p-8 md:p-10 space-y-4">
            <h2 class="heading-display text-3xl">Next step</h2>
            <p class="text-zinc-700 max-w-2xl">
              Book a free Product Roadmap Call. I’ll help cut scope, map the fastest realistic MVP, and tell you whether I’m the right fit.
            </p>
            <div class="space-y-1 text-sm text-zinc-700">
              <p><span class="font-bold">Website:</span> hanifcarroll.com/launch</p>
              <p><span class="font-bold">Portfolio:</span> hanifcarroll.com/projects</p>
              <p><span class="font-bold">Call:</span> <a href={calUrl}>cal.com/hanifcarroll/roadmap-call</a></p>
              <p><span class="font-bold">Location:</span> Buenos Aires, Argentina (works remotely worldwide)</p>
            </div>
          </section>
        </div>
      </article>
    </main>
  </body>
</html>
