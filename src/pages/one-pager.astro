---
import BaseHead from "../layouts/components/BaseHead.astro";
import { BOOK_CALL_URL } from "../consts";

const title = "MVPs + Workflow Automation One-Pager";
const description =
  "A shareable overview of Hanif Carroll's MVP builds, workflow automation, and AI agent work for nontechnical founders and business owners.";

const offerTracks = [
  {
    label: "01",
    title: "MVP builds",
    intro: "For nontechnical founders who need a real first version in users' hands.",
    bullets: [
      "Cut scope to the smallest version worth shipping.",
      "Build the product, not just the landing page.",
      "Launch with direct feedback and a clean handoff.",
    ],
  },
  {
    label: "02",
    title: "Workflow automation + AI agents",
    intro: "For business owners and lean teams buried in repeat work and slow handoffs.",
    bullets: [
      "Turn repeated tasks into internal tools or automation.",
      "Connect the systems already running the business.",
      "Add AI only when it reduces work or improves a decision.",
    ],
  },
];

const proofItems = [
  {
    name: "Casa Elaria",
    detail:
      "Built a fake-door storefront so the founder could validate demand before paying for inventory.",
  },
  {
    name: "Desarmadero La Torre",
    detail:
      "Built a searchable digital stockroom that cut down on repetitive phone-based inventory checks.",
  },
  {
    name: "Genrupt",
    detail:
      "Expanded an AI media MVP into a billable Amazon creative ops platform with subscriptions, queue-backed generation, and seller-facing creative workflows.",
  },
];

const fitSignals = [
  "A founder or owner has a concrete problem, not just a vague idea.",
  "There is urgency: launch, validation, or operational drag is costing time or money.",
  "They want direct senior execution instead of agency layers.",
  "They can make decisions and give timely feedback.",
];

const links = [
  { label: "MVP offer", href: "https://www.hanifcarroll.com/launch" },
  {
    label: "Automation offer",
    href: "https://www.hanifcarroll.com/automation-ai-agents",
  },
  { label: "Case studies", href: "https://www.hanifcarroll.com/projects" },
  { label: "Roadmap call", href: BOOK_CALL_URL },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} · Hanif Carroll`} description={description} />
    <style is:inline>
      @page {
        size: Letter;
        margin: 0.6in;
      }

      html,
      body {
        background: #f2ede3 !important;
      }

      body {
        color: #111111;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        font-family: "IBM Plex Sans", system-ui, sans-serif;
      }

      a {
        color: inherit;
      }

      .sheet {
        max-width: 1120px;
        margin: 0 auto;
      }

      .display {
        font-family: "Syne", "IBM Plex Sans", system-ui, sans-serif;
        font-weight: 700;
        letter-spacing: -0.06em;
        line-height: 0.93;
        text-transform: uppercase;
        text-wrap: balance;
      }

      .eyebrow,
      .mini-label {
        font-family: "IBM Plex Mono", ui-monospace, monospace;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.24em;
        text-transform: uppercase;
      }

      .eyebrow {
        color: #4b5563;
      }

      .mini-label {
        color: #0066ff;
      }

      .muted {
        color: #535868;
      }

      .rule {
        border-top: 1px solid rgba(17, 17, 17, 0.18);
      }

      .section {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2rem;
        align-items: end;
      }

      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      .panel {
        border: 1.5px solid #111111;
        background: rgba(255, 255, 255, 0.66);
        padding: 1.1rem 1.15rem;
      }

      .offer-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .offer-title-row {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: baseline;
      }

      .offer-number {
        font-family: "IBM Plex Mono", ui-monospace, monospace;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        color: #0066ff;
      }

      .compact-list,
      .link-list {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .compact-list li + li,
      .link-list li + li {
        margin-top: 0.55rem;
      }

      .compact-list li {
        position: relative;
        padding-left: 1rem;
      }

      .compact-list li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.6rem;
        width: 0.38rem;
        height: 0.38rem;
        border-radius: 999px;
        background: #0066ff;
      }

      .proof-item + .proof-item,
      .fit-item + .fit-item {
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid rgba(17, 17, 17, 0.12);
      }

      .link-list a {
        text-decoration: underline;
        text-underline-offset: 0.18rem;
      }

      .hero-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.85rem;
      }

      @media (max-width: 800px) {
        .hero-grid,
        .two-col,
        .offer-grid,
        .hero-stats {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="sheet px-6 py-6">
      <article class="space-y-8">
        <section class="section hero-grid">
          <div class="space-y-5">
            <p class="eyebrow">Hanif Carroll · Technical Product Partner · Buenos Aires</p>
            <div class="space-y-4">
              <h1 class="display text-5xl md:text-6xl">
                MVPs and workflow automation for nontechnical founders and business owners.
              </h1>
              <p class="muted max-w-2xl text-lg leading-relaxed">
                I help clients ship useful first versions and replace repeated manual
                work with software that actually fits the business.
              </p>
            </div>
          </div>

          <div class="panel space-y-4">
            <p class="mini-label">When to send me to someone</p>
            <p class="display text-2xl">
              There is a real bottleneck, and they need someone to build the fix.
            </p>
            <div class="hero-stats">
              <div>
                <p class="display text-2xl">8+</p>
                <p class="muted text-sm">years building products</p>
              </div>
              <div>
                <p class="display text-2xl">Direct</p>
                <p class="muted text-sm">senior execution, no agency layer</p>
              </div>
              <div>
                <p class="display text-2xl">Fast</p>
                <p class="muted text-sm">clear scope, short feedback loops</p>
              </div>
            </div>
          </div>
        </section>

        <section class="section rule pt-7">
          <div class="mb-5 flex items-end justify-between gap-6">
            <div>
              <p class="mini-label">Two ways I help</p>
              <h2 class="display mt-2 text-3xl">
                One track for new products, one for operational drag.
              </h2>
            </div>
            <p class="muted max-w-sm text-sm leading-relaxed">
              The common thread is the same: cut through ambiguity, build the useful
              thing first, and keep communication plain.
            </p>
          </div>

          <div class="offer-grid">
            {offerTracks.map((track) => (
              <section class="panel section">
                <div class="offer-title-row">
                  <p class="mini-label">{track.title}</p>
                  <span class="offer-number">{track.label}</span>
                </div>
                <p class="muted mt-3 text-[15px] leading-relaxed">{track.intro}</p>
                <ul class="compact-list mt-5 muted text-[15px] leading-relaxed">
                  {track.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>

        <section class="section two-col rule pt-7">
          <div class="space-y-5">
            <div>
              <p class="mini-label">Recent work</p>
              <h2 class="display mt-2 text-3xl">
                Recent projects clients can map themselves to quickly.
              </h2>
            </div>
            <div>
              {proofItems.map((item) => (
                <div class="proof-item">
                  <p class="font-semibold">{item.name}</p>
                  <p class="muted mt-1 text-sm leading-relaxed">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="space-y-5">
            <div>
              <p class="mini-label">Good referrals</p>
              <h2 class="display mt-2 text-3xl">
                Best fit for people who can decide and want momentum.
              </h2>
            </div>
            <div>
              {fitSignals.map((signal) => (
                <div class="fit-item">
                  <p class="muted text-sm leading-relaxed">{signal}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="section two-col rule pt-7">
          <div class="space-y-5">
            <div>
              <p class="mini-label">How engagements start</p>
              <h2 class="display mt-2 text-3xl">
                Start with a roadmap call, then scope the right first step.
              </h2>
            </div>
            <div class="space-y-3 muted text-sm leading-relaxed">
              <p>
                MVP builds start at <strong style="color:#111111;">$10,000</strong> for a
                focused four-week build.
              </p>
              <p>
                Workflow automation and AI work is scoped after looking at the current
                workflow, systems, and the actual bottleneck.
              </p>
              <p>
                In both cases, the first call is for narrowing the problem and deciding
                whether I am the right fit.
              </p>
            </div>
          </div>

          <div class="panel space-y-5">
            <div>
              <p class="mini-label">Forward or send directly</p>
              <h2 class="display mt-2 text-3xl">
                If someone needs help shipping or cleaning up operations, send this.
              </h2>
            </div>
            <ul class="link-list text-sm leading-relaxed">
              {links.map((link) => (
                <li>
                  <span class="font-semibold">{link.label}:</span>{" "}
                  <a href={link.href}>{link.href.replace("https://", "")}</a>
                </li>
              ))}
              <li>
                <span class="font-semibold">Email:</span>{" "}
                <a href="mailto:HanifCarroll@gmail.com">HanifCarroll@gmail.com</a>
              </li>
            </ul>
          </div>
        </section>
      </article>
    </main>
  </body>
</html>
