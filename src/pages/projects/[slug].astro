---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCallout from '../../components/ServiceCallout.astro';
import TestimonialBillboard from '../../components/TestimonialBillboard.astro';
import ProjectVideo from '../../components/project-video/ProjectVideo.astro';
import type { Project } from '@src/lib/types/project';
import { getProject } from '@src/lib/projects';
import { getProjectImage } from '@src/lib/project-images';
import { getProjectTrackMeta } from '@src/lib/project-tracks';

interface PageProps {
	project: Project;
	caseStudy: CollectionEntry<'caseStudies'>;
}

export async function getStaticPaths() {
	const caseStudies = await getCollection('caseStudies');

	return caseStudies.map((caseStudy) => {
		const slug = caseStudy.id;
		const project = getProject(slug);

		if (!project) {
			throw new Error(`Missing project metadata for case study "${slug}".`);
		}

		return {
			params: { slug },
			props: { project, caseStudy }
		};
	});
}

const { project, caseStudy } = Astro.props as PageProps;
const trackMeta = getProjectTrackMeta(project.track);
const caseStudyVariant = trackMeta.ctaVariant;
const { Content } = await render(caseStudy);
const heroImage = getProjectImage(project, 'hero');
const seoTitle = project.seoTitle ?? `${project.title} · Case Study`;
const seoDescription = project.seoDescription ?? project.description;
const canonicalUrl = new URL(`/projects/${project.slug}/`, Astro.site).toString();
const caseStudyJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: project.title,
	headline: seoTitle,
	description: seoDescription,
	url: canonicalUrl,
	creator: {
		'@type': 'Person',
		name: 'Hanif Carroll',
		url: 'https://www.hanifcarroll.com/'
	},
	about: [project.client, project.service, ...project.technologies.slice(0, 6)],
	datePublished: project.year?.split('-')[0]
};

const caseStudyFacts = [
	{ label: 'Role', value: project.role },
	{ label: 'Timeline', value: project.timeline ?? project.year },
	{ label: 'Team', value: project.teamSize },
	{ label: 'Service', value: project.service }
].filter((detail): detail is { label: string; value: string } => Boolean(detail.value));

const firstResult = Array.isArray(project.result) ? project.result[0] : project.result;
const firstProblem = Array.isArray(project.problem) ? project.problem[0] : project.problem;
const firstSolution = Array.isArray(project.solution) ? project.solution[0] : project.solution;
const overviewVideo = project.videos?.overview;
const proofSnapshot = [
	{ label: 'Starting Point', value: firstProblem },
	{ label: 'What Shipped', value: project.deliveryHighlights?.[0] ?? firstSolution },
	{ label: 'Why It Mattered', value: firstResult }
].filter((detail): detail is { label: string; value: string } => Boolean(detail.value));

const heroActions = [
	project.liveUrl && {
		label: 'Visit live product',
		href: project.liveUrl,
		trackEvent: 'project_live_site_clicked',
		trackLocation: 'project_detail_hero',
		external: true
	},
	project.repository && {
		label: 'View repository',
		href: project.repository,
		trackEvent: 'project_repository_clicked',
		trackLocation: 'project_detail_hero',
		external: true
	}
].filter((action): action is { label: string; href: string; trackEvent: string; trackLocation: string; external: boolean } =>
	Boolean(action)
);
---

<BaseLayout
	title={seoTitle}
	description={seoDescription}
	image={heroImage?.src}
	jsonLd={caseStudyJsonLd}
	showFooterCta={false}
	footerLinksOnly
>
	<article
		class:list={[
			'container max-w-6xl space-y-14 py-8 md:space-y-16 md:py-10',
			`case-study-detail case-study-detail--${project.detailVariant}`
		]}
	>
		<header class='case-study-detail__hero case-study-detail__hero--product'>
			<div class='case-study-detail__hero-body case-study-detail__hero-body--product'>
				<div class='case-study-detail__hero-copy space-y-5'>
					<h1
						class='heading-display heading-display--hero'
						data-fit-heading
						data-fit-min-rem='1.75'
						data-fit-max-rem='7.2'
						data-fit-lines-desktop='3'
						data-fit-lines-mobile='3'
						data-fit-lines-narrow-mobile='3'
					>
						{project.title}
					</h1>
					<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>{project.description}</p>
					<div class='case-study-detail__hero-actions'>
						{
							heroActions.map((action, index) => (
								<a
									class={index === 0 ? 'home-hero-primary-link' : 'fit-secondary-link'}
									href={action.href}
									target={action.external ? '_blank' : undefined}
									rel={action.external ? 'noopener noreferrer' : undefined}
									data-track-event={action.trackEvent}
									data-track-location={action.trackLocation}
								>
									{action.label}
								</a>
							))
						}
					</div>
				</div>

				<aside class='case-study-detail__hero-facts'>
					{
						caseStudyFacts.map((detail) => (
							<div class='case-study-detail__hero-fact'>
								<p>{detail.label}</p>
								<strong>{detail.value}</strong>
							</div>
						))
					}
				</aside>
			</div>
		</header>

		{
			overviewVideo && (
				<ProjectVideo
					video={overviewVideo}
					title={`${project.title} overview`}
					description='A short overview of the problem, solution, and result.'
				/>
			)
		}

		<section class='case-study-detail__proof-snapshot' aria-label='Case study proof points'>
			<div class:list={['case-study-detail__proof-snapshot-grid', `case-study-detail__proof-snapshot-grid--${proofSnapshot.length}`]}>
				{
					proofSnapshot.map((detail) => (
						<div class='case-study-detail__proof-snapshot-item'>
							<p>{detail.label}</p>
							<strong>{detail.value}</strong>
						</div>
					))
				}
			</div>
		</section>

		<Content />

		{
			project.technologies.length > 0 && (
				<section class='case-study-detail__editorial-section'>
					<h2>Tech Stack</h2>
					<div class='case-study-detail__editorial-copy'>
						<div class='flex flex-wrap gap-2'>
							{project.technologies.map((tech) => (
								<span class='tech-tag'>{tech}</span>
							))}
						</div>
						{(project.liveUrl || project.repository) && (
							<div class='case-study-detail__actions'>
								{project.liveUrl && (
									<a
										class='btn-secondary'
										href={project.liveUrl}
										target='_blank'
										rel='noopener noreferrer'
										data-track-event='project_live_site_clicked'
										data-track-location='project_detail'
									>
										Visit Live Site
										<span>&rarr;</span>
									</a>
								)}
								{project.repository && (
									<a
										class='btn-secondary'
										href={project.repository}
										target='_blank'
										rel='noopener noreferrer'
										data-track-event='project_repository_clicked'
										data-track-location='project_detail'
									>
										View Repository
										<span>&rarr;</span>
									</a>
								)}
							</div>
						)}
					</div>
				</section>
			)
		}

		{
			project.proofQuote && (
				<TestimonialBillboard
					quote={project.proofQuote.quote}
					name={project.proofQuote.author}
					role={project.proofQuote.role ?? 'Client'}
					label='Proof'
				/>
			)
		}

		<ServiceCallout variant={caseStudyVariant} context='case-study' location={`case_study_${project.slug}`} />

		<div class='pt-8'>
			<a href='/projects/' class='arrow-link'>Back to All Case Studies</a>
		</div>
	</article>
</BaseLayout>
