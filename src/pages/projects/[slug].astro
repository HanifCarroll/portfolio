---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCallout from "../../components/ServiceCallout.astro";
import type { Project } from "@src/lib/types/project";
import { getAllProjects } from "@src/lib/projects";
import { getProjectTrackMeta } from "@src/lib/project-tracks";

// Import all project images statically
import baEventosHero from "@src/assets/img/projects/ba-eventos-hero.png";
import baEventosFeature from "@src/assets/img/projects/ba-eventos-feature.png";
import hablabaHero from "@src/assets/img/projects/hablaba-hero.png";
import hablabaFeature from "@src/assets/img/projects/hablaba-feature.png";
import muchoHangoutsHero from "@src/assets/img/projects/mucho-hangouts-hero.png";
import muchoHangoutsFeature from "@src/assets/img/projects/mucho-hangouts-feature.png";
import genruptHero from "@src/assets/img/projects/genrupt-hero.png";
import genruptFeature from "@src/assets/img/projects/genrupt-feature.png";
import voxPrismaticHero from "@src/assets/img/projects/vox-prismatic-hero.png";
import voxPrismaticFeature from "@src/assets/img/projects/vox-prismatic-feature.png";
import casaElariaHero from "@src/assets/img/projects/casa-elaria-hero.png";
import casaElariaFeature from "@src/assets/img/projects/casa-elaria-feature.png";
import desarmaderoHero from "@src/assets/img/projects/desarmadero-hero.png";
import desarmaderoFeature from "@src/assets/img/projects/desarmadero-feature.png";
import maximoHero from "@src/assets/img/projects/maximo-hero.png";
import maximoFeature from "@src/assets/img/projects/maximo-feature.png";
import redwriterHero from "@src/assets/img/projects/redwriter-hero.png";
import redwriterFeature from "@src/assets/img/projects/redwriter-feature.png";

interface PageProps {
    project: Project;
}

export async function getStaticPaths() {
    return getAllProjects().map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props as PageProps;
const trackMeta = getProjectTrackMeta(project.track);
const caseStudyVariant = trackMeta.ctaVariant;
const firstText = (value: string | string[]) =>
    Array.isArray(value) ? value[0] : value;
const problemSummary = firstText(project.problem);
const outcomeSummary = firstText(project.result);
const engagementDetails = [
    { label: "Client", value: project.client },
    { label: "Service", value: project.service },
    { label: "Track", value: trackMeta.label },
    { label: "Role", value: project.role },
].filter(
    (detail): detail is { label: string; value: string } => Boolean(detail.value),
);

// Map project slugs to static image imports
const imageMap: Record<
    string,
    { hero: ImageMetadata; feature: ImageMetadata }
> = {
    "ba-eventos": { hero: baEventosHero, feature: baEventosFeature },
    "language-exchange": { hero: hablabaHero, feature: hablabaFeature },
    "mucho-hangouts": { hero: muchoHangoutsHero, feature: muchoHangoutsFeature },
    "genrupt": { hero: genruptHero, feature: genruptFeature },
    "vox-prismatic": { hero: voxPrismaticHero, feature: voxPrismaticFeature },
    "casa-elaria": { hero: casaElariaHero, feature: casaElariaFeature },
    "desarmadero-latorre": { hero: desarmaderoHero, feature: desarmaderoFeature },
    "maximo-interiorismo": { hero: maximoHero, feature: maximoFeature },
    "redwriter-comics": { hero: redwriterHero, feature: redwriterFeature },
};

const images = imageMap[project.slug];
---

<BaseLayout
    title={`${project.title} · Case Study`}
    description={project.description}
    image={images?.hero?.src}
    showFooterCta={false}
    footerLinksOnly
>
    <article class="container max-w-5xl space-y-16 py-10">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 font-mono text-xs uppercase tracking-wide">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="text-zinc-400">/</span>
            <a href="/projects/" class="hover:text-primary transition-colors">Case Studies</a>
            <span class="text-zinc-400">/</span>
            <span class="text-primary">{project.title}</span>
        </nav>

        <header class="space-y-8">
            <div class="space-y-4">
                <span class="section-label">// Case Study</span>
                <h1 class="heading-display text-4xl md:text-5xl">
                    {project.title}
                </h1>
                <div class="tech-card p-6">
                    <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed max-w-4xl">
                        {project.description}
                    </p>
                </div>
            </div>

            <div class="tech-card p-6">
                <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr] lg:gap-10">
                    <div class="space-y-6">
                        <div class="space-y-3">
                            <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                                What changed
                            </p>
                            <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
                                {outcomeSummary}
                            </p>
                        </div>

                        <dl class="grid gap-4 sm:grid-cols-2">
                            {engagementDetails.map((detail) => (
                                <div class="border-t border-black/10 pt-4 text-sm dark:border-white/10">
                                    <dt class="font-mono text-[11px] uppercase tracking-[0.24em] text-primary">
                                        {detail.label}
                                    </dt>
                                    <dd class="mt-2 text-base font-medium text-zinc-900 dark:text-zinc-100">
                                        {detail.value}
                                    </dd>
                                </div>
                            ))}
                        </dl>
                    </div>

                    <div class="space-y-6 border-t border-black/10 pt-6 dark:border-white/10 lg:border-t-0 lg:border-l lg:pl-8 lg:pt-0">
                        <div class="space-y-3">
                            <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                                Why it mattered
                            </p>
                            <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                                {problemSummary}
                            </p>
                        </div>

                        <div class="space-y-3">
                            <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                                Built with
                            </p>
                            <div class="flex flex-wrap gap-2">
                                {project.technologies.map((tech) => (
                                    <span class="tech-tag">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-3">
                            {
                                project.liveUrl && (
                                    <a
                                        class="btn-primary"
                                        href={project.liveUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        data-track-event="project_live_site_clicked"
                                        data-track-location="project_detail"
                                    >
                                        Visit Live Site
                                        <span>&rarr;</span>
                                    </a>
                                )
                            }
                            {
                                project.repository && (
                                    <a
                                        class="btn-secondary"
                                        href={project.repository}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        View Code
                                        <span>&rarr;</span>
                                    </a>
                                )
                            }
                        </div>
                    </div>
                </div>
            </div>

            {
                images?.hero && (
                    <figure class="overflow-hidden border-2 border-black dark:border-white">
                        <Image
                            src={images.hero}
                            alt={`${project.title} hero preview`}
                            class="w-full object-cover"
                            loading="eager"
                        />
                    </figure>
                )
            }
        </header>

        <section class="tech-card p-6 md:p-8 space-y-12">
            <div class="space-y-4">
                <h2 class="section-label">// What Was Happening</h2>
                <div class="max-w-4xl space-y-4">
                    {
                        Array.isArray(project.problem) ? (
                            project.problem.map((p) => (
                                <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                    {p}
                                </p>
                            ))
                        ) : (
                            <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                {project.problem}
                            </p>
                        )
                    }
                </div>
            </div>

            <div class="grid-line-horizontal"></div>

            <div class="space-y-4">
                <h2 class="section-label">// What I Built</h2>
                <div class="max-w-4xl space-y-4">
                    {
                        Array.isArray(project.solution) ? (
                            project.solution.map((s) => (
                                <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                    {s}
                                </p>
                            ))
                        ) : (
                            <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                {project.solution}
                            </p>
                        )
                    }
                </div>
            </div>

            <div class="grid-line-horizontal"></div>

            <div class="space-y-4">
                <h2 class="section-label">// What Changed</h2>
                <div class="max-w-4xl space-y-4">
                    {
                        Array.isArray(project.result) ? (
                            project.result.map((r) => (
                                <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                    {r}
                                </p>
                            ))
                        ) : (
                            <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed">
                                {project.result}
                            </p>
                        )
                    }
                </div>
            </div>
        </section>

        {
            images?.feature && (
                <figure class="overflow-hidden border-2 border-black dark:border-white">
                    <Image
                        src={images.feature}
                        alt={`${project.title} feature preview`}
                        loading="lazy"
                        class="w-full object-cover"
                    />
                </figure>
            )
        }

        <ServiceCallout
            variant={caseStudyVariant}
            context="case-study"
            location={`case_study_${project.slug}`}
        />

        <!-- Back to projects -->
        <div class="pt-8">
            <a href="/projects/" class="arrow-link">
                Back to All Case Studies
            </a>
        </div>
    </article>
</BaseLayout>
