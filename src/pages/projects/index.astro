---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectVideoCard from '../../components/project-video/ProjectVideoCard.astro';
import { projects } from '../../lib/project-cards';
import { PROJECT_INDEX_ORDER } from '../../lib/project-curation';

const title = 'Case Studies';
const description = 'Selected work by Hanif Carroll: AI products, web and mobile builds, and the product decisions behind them.';

const orderProjects = (projectList: typeof projects, preferredOrder: readonly string[]) => {
	const orderMap = new Map(preferredOrder.map((slug, index) => [slug, index]));

	return [...projectList].sort((a, b) => {
		const aIndex = orderMap.get(a.slug) ?? Number.MAX_SAFE_INTEGER;
		const bIndex = orderMap.get(b.slug) ?? Number.MAX_SAFE_INTEGER;
		return aIndex - bIndex;
	});
};

const orderedProjects = orderProjects(projects, PROJECT_INDEX_ORDER);
const leadProject = orderedProjects[0];
const priorityProjects = orderedProjects.slice(1, 5);
const compactProjects = orderedProjects.slice(5);
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly>
	<article class='projects-index container max-w-6xl py-8 md:py-10'>
		<header class='projects-index__hero'>
			<div class='projects-index__hero-main'>
				<h1 class='heading-display heading-display--hero' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='6.8'>
					Selected work
				</h1>
			</div>
		</header>

		{
			leadProject && (
				<section class='projects-index__ranked-work' aria-label='Ranked project work'>
					<ProjectVideoCard project={leadProject} variant='lead' />

					{
						priorityProjects.length > 0 && (
							<div class='projects-index__priority-grid'>
								{priorityProjects.map((project) => (
									<ProjectVideoCard project={project} variant='card' />
								))}
							</div>
						)
					}

					{
						compactProjects.length > 0 && (
							<div class='projects-index__compact-list'>
								{compactProjects.map((project) => (
									<ProjectVideoCard project={project} variant='compact' />
								))}
							</div>
						)
					}
				</section>
			)
		}
	</article>
</BaseLayout>
