---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../lib/project-cards';

import baEventosHero from '@src/assets/img/projects/ba-eventos-hero.png';
import casaElariaHero from '@src/assets/img/projects/casa-elaria-hero.png';
import desarmaderoHero from '@src/assets/img/projects/desarmadero-hero.png';
import genruptHero from '@src/assets/img/projects/genrupt-hero.png';
import palabrunoHero from '@src/assets/img/projects/palabruno-teacher-library.png';
import muchoHangoutsHero from '@src/assets/img/projects/mucho-hangouts-hero.png';
import hablabaHero from '@src/assets/img/projects/hablaba-hero.png';
import maximoHero from '@src/assets/img/projects/maximo-hero.png';
import redwriterHero from '@src/assets/img/projects/redwriter-hero.png';
import voxPrismaticHero from '@src/assets/img/projects/vox-prismatic-hero.png';

const title = 'Case Studies';
const description = 'Selected case studies from MVP builds, launch sites, and workflow systems by Hanif Carroll.';

const preferredClientOrder = [
	'palabruno',
	'desarmadero-latorre',
	'genrupt',
	'casa-elaria',
	'mucho-hangouts',
	'maximo-interiorismo',
	'redwriter-comics'
] as const;

const preferredExperimentOrder = ['ba-eventos', 'language-exchange', 'vox-prismatic'] as const;

const orderProjects = (projectList: typeof projects, preferredOrder: readonly string[]) => {
	const orderMap = new Map(preferredOrder.map((slug, index) => [slug, index]));

	return [...projectList].sort((a, b) => {
		const aIndex = orderMap.get(a.slug) ?? Number.MAX_SAFE_INTEGER;
		const bIndex = orderMap.get(b.slug) ?? Number.MAX_SAFE_INTEGER;
		return aIndex - bIndex;
	});
};

const clientProjects = orderProjects(
	projects.filter((project) => project.proofType === 'client'),
	preferredClientOrder
);

const experimentProjects = orderProjects(
	projects.filter((project) => project.proofType === 'experiment'),
	preferredExperimentOrder
);

const featuredProject = clientProjects[0];
const archiveProjects = clientProjects.slice(1);

const imageMap = {
	palabruno: palabrunoHero,
	'desarmadero-latorre': desarmaderoHero,
	genrupt: genruptHero,
	'casa-elaria': casaElariaHero,
	'mucho-hangouts': muchoHangoutsHero,
	'language-exchange': hablabaHero,
	'maximo-interiorismo': maximoHero,
	'redwriter-comics': redwriterHero,
	'ba-eventos': baEventosHero,
	'vox-prismatic': voxPrismaticHero
} as const;

const featuredOutcomeHighlights = {
	palabruno:
		'Palabruno moved from rough founder idea to paid MVP with mobile subscriptions, teacher payments on the web, app store launch assets, and launch-ready positioning.',
	'desarmadero-latorre': 'The business gained a 24/7 inventory channel and fewer repetitive stock calls.',
	genrupt: 'Genrupt moved from demo-stage AI generation toward a more reliable seller platform.',
	'casa-elaria': 'The fake-door storefront tested buyer intent before inventory spend.',
	'mucho-hangouts': 'The product became more reliable while the team kept shipping.',
	'maximo-interiorismo': 'The designer gained a cleaner public home for high-value project conversations.',
	'redwriter-comics': 'The artist gained a professional portfolio hub for editors and commissions.'
} as const;
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly>
	<article class='projects-index container max-w-6xl space-y-16 py-8 md:space-y-24 md:py-10'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Case Studies</span>
		</nav>

		<header class='projects-index__hero'>
			<h1 class='heading-display heading-display--hero' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='6.6'>
				Case studies with the work in context.
			</h1>
			<div class='projects-index__hero-copy'>
				<p class='launch-meta text-primary'>Selected Work</p>
				<p>
					MVP launches, workflow systems, AI product foundations, and launch sites. Each case study shows the product judgment around the
					build, not just the final screen.
				</p>
			</div>
		</header>

		{
			featuredProject && (
				<section class='projects-index__section'>
					<h2>Featured</h2>
					<div class='projects-index__section-body'>
						<a href={`/projects/${featuredProject.slug}/`} class='projects-index__feature group'>
							<figure class='projects-index__feature-media'>
								<Image
									src={imageMap[featuredProject.slug as keyof typeof imageMap]}
									alt={featuredProject.name}
									class='projects-index__image transition duration-700 ease-out group-hover:scale-[1.015]'
									loading='eager'
								/>
							</figure>
							<div class='projects-index__feature-copy'>
								<p class='launch-meta text-primary'>{featuredProject.trackLabel}</p>
								<h3 class='heading-display heading-display--section'>{featuredProject.name}</h3>
								<p>{featuredProject.description}</p>
								<div class='projects-index__fact'>
									<p class='launch-meta text-primary'>What changed</p>
									<p>
										{featuredOutcomeHighlights[featuredProject.slug as keyof typeof featuredOutcomeHighlights] ?? featuredProject.outcome}
									</p>
								</div>
								<span class='arrow-link w-fit'>Read case study</span>
							</div>
						</a>
					</div>
				</section>
			)
		}

		<section class='projects-index__section'>
			<h2>Client Work</h2>
			<div class='projects-index__section-body projects-index__rows'>
				{
					archiveProjects.map((project) => (
						<article class='projects-index__row'>
							<a href={`/projects/${project.slug}/`} class='projects-index__row-media group'>
								<Image
									src={imageMap[project.slug as keyof typeof imageMap]}
									alt={project.name}
									class='projects-index__image transition duration-700 ease-out group-hover:scale-[1.02]'
									loading='lazy'
								/>
							</a>
							<div class='projects-index__row-copy'>
								<p class='launch-meta text-primary'>{project.trackLabel}</p>
								<h3 class='heading-display heading-display--subsection'>
									<a href={`/projects/${project.slug}/`}>{project.name}</a>
								</h3>
								<p>{project.description}</p>
								<div class='projects-index__fact'>
									<p class='launch-meta text-primary'>Outcome</p>
									<p>{featuredOutcomeHighlights[project.slug as keyof typeof featuredOutcomeHighlights] ?? project.outcome}</p>
								</div>
								<div class='projects-index__links'>
									<a href={`/projects/${project.slug}/`} class='arrow-link'>
										Read case study
									</a>
									{project.demoLink && (
										<a
											href={project.demoLink}
											target='_blank'
											rel='noopener noreferrer'
											class='case-studies-live-link'
											data-track-event='project_live_site_clicked'
											data-track-location='projects_archive'
										>
											Visit live site
										</a>
									)}
								</div>
							</div>
						</article>
					))
				}
			</div>
		</section>

		{
			experimentProjects.length > 0 && (
				<section class='projects-index__section'>
					<h2>Experiments</h2>
					<div class='projects-index__section-body projects-index__rows'>
						{experimentProjects.map((project) => (
							<article class='projects-index__row projects-index__row--compact'>
								<a href={`/projects/${project.slug}/`} class='projects-index__row-media group'>
									<Image
										src={imageMap[project.slug as keyof typeof imageMap]}
										alt={project.name}
										class='projects-index__image transition duration-700 ease-out group-hover:scale-[1.02]'
										loading='lazy'
									/>
								</a>
								<div class='projects-index__row-copy'>
									<p class='launch-meta text-primary'>{project.trackLabel}</p>
									<h3 class='heading-display heading-display--subsection'>
										<a href={`/projects/${project.slug}/`}>{project.name}</a>
									</h3>
									<p>{project.description}</p>
									<a href={`/projects/${project.slug}/`} class='arrow-link w-fit'>
										Read case study
									</a>
								</div>
							</article>
						))}
					</div>
				</section>
			)
		}
	</article>
</BaseLayout>
