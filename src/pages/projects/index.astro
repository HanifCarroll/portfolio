---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectList from "../../components/ProjectList.astro";
import { projects } from "../../lib/project-cards";
import { projectTrackGroups } from "../../lib/project-tracks";

const title = "Case Studies";
const description =
    "Case studies from product builds and automation work by Hanif Carroll.";

const projectSections = projectTrackGroups
    .map((group) => ({
        ...group,
        projects: projects.filter((project) => project.trackGroup === group.key),
    }))
    .filter((group) => group.projects.length > 0);
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description}>
    <article class="container max-w-6xl space-y-16 py-10">
        <nav class="flex items-center gap-2 font-mono text-xs uppercase tracking-wide">
            <a href="/" class="transition-colors hover:text-primary">Home</a>
            <span class="text-zinc-400">/</span>
            <span class="text-primary">Case Studies</span>
        </nav>

        <header class="space-y-6">
            <span class="section-label">// Case Studies</span>
            <h1 class="heading-display text-4xl md:text-5xl">
                Case studies grouped by the problem they solved.
            </h1>
            <div class="tech-card p-6 md:p-8">
                <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
                    Start with the kind of problem you are trying to solve: shipping a
                    first version, cleaning up a workflow, or building a site that
                    supports the launch.
                </p>
            </div>
        </header>

        <div class="space-y-16">
            {projectSections.map((section) => (
                <section class="space-y-6">
                    <div class="max-w-3xl space-y-3">
                        <p class="font-mono text-xs uppercase tracking-[0.28em] text-primary">
                            {section.title}
                        </p>
                        <p class="text-base leading-7 text-zinc-600 dark:text-zinc-300">
                            {section.description}
                        </p>
                    </div>
                    <ProjectList projects={section.projects} />
                </section>
            ))}
        </div>
    </article>
</BaseLayout>
