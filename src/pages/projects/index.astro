---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import ServiceCallout from '../../components/ServiceCallout.astro';
import { projects } from '../../lib/project-cards';

const title = 'Case Studies';
const description = 'Case studies from product builds and automation work by Hanif Carroll.';

const preferredClientOrder = [
	'desarmadero-latorre',
	'genrupt',
	'casa-elaria',
	'mucho-hangouts',
	'maximo-interiorismo',
	'redwriter-comics'
] as const;

const preferredExperimentOrder = ['ba-eventos', 'language-exchange', 'vox-prismatic'] as const;

const sortByPreferredOrder = (projectList: typeof projects, preferredOrder: readonly string[]) => {
	const orderMap = new Map(preferredOrder.map((slug, index) => [slug, index]));

	return [...projectList].sort((a, b) => {
		const aIndex = orderMap.get(a.slug) ?? Number.MAX_SAFE_INTEGER;
		const bIndex = orderMap.get(b.slug) ?? Number.MAX_SAFE_INTEGER;

		if (aIndex !== bIndex) return aIndex - bIndex;
		return 0;
	});
};

const clientProjects = sortByPreferredOrder(
	projects.filter((project) => project.proofType === 'client'),
	preferredClientOrder
);

const experimentProjects = sortByPreferredOrder(
	projects.filter((project) => project.proofType === 'experiment'),
	preferredExperimentOrder
);
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly>
	<article class='container max-w-6xl space-y-20 py-10 md:space-y-24'>
		<nav class='flex items-center gap-2 font-mono text-xs uppercase tracking-wide'>
			<a href='/' class='transition-colors hover:text-primary'>Home</a>
			<span class='text-zinc-400'>/</span>
			<span class='text-primary'>Case Studies</span>
		</nav>

		<header class='max-w-4xl space-y-5'>
			<p class='section-label'>// Case Studies</p>
			<h1 class='heading-display text-4xl md:text-6xl'>Find the closest match for the kind of problem you have.</h1>
			<p class='max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300'>
				Start with client work if you want the clearest signal of what it is like to hire me. The experiments are useful too, but they are
				better for product judgment than delivery proof.
			</p>
		</header>

		<section class='space-y-8 md:space-y-10'>
			<div class='max-w-3xl space-y-4'>
				<p class='section-label'>// Client Work</p>
				<h2 class='heading-display text-3xl md:text-5xl'>Proof from paid engagements.</h2>
				<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
					These are the strongest examples of how I scope, build, and ship for real businesses. If you want to know what the work feels
					like in practice, start here.
				</p>
			</div>
			<ProjectList projects={clientProjects} />
		</section>

		{
			experimentProjects.length > 0 && (
				<section class='space-y-8 md:space-y-10'>
					<div class='max-w-3xl space-y-4'>
						<p class='section-label'>// Selected Experiments</p>
						<h2 class='heading-display text-3xl md:text-5xl'>Self-initiated product work.</h2>
						<p class='max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-300'>
							These projects show how I think when I own the problem end to end. They are useful for product taste, AI judgment, and
							workflow design, but separate from client proof.
						</p>
					</div>
					<ProjectList projects={experimentProjects} />
				</section>
			)
		}

		<ServiceCallout context='case-study' variant='general' location='projects_index' />
	</article>
</BaseLayout>
