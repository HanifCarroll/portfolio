---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../lib/project-cards';
import { CLIENT_PROJECT_ORDER, EXPERIMENT_PROJECT_ORDER, PROJECT_OUTCOME_HIGHLIGHTS } from '../../lib/project-curation';

import palabrunoHero from '@src/assets/img/projects/palabruno-reading-materials-photo.png';

const title = 'Case Studies';
const description = 'Selected product work by Hanif Carroll: AI products, web and mobile builds, and the product decisions behind them.';

const orderProjects = (projectList: typeof projects, preferredOrder: readonly string[]) => {
	const orderMap = new Map(preferredOrder.map((slug, index) => [slug, index]));

	return [...projectList].sort((a, b) => {
		const aIndex = orderMap.get(a.slug) ?? Number.MAX_SAFE_INTEGER;
		const bIndex = orderMap.get(b.slug) ?? Number.MAX_SAFE_INTEGER;
		return aIndex - bIndex;
	});
};

const clientProjects = orderProjects(
	projects.filter((project) => project.proofType === 'client'),
	CLIENT_PROJECT_ORDER
);

const experimentProjects = orderProjects(
	projects.filter((project) => project.proofType === 'experiment'),
	EXPERIMENT_PROJECT_ORDER
);

const featuredProject = clientProjects[0];
const visibleClientProjects = clientProjects.filter((project) => project.slug !== featuredProject?.slug);

const focusAreas = ['AI products', 'Product strategy', 'Forward-deployed', 'UX & launch'];
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly>
	<article class='projects-index container max-w-6xl py-8 md:py-10'>
		<header class='projects-index__hero'>
			<div class='projects-index__hero-main'>
				<h1 class='heading-display heading-display--hero' data-fit-heading data-fit-min-rem='2' data-fit-max-rem='6.8'>
					Selected product work
				</h1>
			</div>
			<div class='projects-index__hero-side'>
				<p>Product strategy, UX, and engineering, and the decisions that make a first version actually usable in the real world.</p>
				<p class='projects-index__focus-areas'>{focusAreas.join(' · ')}</p>
			</div>
		</header>

		{
			featuredProject && (
				<section class='projects-index__feature-section' aria-labelledby='featured-work-title'>
					<a href={`/projects/${featuredProject.slug}/`} class='projects-index__feature group'>
						<div class='projects-index__feature-copy'>
							<p class='section-label'>Featured Case Study</p>
							<h2 id='featured-work-title' class='heading-display heading-display--section'>
								{featuredProject.name}
							</h2>
							<p>{featuredProject.description}</p>
							<figure class='projects-index__feature-media'>
								<Image
									src={palabrunoHero}
									alt='Spanish reading materials with vocabulary, grammar, and pronunciation cards representing the Palabruno launch.'
									class='projects-index__image transition duration-700 ease-out group-hover:scale-[1.015]'
									loading='eager'
								/>
							</figure>
							<dl class='projects-index__meta'>
								<div>
									<dt>Client</dt>
									<dd>{featuredProject.client}</dd>
								</div>
								<div>
									<dt>Services</dt>
									<dd>{featuredProject.service}</dd>
								</div>
								<div>
									<dt>Result</dt>
									<dd>{PROJECT_OUTCOME_HIGHLIGHTS[featuredProject.slug] ?? featuredProject.outcome}</dd>
								</div>
							</dl>
							<span class='arrow-link w-fit'>Read case study</span>
						</div>
					</a>
				</section>
			)
		}

		<section class='projects-index__archive' aria-labelledby='client-work-title'>
			<div class='projects-index__archive-heading'>
				<h2 id='client-work-title' class='heading-display heading-display--section'>Client work</h2>
			</div>
			<div class='projects-index__rows'>
				{
					visibleClientProjects.map((project, index) => (
						<article class='projects-index__row'>
							<a href={`/projects/${project.slug}/`} class='projects-index__row-hit' aria-label={`Read ${project.name} case study`} />
							<span class='projects-index__row-number'>{String(index + 1).padStart(2, '0')}</span>
							<div class='projects-index__row-copy'>
								<h3 class='heading-display heading-display--subsection'>
									<a href={`/projects/${project.slug}/`}>{project.name}</a>
								</h3>
								<p>{PROJECT_OUTCOME_HIGHLIGHTS[project.slug] ?? project.outcome}</p>
							</div>
							<div class='projects-index__row-meta' aria-label={`${project.name} details`}>
								<p>
									<span>Client</span>
									{project.client}
								</p>
								<p>
									<span>Services</span>
									{project.service}
								</p>
							</div>
							<span class='projects-index__row-action'>View</span>
						</article>
					))
				}
			</div>
		</section>

		{
			experimentProjects.length > 0 && (
				<section class='projects-index__experiments' aria-labelledby='experiments-title'>
					<h2 id='experiments-title' class='heading-display heading-display--subsection projects-index__experiments-title'>
						Smaller builds and studies
					</h2>
					<div class='projects-index__experiment-list'>
						{experimentProjects.map((project) => (
							<a href={`/projects/${project.slug}/`} class='projects-index__experiment-row group'>
								<span class='projects-index__experiment-track'>{project.trackShortLabel}</span>
								<span class='projects-index__experiment-name'>{project.name}</span>
								<span class='projects-index__experiment-arrow' aria-hidden='true'>→</span>
							</a>
						))}
					</div>
				</section>
			)
		}
	</article>
</BaseLayout>
