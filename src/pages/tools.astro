---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Workflow tools';
const description = 'Local-first tools for AI agents, automation, desktop utilities, and personal workflows.';

const tools = [
	{
		name: 'codex-telegram-bridge',
		focus: 'Remote Codex control',
		body: 'A local bridge for supervising Codex work from Telegram: receive updates, reply into the right thread, inspect active runs, and approve actions away from the laptop.',
		why: 'It turns Codex Desktop from a single-machine workflow into an agent setup I can safely supervise while away.',
		repo: 'https://github.com/HanifCarroll/codex-telegram-bridge'
	},
	{
		name: 'agent-recall',
		focus: 'Session recall',
		body: 'A local SQLite FTS index over Codex, OMP, Pi, and Claude session archives, so agents can search prior work and reuse context with receipts.',
		repo: 'https://github.com/HanifCarroll/agent-recall'
	},
	{
		name: 'chatgpt-share-export',
		focus: 'Shared conversation export',
		body: 'A standard-library Python CLI that converts public ChatGPT share links or saved share-page HTML into Markdown, JSON, or plain text by decoding the embedded React Router payload.',
		repo: 'https://github.com/HanifCarroll/chatgpt-share-export'
	},
	{
		name: 'devtree',
		focus: 'Runnable worktrees',
		body: 'A Rust CLI that turns Git worktrees into runnable local environments with copied env files, setup commands, managed dev servers, stable local URLs, logs, and safe cleanup.',
		repo: 'https://github.com/HanifCarroll/devtree'
	},
	{
		name: 'mailbridge',
		focus: 'Mailbox context',
		body: 'A conservative JSON CLI over Gmail and Fastmail for search, read, thread lookup, attachment pulls, and draft-only composition.',
		repo: 'https://github.com/HanifCarroll/mailbridge'
	},
	{
		name: 'transcribe-audio',
		focus: 'Voice-note transcription',
		body: 'A Rust CLI for local audio transcription with batch runs, discoverable audio files, JSON manifests, prompt files, and combined Markdown transcripts for agent workflows.',
		repo: 'https://github.com/HanifCarroll/transcribe-audio'
	},
	{
		name: 'apartment-finder',
		focus: 'AI listing triage',
		body: 'A TanStack Start app and Bun CLI for searching Buenos Aires rentals, extracting listing evidence, and classifying whether washer access is likely in-unit or shared-building.',
		repo: 'https://github.com/HanifCarroll/apartment-finder'
	},
	{
		name: 'Folder Image Viewer',
		focus: 'Folder media review',
		body: 'A dependency-free SwiftUI macOS app for opening a folder, image, or video, scanning nearby media with optional subfolder depth and file-count limits, and reviewing it with keyboard navigation, sort/filter controls, thumbnails, GIF playback, and native video controls.',
		repo: 'https://github.com/HanifCarroll/simple-image-viewer'
	},
	{
		name: 'Task Time Tracker',
		focus: 'Menu bar time tracking',
		body: 'A minimalist SwiftUI macOS menu bar timer with a compact floating panel, task naming, count-up Free Time mode, configurable countdown mode with progress, menu controls, and one-command local install into ~/Applications.',
		repo: 'https://github.com/HanifCarroll/task-time-tracker'
	},
	{
		name: 'macos-automation-cli',
		focus: 'macOS app automation',
		body: 'A local Bun and TypeScript CLI for Mail, Calendar, Contacts, Reminders, Notes, and Messages workflows, using AppleScript, EventKit helpers, Contacts, and direct Messages database reads where each interface is strongest.',
		repo: 'https://github.com/HanifCarroll/macos-automation-cli'
	},
	{
		name: 'granola-notes-cli',
		focus: 'Meeting-note retrieval',
		body: 'A local Bun and TypeScript CLI for listing, searching, exporting, and loading Granola meeting notes and transcripts from the app cache for agent context.',
		repo: 'https://github.com/HanifCarroll/granola-notes-cli'
	}
];
---

<BaseLayout title={`${title} · Hanif Carroll`} description={description} showFooterCta={false} footerLinksOnly>
	<article class='content-page container max-w-4xl'>
		<header class='content-page__hero'>
			<h1 class='content-page__title'>Workflow tools</h1>
			<p class='content-page__lede'>
				Small systems I built to solve problems I kept running into: remote agent control, session recall, runnable worktrees, mailbox
				context, shared conversation export, meeting-note retrieval, and desktop utilities.
			</p>
		</header>

		<section aria-label='Tools'>
			<div class='content-page__list'>
				{
					tools.map((tool) => (
						<article class='content-page__entry'>
							<h2 class='content-page__entry-title'>{tool.name}</h2>
							<p class='content-page__entry-meta'>{tool.focus}</p>
							<p class='content-page__entry-body'>{tool.body}</p>
							{tool.why && <p class='content-page__entry-body'>{tool.why}</p>}
							<p class='content-page__aside'>
								<a
									href={tool.repo}
									class='content-page__link'
									target='_blank'
									rel='noopener noreferrer'
									aria-label={`View ${tool.name} repository`}
									data-track-event='tool_repo_clicked'
									data-track-location='tools_page'
								>
									View repo
								</a>
							</p>
						</article>
					))
				}
			</div>
		</section>

		<footer class='content-page__footer'>
			<a href='/projects/' class='content-page__link'>See client case studies</a>
		</footer>
	</article>
</BaseLayout>
