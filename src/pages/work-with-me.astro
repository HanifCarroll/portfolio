---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_CALL_URL } from '../consts';
import { serviceOfferList } from '../lib/service-offers';

const title = 'Work With Me';
const description =
	'Choose between a Business Systems Audit, a focused systems build, and fractional product engineering for growing teams that need software, automation, and AI support.';

const workWithMeJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: title,
	description,
	url: 'https://www.hanifcarroll.com/work-with-me/'
};
---

<BaseLayout
	title={`${title} · Hanif Carroll`}
	description={description}
	jsonLd={workWithMeJsonLd}
	showFooterCta={false}
	footerLinksOnly
	bodyClass='page-work-with-me'
>
	<article class='container work-with-me-page'>
		<header class='work-with-me-hero'>
			<h1>Build the system your business is missing.</h1>
			<p>
				If the business has outgrown spreadsheets, inboxes, manual handoffs, or scattered tools, choose the right first step: diagnose the
				system, build the first workflow, or bring in ongoing product engineering support.
			</p>
			<div class='work-with-me-actions'>
				<a
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					class='work-with-me-button'
					data-track-event='book_call_clicked'
					data-track-location='work_with_me_hero'
				>
					Book a Business Systems Audit
				</a>
				<a href='#offers' class='work-with-me-link'>Compare options</a>
			</div>
		</header>

		<section id='offers' class='work-with-me-offers' aria-label='Service options'>
			{
				serviceOfferList.map((offer) => (
					<a
						href={offer.path}
						class='work-with-me-offer'
						data-track-event='service_page_clicked'
						data-track-location={`work_with_me_${offer.key}`}
					>
						<div class='work-with-me-offer__meta'>
							<span>{offer.label}</span>
							<span>{offer.price}</span>
						</div>
						<div class='work-with-me-offer__body'>
							<h2>{offer.title}</h2>
							<p>{offer.chooserSummary}</p>
						</div>
						<ul>
							{offer.fitSignals.slice(0, 2).map((signal) => (
								<li>{signal}</li>
							))}
						</ul>
						<span class='work-with-me-link work-with-me-offer__link'>{offer.chooserCta}</span>
					</a>
				))
			}
		</section>

		<section class='work-with-me-closing' aria-labelledby='work-with-me-fit-title'>
			<div>
				<p class='work-with-me-closing__label'>Not sure which path fits?</p>
				<h2 id='work-with-me-fit-title'>Start with the constraint.</h2>
			</div>
			<div>
				<p>
					Bring the rough version. I will help decide whether this should be a Business Systems Audit, a focused systems build, fractional
					product engineering, or a smaller first step.
				</p>
				<a
					href={BOOK_CALL_URL}
					target='_blank'
					rel='noopener noreferrer'
					class='work-with-me-link'
					data-track-event='book_call_clicked'
					data-track-location='work_with_me_final'
				>
					Book a Business Systems Audit
				</a>
			</div>
		</section>
	</article>
</BaseLayout>
